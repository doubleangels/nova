<!-- User info at bottom -->
<% if (typeof user !== 'undefined' && user) { %>
  <div class="sb-footer border-t border-white/5 p-4 bg-white/[0.01]">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3 min-w-0">
        <div class="relative">
            <% if (user.avatar) { %>
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=32"
                    class="w-8 h-8 rounded-lg flex-shrink-0 ring-1 ring-white/10" alt="Avatar" />
            <% } else { %>
                <div class="w-8 h-8 rounded-lg flex items-center justify-center text-xs text-white flex-shrink-0"
                    style="background:var(--c-accent)">
                    <%= user.username.slice(0,2).toUpperCase() %>
                </div>
            <% } %>
            <div class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 bg-green-500 border-2 border-[var(--c-sidebar)] rounded-full"></div>
        </div>
        <div class="min-w-0">
            <p class="sb-username text-xs font-bold truncate text-[var(--c-text)]">
                <%= user.username %>
            </p>
            <p class="text-[9px] text-[var(--c-text-dim)] uppercase tracking-tighter">Administrator</p>
        </div>
      </div>
      <a href="/auth/logout" class="p-2 rounded-lg hover:bg-red-500/10 text-red-400/60 hover:text-red-400 transition-all" title="Logout">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
      </a>
    </div>
  </div>
<% } %>