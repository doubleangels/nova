<!-- Sidebar header -->
<div class="sb-header p-6 border-b border-white/5 bg-white/[0.02] hidden lg:flex flex-col">
  <div class="flex items-center gap-3">
    <% if (typeof guildIcon !== 'undefined' && guildIcon) { %>
      <div class="relative group">
        <div class="absolute inset-0 bg-[var(--c-accent)] blur-lg opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <img src="<%= guildIcon %>" class="relative w-10 h-10 rounded-xl ring-1 ring-white/10" alt="Server icon" />
      </div>
    <% } else { %>
      <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0"
        style="background:var(--c-accent)">N</div>
    <% } %>
    <div class="min-w-0">
      <p class="sb-guild-name font-bold leading-tight text-sm truncate">
        <%= typeof guildName !== 'undefined' ? guildName : 'Da Frens' %>
      </p>
      <p class="sb-sub text-[10px] tracking-wide opacity-50 font-bold">Nova</p>
    </div>
  </div>
</div>

