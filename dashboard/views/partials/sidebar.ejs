<!-- Sidebar header -->
<div class="sb-header p-5 border-b">
  <div class="flex items-center gap-3">
    <% if (typeof guildIcon !== 'undefined' && guildIcon) { %>
      <img src="<%= guildIcon %>" class="w-9 h-9 rounded-full ring-2" style="--tw-ring-color: var(--c-accent);" alt="Server icon" />
    <% } else { %>
      <div class="w-9 h-9 rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0" style="background:var(--c-accent)">N</div>
    <% } %>
    <div>
      <p class="sb-guild-name font-semibold leading-tight text-sm"><%= typeof guildName !== 'undefined' ? guildName : 'Da Frens' %></p>
      <p class="sb-sub text-xs">Nova Dashboard</p>
    </div>
  </div>
</div>

<!-- Navigation links -->
<nav class="flex-1 px-3 py-4 space-y-1 text-sm">
  <p class="sb-section-label px-2 text-xs font-semibold uppercase tracking-wider mb-2">Configuration</p>

  <a href="#general" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg transition-colors">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
    </svg>
    Bot Settings
  </a>

  <a href="#roles" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg transition-colors">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
    </svg>
    Role Configuration
  </a>

  <a href="#moderation" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg transition-colors">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
    </svg>
    Moderation
  </a>

  <a href="#reminders" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg transition-colors">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
    </svg>
    Reminders
  </a>

  <a href="#channels" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg transition-colors">
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
    </svg>
    Channels
  </a>
</nav>

<!-- User info at bottom -->
<% if (typeof user !== 'undefined' && user) { %>
<div class="sb-footer border-t p-4">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2 min-w-0">
      <% if (user.avatar) { %>
        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=32"
             class="w-8 h-8 rounded-full flex-shrink-0" alt="Avatar" />
      <% } else { %>
        <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs text-white flex-shrink-0" style="background:var(--c-accent)">
          <%= user.username.slice(0,2).toUpperCase() %>
        </div>
      <% } %>
      <span class="sb-username text-sm truncate"><%= user.username %></span>
    </div>
    <a href="/auth/logout" class="text-xs ml-2 flex-shrink-0" style="color:var(--c-text-dim)" onmouseover="this.style.color='#f87171'" onmouseout="this.style.color='var(--c-text-dim)'">Logout</a>
  </div>
</div>
<% } %>
