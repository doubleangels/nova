    if (autoReactionsSaving) return;
    autoReactionsSaving = true;
    const rows = document.querySelectorAll('#autoReactionTableBody tr');
    const reactions = [];
    
    rows.forEach((row) => {
      const pattern = row.querySelector('.ar-pattern')?.value.trim();
      const emoji = row.querySelector('.ar-emoji')?.value.trim();
      const useRegex = row.querySelector('.ar-use-regex')?.checked;
      if (!pattern || !emoji) return;
      if (useRegex) reactions.push({ mode: 'regex', regex: pattern, emoji });
      else reactions.push({ mode: 'keyword', keyword: pattern, emoji });
    });

    try {
      const res = await fetch('/api/fun/auto-reactions', {
