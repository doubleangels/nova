    <div class="hidden lg:grid lg:grid-cols-12 gap-4 px-5 py-2.5 border-b border-[var(--c-card-border)] bg-[var(--c-input)] text-[9px] uppercase tracking-widest text-[var(--c-text-dim)] font-bold items-center">
