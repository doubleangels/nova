      return;
    }
    el.classList.remove('hidden');
    el.textContent = msg;
    el.classList.toggle('text-red-400/90', !!isError);
    el.classList.toggle('text-[var(--c-text-muted)]', !isError);
  }

  document.getElementById('importDbJsonInput')?.addEventListener('change', (ev) => {
    const f = ev.target && ev.target.files && ev.target.files[0];
    pendingDbBackupJson = null;
    importDbBackupValidated = false;
    const vBtn = document.getElementById('validateDbJsonBtn');
    const aBtn = document.getElementById('applyDbJsonBtn');
    const label = document.getElementById('importDbJsonFileLabel');
    setImportDbUiStatus('');
    if (!f) {
      if (label) { label.classList.add('hidden'); label.textContent = ''; }
      if (vBtn) vBtn.disabled = true;
      if (aBtn) aBtn.disabled = true;
      return;
    }
    if (label) {
      label.classList.remove('hidden');
      label.textContent = f.name;
    }
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const parsed = JSON.parse(String(reader.result || ''));
        pendingDbBackupJson = parsed;
        importDbBackupValidated = false;
        if (vBtn) vBtn.disabled = false;
        if (aBtn) aBtn.disabled = true;
        showToast('Backup file loaded. Run Validate before Import.');
      } catch (e) {
        pendingDbBackupJson = null;
        if (vBtn) vBtn.disabled = true;
        if (aBtn) aBtn.disabled = true;
        showToast(e.message || 'Invalid JSON file.', 'error');
      }
    };
    reader.onerror = () => {
      pendingDbBackupJson = null;
      if (vBtn) vBtn.disabled = true;
      if (aBtn) aBtn.disabled = true;
      showToast('Could not read file.', 'error');
    };
    reader.readAsText(f);
  });

  async function validateDatabaseJsonImport() {
    if (!pendingDbBackupJson) {
      showToast('Choose a backup file first.', 'error');
      return;
    }
    const btn = document.getElementById('validateDbJsonBtn');
    if (btn) btn.disabled = true;
    setImportDbUiStatus('Validating…', false);
    try {
      const res = await fetch('/api/database/import/validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ backup: pendingDbBackupJson })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Validation failed');
      importDbBackupValidated = true;
      const aBtn = document.getElementById('applyDbJsonBtn');
      if (aBtn) aBtn.disabled = false;
      const ns = data.namespaces && typeof data.namespaces === 'object'
        ? Object.entries(data.namespaces).map(([k, v]) => `${k}: ${v}`).join(', ')
        : '';
      const warn = Array.isArray(data.warnings) && data.warnings.length
        ? '\n\nWarnings:\n' + data.warnings.join('\n')
        : '';
      setImportDbUiStatus(`OK — ${data.entryCount} entries${ns ? '\nNamespaces: ' + ns : ''}${warn}`, false);
      showToast('Backup passed validation.');
    } catch (e) {
      importDbBackupValidated = false;
      const aBtn = document.getElementById('applyDbJsonBtn');
      if (aBtn) aBtn.disabled = true;
      setImportDbUiStatus(e.message || 'Validation failed', true);
      showToast(e.message || 'Validation failed', 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  async function applyDatabaseJsonImport() {
    if (!pendingDbBackupJson) {
      showToast('Choose a backup file first.', 'error');
      return;
    }
    if (!importDbBackupValidated) {
      showToast('Validate the backup before importing.', 'error');
      return;
    }
    const ok = await confirmWithModal({
      title: 'Apply Database Import',
      message: 'Import will upsert keys from this backup into the live database. Continue?',
      confirmLabel: 'Import'
    });
    if (!ok) return;
    const btn = document.getElementById('applyDbJsonBtn');
    if (btn) btn.disabled = true;
    setImportDbUiStatus('Importing…', false);
    try {
      const res = await fetch('/api/database/import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ backup: pendingDbBackupJson, dryRun: false })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Import failed');
      const warn = Array.isArray(data.warnings) && data.warnings.length
        ? '\n\nWarnings:\n' + data.warnings.join('\n')
        : '';
      setImportDbUiStatus(`Imported ${data.imported} rows.${warn}`, false);
      showToast(`Imported ${data.imported} keys.`);
      try { await loadDatabaseEntries(); } catch (_) {}
    } catch (e) {
      setImportDbUiStatus(e.message || 'Import failed', true);
      showToast(e.message || 'Import failed', 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  // ── User Manager System ────────────────────────────────────────────────────────
  let userManagerCache = null;
  let userManagerSearchQuery = '';
  /** @type {Set<string>} Selected filter chip keys (AND together). */
  let userManagerSelectedChips = new Set();
  /** @type {'joined' | 'activity'} */
  let userManagerSortKey = 'joined';
  /** @type {'asc' | 'desc'} */
  let userManagerSortDir = 'desc';

  function userManagerRoot() {
    return document.getElementById('users');
  }

  function userManagerIsBot(u) {
    return u.isBot === true || u.isBot === 1 || String(u.isBot).toLowerCase() === 'true';
  }

  function userManagerPrivilege(u) {
    const v = u && u.privilege;
    if (v === 'admin' || v === 'Admin') return 'admin';
    if (v === 'mod' || v === 'Mod') return 'mod';
    return null;
  }

  function escapeHtmlUserManager(s) {
    if (s == null) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function userManagerInactiveDays() {
    const el = document.getElementById('inactivityDays');
    const n = parseInt(el && el.value, 10);
    if (!Number.isFinite(n) || n < 1) return 30;
    return Math.min(730, n);
  }

  function userManagerIsInactive(u, days) {
    if (userManagerIsBot(u)) return false;
    const thresholdMs = days * 24 * 60 * 60 * 1000;
    const now = Date.now();
    const last = u.lastMessageAt;
    const lastNum =
      last != null && last !== ''
        ? typeof last === 'number'
          ? last
          : Number(last)
        : null;
    if (lastNum != null && !Number.isNaN(lastNum)) {
      return now - lastNum > thresholdMs;
    }
    const joinTs = new Date(u.joinedAt).getTime();
    if (Number.isNaN(joinTs)) return false;
    return now - joinTs > thresholdMs;
  }

  function userManagerLastActivityNum(u) {
    const last = u && u.lastMessageAt;
    if (last == null || last === '') return NaN;
    const n = typeof last === 'number' ? last : Number(last);
    return Number.isFinite(n) ? n : NaN;
  }

  function userManagerCompareSort(a, b) {
    const mult = userManagerSortDir === 'asc' ? 1 : -1;
    if (userManagerSortKey === 'joined') {
      const ta = new Date(a.joinedAt).getTime();
      const tb = new Date(b.joinedAt).getTime();
      const va = Number.isNaN(ta) ? 0 : ta;
      const vb = Number.isNaN(tb) ? 0 : tb;
      return mult * (va - vb);
    }
    const la = userManagerLastActivityNum(a);
    const lb = userManagerLastActivityNum(b);
    const aHas = Number.isFinite(la);
    const bHas = Number.isFinite(lb);
    if (aHas && bHas) return mult * (la - lb);
    if (aHas && !bHas) return -1;
    if (!aHas && bHas) return 1;
    const ja = new Date(a.joinedAt).getTime();
    const jb = new Date(b.joinedAt).getTime();
    const va = Number.isNaN(ja) ? 0 : ja;
    const vb = Number.isNaN(jb) ? 0 : jb;
    return mult * (va - vb);
  }

  function userManagerToggleSort(key) {
    if (!userManagerCache) return;
    if (userManagerSortKey === key) {
      userManagerSortDir = userManagerSortDir === 'desc' ? 'asc' : 'desc';
    } else {
      userManagerSortKey = key;
      userManagerSortDir = 'desc';
    }
    renderUserManagerTable();
  }

  function userManagerUpdateSortHeaderIcons() {
    const icon = (k) => (userManagerSortKey === k ? (userManagerSortDir === 'desc' ? '▼' : '▲') : '');
    const set = (id, k) => {
      const el = document.getElementById(id);
      if (el) el.textContent = icon(k);
    };
    set('um_sort_ico_act', 'activity');
    set('um_sort_ico_join', 'joined');
    set('um_sort_ico_act_m', 'activity');
    set('um_sort_ico_join_m', 'joined');
  }

  function userManagerCsvEscape(value) {
    const s = value == null ? '' : String(value);
    if (/[",\n\r]/.test(s)) return '"' + s.replace(/"/g, '""') + '"';
    return s;
  }

  function userManagerExportCsv() {
    if (!userManagerCache || !userManagerCache.recent) {
      showToast('Load the roster first.', 'error');
      return;
    }
    const days = userManagerInactiveDays();
    const filtered = userManagerCache.recent.filter(
      (u) =>
        userManagerPassesChipFilters(u, userManagerSelectedChips) &&
        userManagerPassesSearch(u, userManagerSearchQuery)
    );
    filtered.sort(userManagerCompareSort);
    const headers = [
      'id',
      'username',
      'display_name',
      'bot',
      'privilege',
      'safe',
      'account_created',
      'joined_server',
      'last_message_iso',
      'last_activity_label',
      'message_count',
      'last_channel_id',
      'last_channel',
      'inactive_for_threshold'
    ];
    const lines = [headers.join(',')];
    for (const u of filtered) {
      const lastNum = userManagerLastActivityNum(u);
      const hasTracked = Number.isFinite(lastNum);
      let relLabel;
      if (!hasTracked) {
        relLabel = userManagerIsBot(u) ? 'Bot' : 'No Data';
      } else {
        relLabel = formatRelativeActivity(lastNum).text;
      }
      const inactive = userManagerIsInactive(u, days) ? 'yes' : 'no';
      const acctMs = u.accountCreatedAt != null ? Number(u.accountCreatedAt) : NaN;
      const acct = Number.isFinite(acctMs) ? new Date(acctMs).toISOString() : '';
      const joined = u.joinedAt ? new Date(u.joinedAt).toISOString() : '';
      const lastIso = hasTracked ? new Date(lastNum).toISOString() : '';
      const mc = u.messageCount != null && u.messageCount !== '' ? String(u.messageCount) : '';
      const row = [
        userManagerCsvEscape(u.id),
        userManagerCsvEscape(u.username),
        userManagerCsvEscape(u.displayName),
        userManagerIsBot(u) ? 'yes' : 'no',
        userManagerCsvEscape(userManagerPrivilege(u) || ''),
        u.hasSafeRole ? 'yes' : 'no',
        userManagerCsvEscape(acct),
        userManagerCsvEscape(joined),
        userManagerCsvEscape(lastIso),
        userManagerCsvEscape(relLabel),
        userManagerCsvEscape(mc),
        userManagerCsvEscape(u.lastMessageChannelId || ''),
        userManagerCsvEscape(u.lastMessageChannelName || ''),
        inactive
      ];
      lines.push(row.join(','));
    }
    const bom = '\uFEFF';
    const blob = new Blob([bom + lines.join('\n')], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `nova-users-${new Date().toISOString().slice(0, 10)}.csv`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
    showToast('Exported CSV (' + filtered.length + ' rows).');
  }

  function formatRelativeActivity(lastMessageAt) {
    if (lastMessageAt == null || typeof lastMessageAt !== 'number') {
      return { text: 'No Data', cls: 'text-[var(--c-text-dim)] italic', title: 'No message activity recorded yet for this member' };
    }
    const now = Date.now();
    let diffSec = Math.floor((now - lastMessageAt) / 1000);
    if (diffSec < 0) diffSec = 0;
    const absTitle = new Date(lastMessageAt).toLocaleString();
    if (diffSec < 60) return { text: 'Just now', cls: 'text-emerald-400', title: absTitle };
    const diffMin = Math.floor(diffSec / 60);
    if (diffMin < 60) return { text: `${diffMin}m ago`, cls: 'text-[var(--c-text-muted)]', title: absTitle };
    const diffH = Math.floor(diffMin / 60);
    if (diffH < 48) return { text: `${diffH}h ago`, cls: 'text-[var(--c-text-muted)]', title: absTitle };
    const diffD = Math.floor(diffH / 24);
    if (diffD < 14) return { text: `${diffD}d ago`, cls: 'text-[var(--c-text-muted)]', title: absTitle };
    const diffW = Math.floor(diffD / 7);
    if (diffW < 8) return { text: `${diffW}w ago`, cls: 'text-[var(--c-text-dim)]', title: absTitle };
    const diffMo = Math.floor(diffD / 30);
    return { text: `${Math.max(1, diffMo)}mo ago`, cls: 'text-[var(--c-text-dim)]', title: absTitle };
  }

  function userManagerSyncChipStyles() {
    const root = userManagerRoot();
    if (!root) return;
    root.querySelectorAll('[data-um-chip]').forEach((btn) => {
      const key = btn.getAttribute('data-um-chip');
      const on = key && userManagerSelectedChips.has(key);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      btn.classList.toggle('ring-2', !!on);
      btn.classList.toggle('ring-[var(--c-accent)]', !!on);
      btn.classList.toggle('ring-offset-2', !!on);
      btn.classList.toggle('ring-offset-[var(--c-card)]', !!on);
    });
  }

  function userManagerToggleChip(key) {
    if (!userManagerCache) return;
    if (userManagerSelectedChips.has(key)) userManagerSelectedChips.delete(key);
    else userManagerSelectedChips.add(key);
    userManagerSyncChipStyles();
    renderUserManagerTable();
  }

  function userManagerPassesChipFilters(u, chips) {
    if (!chips || chips.size === 0) return true;
    const bot = userManagerIsBot(u);
    const p = userManagerPrivilege(u);
    const days = userManagerInactiveDays();

    const wantAdmin = chips.has('admin');
    const wantMod = chips.has('mod');
    if (wantAdmin || wantMod) {
      // One staff chip: match that level. Both: treat as "any staff" (AND on admin+mod was impossible).
      if (wantAdmin && wantMod) {
        if (p !== 'admin' && p !== 'mod') return false;
      } else if (wantAdmin && p !== 'admin') {
        return false;
      } else if (wantMod && p !== 'mod') {
        return false;
      }
    }

    if (chips.has('safe') && !u.hasSafeRole) return false;

    if (chips.has('inactive') && !userManagerIsInactive(u, days)) return false;

    const wantHumans = chips.has('humans');
    const wantBots = chips.has('bots');
    if (!(wantHumans && wantBots)) {
      if (wantHumans && bot) return false;
      if (wantBots && !bot) return false;
    }

    return true;
  }

  function userManagerPassesSearch(u, query) {
    if (!query) return true;
    const q = String(query).trim().toLowerCase();
    if (!q) return true;
    const displayName = String(u.displayName || '').toLowerCase();
    const username = String(u.username || '').toLowerCase();
    const userId = String(u.id || '').toLowerCase();
    return displayName.includes(q) || username.includes(q) || userId.includes(q);
  }

  function userManagerUpdateChips() {
    if (!userManagerCache || !userManagerCache.recent) return;
    const list = userManagerCache.recent;
    let admin = 0;
    let mod = 0;
    let umHumans = 0;
    let umBots = 0;
    let safe = 0;
    const days = userManagerInactiveDays();
    let inactive = 0;
    for (const u of list) {
      const p = userManagerPrivilege(u);
      const bot = userManagerIsBot(u);
      if (p === 'admin') admin++;
      else if (p === 'mod') mod++;
      if (bot) umBots++;
      else umHumans++;
      if (u.hasSafeRole) safe++;
      if (userManagerIsInactive(u, days)) inactive++;
    }
    const set = (id, n) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(n);
    };
    set('usr_chip_admin', admin);
    set('usr_chip_mod', mod);
    set('usr_chip_um_humans', umHumans);
    set('usr_chip_um_bots', umBots);
    set('usr_chip_safe', safe);
    set('usr_chip_inactive', inactive);
    userManagerSyncChipStyles();
  }

  function userManagerResetFilters() {
    userManagerSelectedChips.clear();
    userManagerSyncChipStyles();
    renderUserManagerTable();
  }

  function renderUserManagerTable() {
    if (!userManagerCache || !userManagerCache.recent) return;
    const tbody = document.getElementById('userTableBody');
    if (!tbody) return;
    const hint = document.getElementById('userManagerFilterHint');
    const days = userManagerInactiveDays();
    userManagerUpdateChips();

    const filtered = userManagerCache.recent.filter((u) => (
      userManagerPassesChipFilters(u, userManagerSelectedChips) &&
      userManagerPassesSearch(u, userManagerSearchQuery)
    ));
    const sorted = [...filtered].sort(userManagerCompareSort);

    tbody.innerHTML = '';
    if (sorted.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'px-4 py-10 text-center text-xs text-[var(--c-text-dim)]';
      empty.setAttribute('role', 'status');
      empty.textContent = 'No members match these filters.';
      tbody.appendChild(empty);
    } else {
      const safeCheckSvg =
        '<svg class="w-4 h-4 mx-auto text-[var(--c-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
      const safeEmpty = '<span class="inline-flex w-8 justify-center text-[var(--c-text-dim)] opacity-25 select-none" aria-hidden="true">—</span>';
      sorted.forEach((u) => {
        const row = document.createElement('div');
        row.setAttribute('role', 'listitem');
        const bot = userManagerIsBot(u);
        const privilege = userManagerPrivilege(u);
        const rowTint =
          privilege === 'admin'
            ? ' border-l-[3px] border-l-red-500 bg-red-500/[0.08] hover:bg-red-500/[0.12]'
            : privilege === 'mod'
              ? ' border-l-[3px] border-l-yellow-500 bg-yellow-500/[0.07] hover:bg-yellow-500/[0.11]'
              : ' border-l-[3px] border-l-transparent um-row-hover';
        row.className = 'transition-colors' + rowTint;

        const avatarSrc = u.avatar || 'https://cdn.discordapp.com/embed/avatars/0.png';
        const createdDate = new Date(u.joinedAt).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric'
        });
        const safeInner = u.hasSafeRole
          ? `<span class="inline-flex w-8 justify-center" title="Has protected (safe) role">${safeCheckSvg}</span>`
          : safeEmpty;

        const lastNum = userManagerLastActivityNum(u);
        const hasTracked = Number.isFinite(lastNum);
        const inactiveRow = userManagerIsInactive(u, days);

        let lastCellHtml;
        let lastCellTitle;
        let lastSubHtml = '';
        if (!hasTracked) {
          if (bot) {
            lastCellHtml = '<span class="text-blue-400/90 font-medium">Bot</span>';
            lastCellTitle = 'Bot accounts are exempt from human message activity tracking';
          } else {
            lastCellHtml =
              '<span style="color:var(--c-text);font-style:italic">No Data</span>';
            lastCellTitle = 'No message activity recorded yet for this member';
          }
        } else {
          const rel = formatRelativeActivity(lastNum);
          const actCls = inactiveRow && !bot ? 'text-orange-400/90' : rel.cls;
          lastCellTitle = rel.title;
          const extras = [];
          if (!bot && u.messageCount != null && Number(u.messageCount) > 0) {
            extras.push(`${Number(u.messageCount).toLocaleString()} messages tracked`);
          }
          if (!bot && u.lastMessageChannelName) {
            extras.push(`Last in ${u.lastMessageChannelName}`);
          }
          if (extras.length) lastCellTitle = `${rel.title} · ${extras.join(' · ')}`;
          lastCellHtml = `<span class="${actCls}">${escapeHtmlUserManager(rel.text)}</span>`;
          if (!bot) {
            const parts = [];
            if (u.messageCount != null && Number(u.messageCount) > 0) {
              parts.push(`${Number(u.messageCount).toLocaleString()} messages`);
            }
            if (u.lastMessageChannelName) {
              parts.push(escapeHtmlUserManager(u.lastMessageChannelName));
            }
            if (parts.length) {
              lastSubHtml = `<div class="text-[9px] text-[var(--c-text-dim)] truncate mt-0.5">${parts.join(' · ')}</div>`;
            }
          }
        }

        const acctMs = u.accountCreatedAt != null ? Number(u.accountCreatedAt) : NaN;
        const acctLine =
          Number.isFinite(acctMs) && !bot
            ? `<span class="text-[9px] text-[var(--c-text-dim)] truncate">Discord since ${new Date(acctMs).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric'
              })}</span>`
            : '';

        const dn = escapeHtmlUserManager(u.displayName);
        const un = escapeHtmlUserManager(u.username);
        const userIdJs = JSON.stringify(String(u.id || ''));
        const displayNameJs = JSON.stringify(String(u.displayName || u.username || u.id || 'User'));

        row.innerHTML = `
          <div class="lg:grid lg:grid-cols-12 lg:gap-4 lg:items-center px-4 py-3">
            <div class="lg:col-span-4 flex flex-col items-center lg:flex-row lg:items-start lg:justify-start gap-2 min-w-0">
              <div class="flex items-center lg:items-center gap-3 min-w-0 flex-1 flex-col lg:flex-row">
                <div class="relative shrink-0">
                  <img src="${avatarSrc}" class="w-10 h-10 sm:w-8 sm:h-8 rounded-full border border-[var(--c-input-border)]" alt="">
                  ${bot ? '<div class="absolute -bottom-1 -right-1 px-1 rounded bg-blue-500 text-[8px] font-bold text-white leading-tight">BOT</div>' : ''}
                </div>
                <div class="flex flex-col min-w-0 items-center lg:items-start text-center lg:text-left">
                  <span class="text-sm font-bold truncate ${privilege === 'admin' ? 'text-red-400' : privilege === 'mod' ? 'text-yellow-400' : 'text-[var(--c-text)]'}">${dn}</span>
                  <span class="text-[10px] text-[var(--c-text-dim)] truncate">@${un}</span>
                  ${acctLine}
                </div>
              </div>
              <div class="lg:hidden shrink-0 pt-0.5 mt-2 lg:mt-0" aria-label="Safe role">${safeInner}</div>
            </div>
            <div class="hidden lg:flex lg:col-span-1 justify-center items-center" aria-label="Safe role">${safeInner}</div>
            <div class="mt-4 lg:mt-0 lg:col-span-3 text-xs sm:text-sm text-center lg:text-right">
              <span class="block lg:hidden text-[9px] font-bold uppercase tracking-wider text-[var(--c-text-dim)] mb-1">Last activity</span>
              <div title="${escapeHtmlUserManager(lastCellTitle)}">${lastCellHtml}${lastSubHtml}</div>
            </div>
            <div class="mt-3 lg:mt-0 lg:col-span-2 text-xs text-[var(--c-text-muted)] text-center lg:text-left pl-0 lg:pl-4">
              <span class="block lg:hidden text-[9px] font-bold uppercase tracking-wider text-[var(--c-text-dim)] mb-1">Joined</span>
              <div>${createdDate}</div>
            </div>
            <div class="mt-4 lg:mt-0 lg:col-span-2">
              <span class="block lg:hidden text-[9px] font-bold uppercase tracking-wider text-[var(--c-text-dim)] mb-1 text-center">Actions</span>
              <div class="flex justify-center lg:justify-end gap-2">
                <button type="button" onclick='kickUserFromManager(${userIdJs}, ${displayNameJs})' class="btn-dash-warn btn-dash-table-action">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  Kick
                </button>
                <button type="button" onclick='banUserFromManager(${userIdJs}, ${displayNameJs})' class="btn-dash-danger btn-dash-table-action">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 0L5.636 18.364" /></svg>
                  Ban
                </button>
              </div>
            </div>
          </div>
        `;
        tbody.appendChild(row);
      });
    }

    if (hint) {
      const allN = userManagerCache.recent.length;
      const selective = userManagerSelectedChips.size > 0 || Boolean(userManagerSearchQuery.trim());
      const sortNonDefault =
        userManagerSortKey !== 'joined' || userManagerSortDir !== 'desc';
      const sortBit = sortNonDefault
        ? ` · sort: ${userManagerSortKey === 'joined' ? 'joined' : 'last activity'} ${userManagerSortDir}`
        : '';
      if (sorted.length !== allN || selective || sortNonDefault) {
        hint.classList.remove('hidden');
        hint.textContent = `Showing ${sorted.length} of ${allN} members (${days} day${days === 1 ? '' : 's'} inactive threshold; chips use AND${userManagerSearchQuery.trim() ? '; search active' : ''}${sortBit}).`;
      } else {
        hint.classList.add('hidden');
        hint.textContent = '';
      }
    }
    userManagerUpdateSortHeaderIcons();
    ensureNonChipButtonsHaveIcons();
  }

  async function loadUserSummary(forceRefresh = false) {
    const refreshIcon = document.getElementById('refreshUsersIcon');
    if (refreshIcon) {
      refreshIcon.style.transition = 'transform 0.6s ease';
      refreshIcon.style.transform = 'rotate(360deg)';
    }
    try {
      const url = forceRefresh ? '/api/users/summary?refresh=1' : '/api/users/summary';
      const res = await fetch(url);
      if (res.ok) {
        const data = await res.json();
        document.getElementById('usr_total').textContent = data.total || 0;
        document.getElementById('usr_humans').textContent = data.humans || 0;
        document.getElementById('usr_bots').textContent = data.bots || 0;
        const b = data.activityInsights?.buckets || {};
        const under1d = Number(b.under1d ?? 0);
        const under7dOnly = Number(b.under7d ?? 0);
        const under30dOnly = Number(b.under30d ?? 0);
        document.getElementById('usr_act_1d').textContent = under1d;
        document.getElementById('usr_act_7d').textContent = under1d + under7dOnly;
        document.getElementById('usr_act_30d').textContent = under1d + under7dOnly + under30dOnly;
        document.getElementById('usr_act_30p').textContent = b.over30d ?? 0;
        document.getElementById('usr_act_nodata').textContent = b.noData ?? 0;
        userManagerCache = data;
        const metaEl = document.getElementById('userManagerRosterMeta');
        if (metaEl) {
          const gen = data.activityInsights && data.activityInsights.generatedAt;
          const parts = [];
          if (gen) {
            try {
              parts.push('Snapshot · ' + new Date(gen).toLocaleString());
            } catch (e) {}
          }
          if (data.cached) parts.push('served from cache');
          if (data.stale) parts.push('stale (Discord rate limit)');
          metaEl.textContent = parts.join(' · ');
        }
        renderUserManagerTable();
        if (data.stale) {
          showToast('User list is cached (Discord member fetch rate limit). Try again in a moment.', 'success');
        }
      }
    } catch (e) {
      console.error('Failed to load user summary', e);
    } finally {
      if (refreshIcon) {
        setTimeout(() => {
          refreshIcon.style.transition = 'none';
          refreshIcon.style.transform = 'rotate(0deg)';
        }, 650);
      }
    }
  }

  async function exportDiagnosticsBundle() {
    try {
      const res = await fetch('/api/maintenance/diagnostics/export');
      if (!res.ok) throw new Error('Failed to export diagnostics bundle.');
      const blob = await res.blob();
      const cd = res.headers.get('content-disposition') || '';
      const filenameMatch = /filename=\"?([^\";]+)\"?/i.exec(cd);
      const filename = filenameMatch ? filenameMatch[1] : 'nova-diagnostics.json';
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      showToast('Diagnostics bundle exported.');
    } catch (e) {
      showToast(e.message || 'Failed to export diagnostics.', 'error');
    }
  }

  (function initUserManagerFilterListeners() {
    const root = userManagerRoot();
    if (!root || root.dataset.umFilterWired) return;
    root.dataset.umFilterWired = '1';

    root.addEventListener('input', (e) => {
      const t = e.target;
      if (!t || !root.contains(t)) return;
      if (t.id === 'inactivityDays') renderUserManagerTable();
      if (t.id === 'userManagerSearch') {
        userManagerSearchQuery = t.value || '';
        renderUserManagerTable();
      }
    });

    root.addEventListener('click', (e) => {
      const t = e.target;
      if (!t || !root.contains(t)) return;
      const chipBtn = t.closest('[data-um-chip]');
      if (chipBtn && root.contains(chipBtn)) {
        const key = chipBtn.getAttribute('data-um-chip');
        if (key) userManagerToggleChip(key);
        return;
      }
      if (t.closest('#userManagerClearChipsBtn')) {
        userManagerResetFilters();
        return;
      }
      const sortBtn = t.closest('[data-um-sort]');
      if (sortBtn && root.contains(sortBtn)) {
        const sk = sortBtn.getAttribute('data-um-sort');
        if (sk === 'activity' || sk === 'joined') userManagerToggleSort(sk);
      }
    });
  })();

