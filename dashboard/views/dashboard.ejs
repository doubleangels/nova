</section>

<!-- Invite Creation Modal -->
<div id="inviteModal" class="hidden fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
    <div class="card w-full max-w-md shadow-2xl scale-95 opacity-0 transition-all duration-300" id="inviteModalCard">
        <div class="flex items-center justify-between p-5 border-b border-[var(--c-card-border)]">
            <h3 class="font-bold text-lg">Create New Invite</h3>
            <button onclick="closeInviteModal()" class="text-[var(--c-text-dim)] hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <div>
                <label class="field-label">Target Channel</label>
                <select id="inv_channel" class="field-input"></select>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="field-label">Max Uses</label>
                    <input type="number" id="inv_uses" class="field-input" value="0" min="0" />
                    <p class="text-[10px] mt-1 text-[var(--c-text-dim)]">0 for unlimited</p>
                </div>
                <div>
                    <label class="field-label">Expiration</label>
                    <select id="inv_age" class="field-input">
                        <option value="0">Never</option>
                        <option value="1800">30 Minutes</option>
                        <option value="3600">1 Hour</option>
                        <option value="21600">6 Hours</option>
                        <option value="43200">12 Hours</option>
                        <option value="86400">24 Hours</option>
                        <option value="604800">7 Days</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="field-label">Invite Tag (Optional)</label>
                <input type="text" id="inv_tag" class="field-input" placeholder="e.g. Website, YouTube, Disboard" />
                <p class="text-[10px] mt-1 text-[var(--c-text-dim)]">A custom name for tracking this invite.</p>
            </div>
            <div class="flex items-center gap-2 pt-2">
                <input type="checkbox" id="inv_unique" class="rounded bg-[var(--c-input)] border-[var(--c-input-border)] text-[var(--c-accent)] focus:ring-[var(--c-accent)]" />
                <label for="inv_unique" class="text-xs text-[var(--c-label)]">Force unique code</label>
            </div>
        </div>
        <div class="p-5 border-t border-[var(--c-card-border)] flex justify-end gap-3">
            <button type="button" onclick="closeInviteModal()" class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg text-sm font-medium hover:bg-[var(--c-input)] transition-colors">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              Cancel
            </button>
            <button type="button" onclick="createInvite()" id="createInviteBtn" class="btn-dash-primary btn-dash-md">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
              <span data-btn-text>Create</span>
            </button>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════ ADVANCED DATABASE EDITOR -->
<section id="database" class="mb-10 page-section hidden">
  <div id="database-browse" class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between scroll-mt-28">
    <div class="min-w-0">
        <h2 class="section-heading mb-1">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>
            Database Explorer
        </h2>
        <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed">Browse Keyv namespaces, edit values, and delete keys—<strong class="text-[var(--c-text-muted)]">dangerous</strong> on production if misused.</p>
    </div>
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-3 w-full sm:w-auto sm:max-w-xl sm:ml-auto min-w-0">
      <div class="relative w-full min-w-0 flex-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-[var(--c-text-dim)] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="text" id="dbSearch" placeholder="Search keys or values..." class="field-input field-input-with-icon py-2.5 pr-3 text-xs w-full min-h-[44px]" />
      </div>
      <button type="button" id="refreshDbBtn" class="p-2.5 min-w-[44px] min-h-[44px] flex items-center justify-center bg-[var(--c-input)] border border-[var(--c-input-border)] rounded-lg hover:bg-[var(--c-card-border)] transition-colors active:scale-[0.98] shrink-0 self-end sm:self-auto" title="Refresh Database">
        <svg id="refreshDbIcon" xmlns="http://www.w3.org/2000/svg" style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row gap-4 lg:gap-6">
    <!-- Namespace: horizontal scroll on small screens -->
    <aside class="w-full lg:w-56 shrink-0 min-w-0">
        <p class="text-[10px] font-bold uppercase tracking-wider text-[var(--c-text-dim)] mb-2 lg:hidden">Namespace</p>
        <div class="card p-2 flex flex-row lg:flex-col gap-2 overflow-x-auto lg:overflow-x-visible lg:overflow-y-auto lg:max-h-[min(70vh,36rem)] snap-x snap-mandatory lg:snap-none" id="dbNamespaceList">
            <!-- Namespaces injected here -->
            <div class="px-3 py-10 text-center text-xs text-[var(--c-text-dim)] w-full flex-shrink-0 min-w-[200px]">Loading...</div>
        </div>
        
        <div class="mt-3 lg:mt-4 px-1 flex flex-wrap gap-x-2 gap-y-1 items-center text-[10px] font-bold uppercase tracking-widest">
            <button type="button" onclick="expandAllCategories()" class="inline-flex items-center gap-1.5 text-[var(--c-text-dim)] hover:text-[var(--c-accent)] transition-colors py-1 text-[10px] font-bold tracking-wide">Expand All</button>
            <span class="text-[var(--c-text-dim)] opacity-50">·</span>
            <button type="button" onclick="collapseAllCategories()" class="inline-flex items-center gap-1.5 text-[var(--c-text-dim)] hover:text-[var(--c-accent)] transition-colors py-1 text-[10px] font-bold tracking-wide">Collapse All</button>
        </div>
    </aside>

    <!-- Content Area -->
    <div class="flex-1 space-y-4 min-w-0" id="dbContentArea">
        <!-- Categories and Items injected here -->
        <div class="card p-12 text-center text-[var(--c-text-dim)]">
            <div class="animate-spin w-6 h-6 border-2 border-[var(--c-accent)] border-t-transparent rounded-full mx-auto mb-4"></div>
            <p class="text-xs">Fetching database entries...</p>
        </div>
    </div>
  </div>
</section>

<!-- ─── USERS SECTION ───────────────────────────────────────────────────────── -->
<section id="users" class="page-section hidden space-y-8 mt-8 mb-10">
  <div id="users-user-manager" class="card bg-[var(--c-input)]/50 border-dashed scroll-mt-28">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
          <div>
              <h2 class="section-heading mb-1">User Manager</h2>
              <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed font-bold">Server member roster, filters, and exports.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
              <button type="button" onclick="userManagerExportCsv()" class="flex items-center justify-center gap-2 min-h-[44px] px-4 py-2 bg-[var(--c-card)] border border-[var(--c-input-border)] rounded-lg hover:border-emerald-500/50 transition-colors text-xs font-bold w-full sm:w-auto">
                  <svg class="w-4 h-4 shrink-0 text-emerald-400/90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v12m0 0l4-4m-4 4l-4-4M4 21h16" /></svg>
                  Export CSV
              </button>
              <button type="button" onclick="loadUserSummary(true)" class="flex items-center justify-center gap-2 min-h-[44px] px-4 py-2 bg-[var(--c-card)] border border-[var(--c-input-border)] rounded-lg hover:border-[var(--c-accent)] transition-colors group w-full sm:w-auto">
                  <svg id="refreshUsersIcon" class="w-4 h-4 text-[var(--c-text-dim)] group-hover:text-[var(--c-accent)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                  <span class="text-xs font-bold">Refresh</span>
              </button>
          </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mb-6">
          <div class="p-4 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center">
              <p class="text-[10px] text-[var(--c-text-dim)] uppercase font-bold tracking-wider mb-1">Total Members</p>
              <p id="usr_total" class="text-xl sm:text-2xl font-mono font-bold text-[var(--c-text)]">--</p>
          </div>
          <div class="p-4 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center">
              <p class="text-[10px] text-[var(--c-text-dim)] uppercase font-bold tracking-wider mb-1">Humans</p>
              <p id="usr_humans" class="text-xl sm:text-2xl font-mono font-bold text-emerald-400">--</p>
          </div>
          <div class="p-4 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center">
              <p class="text-[10px] text-[var(--c-text-dim)] uppercase font-bold tracking-wider mb-1">Bots</p>
              <p id="usr_bots" class="text-xl sm:text-2xl font-mono font-bold text-blue-400">--</p>
          </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 sm:gap-4 mb-6">
          <div class="p-3 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center"><p class="text-[10px] text-[var(--c-text-dim)] uppercase">Active &lt;1d</p><p id="usr_act_1d" class="text-lg font-bold">--</p></div>
          <div class="p-3 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center"><p class="text-[10px] text-[var(--c-text-dim)] uppercase">Active &lt;7d</p><p id="usr_act_7d" class="text-lg font-bold">--</p></div>
          <div class="p-3 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center"><p class="text-[10px] text-[var(--c-text-dim)] uppercase">Active &lt;30d</p><p id="usr_act_30d" class="text-lg font-bold">--</p></div>
          <div class="p-3 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center"><p class="text-[10px] text-[var(--c-text-dim)] uppercase">Inactive 30d+</p><p id="usr_act_30p" class="text-lg font-bold">--</p></div>
          <div class="p-3 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] text-center"><p class="text-[10px] text-[var(--c-text-dim)] uppercase">No Data</p><p id="usr_act_nodata" class="text-lg font-bold">--</p></div>
      </div>

      <p id="userManagerRosterMeta" class="text-[10px] text-[var(--c-text-dim)] mb-4 px-1 font-medium"></p>

      <div class="mb-6 p-4 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] space-y-3">
          <h3 class="text-[11px] font-bold text-[var(--c-text-muted)] tracking-wide">Admin vs Mod vs Member</h3>
          <p class="text-[10px] text-[var(--c-text-dim)] leading-relaxed">Row tint and filter chips use each member’s effective permissions <strong class="text-[var(--c-text-muted)]">minus @everyone</strong>. That way a very open base role does not mark the whole server as staff.</p>
          <ul class="text-[10px] text-[var(--c-text-dim)] space-y-2 list-none leading-relaxed border-t border-[var(--c-card-border)] pt-3">
              <li class="flex gap-2"><span class="shrink-0 w-14 text-red-400 font-bold">Admin</span><span>If elevated permissions include <strong class="text-[var(--c-text-muted)]">Administrator</strong> or <strong class="text-[var(--c-text-muted)]">Manage Server</strong>.</span></li>
              <li class="flex gap-2"><span class="shrink-0 w-14 text-yellow-400 font-bold">Mod</span><span>Otherwise, if <strong class="text-[var(--c-text-muted)]">any</strong> of these elevated permissions are present: Kick Members, Ban Members, Moderate Members, Manage Messages, Manage Nicknames, Manage Threads, Mute Members, Deafen Members, Move Members.</span></li>
              <li class="flex gap-2"><span class="shrink-0 w-14 text-[var(--c-text-muted)] font-bold">Neither</span><span>Everyone else: no elevated admin or mod permission from the lists above (normal member row styling).</span></li>
          </ul>
      </div>

      <div class="mb-6 p-4 bg-[var(--c-card)] rounded-xl border border-[var(--c-accent-soft-ring)] space-y-3">
          <p class="text-[10px] text-[var(--c-text-dim)] leading-relaxed">Click chips to combine filters — most chips use <strong class="text-[var(--c-text-muted)]">AND</strong> (every highlighted rule must match). <strong class="text-[var(--c-text-muted)]">Admin + Mod</strong> together means <strong class="text-[var(--c-text-muted)]">either</strong> staff tier. “Humans” + “Bots” together ignores member type. Counts are the full roster. <strong class="text-[var(--c-text-muted)]">Inactive</strong> uses <strong class="text-[var(--c-text-muted)]">Days of Inactivity</strong> (Inactivity Prune card below). Sort applies to the table below.</p>
          <div class="relative">
              <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--c-text-dim)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input type="search" id="userManagerSearch" class="field-input field-input-with-icon min-h-[40px]" placeholder="Search members by display name, username, or ID" autocomplete="off" />
          </div>
          <div class="flex flex-wrap items-center gap-2">
              <button type="button" data-um-chip="admin" class="um-chip-btn min-h-[40px] px-3 py-2 rounded-lg border border-red-500/40 bg-red-500/10 text-[11px] font-bold text-red-400 hover:bg-red-500/20 transition-all" aria-pressed="false">Admin <span id="usr_chip_admin" class="font-mono">0</span></button>
              <button type="button" data-um-chip="mod" class="um-chip-btn min-h-[40px] px-3 py-2 rounded-lg border border-yellow-500/40 bg-yellow-500/10 text-[11px] font-bold text-yellow-400 hover:bg-yellow-500/20 transition-all" aria-pressed="false">Mod <span id="usr_chip_mod" class="font-mono">0</span></button>
              <button type="button" data-um-chip="humans" class="um-chip-btn min-h-[40px] px-3 py-2 rounded-lg border border-emerald-500/40 bg-emerald-500/10 text-[11px] font-bold text-emerald-400 hover:bg-emerald-500/20 transition-all" aria-pressed="false">Humans <span id="usr_chip_um_humans" class="font-mono">0</span></button>
              <button type="button" data-um-chip="bots" class="um-chip-btn min-h-[40px] px-3 py-2 rounded-lg border border-blue-500/40 bg-blue-500/10 text-[11px] font-bold text-blue-400 hover:bg-blue-500/20 transition-all" aria-pressed="false">Bots <span id="usr_chip_um_bots" class="font-mono">0</span></button>
              <button type="button" data-um-chip="safe" class="um-chip-btn btn-dash-secondary btn-dash-sm min-h-[40px] !text-[11px]" aria-pressed="false">Safe <span id="usr_chip_safe" class="font-mono">0</span></button>
              <button type="button" data-um-chip="inactive" class="um-chip-btn min-h-[40px] px-3 py-2 rounded-lg border border-orange-500/40 bg-orange-500/10 text-[11px] font-bold text-orange-300 hover:bg-orange-500/20 transition-all" aria-pressed="false">Inactive <span id="usr_chip_inactive" class="font-mono">0</span></button>
              <button type="button" id="userManagerClearChipsBtn" class="w-full sm:w-auto sm:ml-auto min-h-[40px] px-3 py-2 text-[10px] font-bold tracking-wide text-[var(--c-text-dim)] hover:text-[var(--c-text)] underline decoration-dotted text-center sm:text-left">Clear Chips</button>
          </div>
          <div class="flex lg:hidden flex-wrap items-center gap-2 pt-1">
              <span class="text-[9px] uppercase font-bold text-[var(--c-text-dim)] tracking-wider">Sort</span>
              <button type="button" data-um-sort="activity" class="min-h-[36px] px-2.5 py-1.5 rounded-lg border border-[var(--c-accent-soft-ring)] bg-[var(--c-input)] text-[10px] font-bold text-[var(--c-text-muted)] hover:border-[var(--c-accent)]">Last activity <span id="um_sort_ico_act_m" class="font-mono text-[var(--c-accent-text)]"></span></button>
              <button type="button" data-um-sort="joined" class="min-h-[36px] px-2.5 py-1.5 rounded-lg border border-[var(--c-accent-soft-ring)] bg-[var(--c-input)] text-[10px] font-bold text-[var(--c-text-muted)] hover:border-[var(--c-accent)]">Joined <span id="um_sort_ico_join_m" class="font-mono text-[var(--c-accent-text)]"></span></button>
          </div>
          <p id="userManagerFilterHint" class="text-[10px] text-[var(--c-text-dim)] font-medium hidden"></p>
      </div>

      <div class="bg-[var(--c-card)] border border-[var(--c-accent-soft-ring)] rounded-xl overflow-hidden">
          <div class="hidden lg:grid lg:grid-cols-12 gap-3 lg:gap-4 px-4 sm:px-5 py-2.5 border-b border-[var(--c-card-border)] bg-[var(--c-input)] text-[9px] uppercase tracking-widest text-[var(--c-text-muted)] font-bold items-center">
              <div class="lg:col-span-4">User</div>
              <div class="lg:col-span-1 text-center" title="Protected from Inactivity Prune (safe role)">Safe</div>
              <div class="lg:col-span-3 text-right">
                  <button type="button" data-um-sort="activity" class="inline-flex items-center gap-1 justify-end w-full text-[9px] uppercase tracking-widest font-bold text-[var(--c-text-muted)] hover:text-[var(--c-accent-text)] transition-colors" title="Sort by last recorded message">Last activity <span id="um_sort_ico_act" class="font-mono normal-case text-[var(--c-accent-text)]"></span></button>
              </div>
              <div class="lg:col-span-2 text-left pl-4">
                  <button type="button" data-um-sort="joined" class="inline-flex items-center gap-1 justify-start w-full text-[9px] uppercase tracking-widest font-bold text-[var(--c-text-muted)] hover:text-[var(--c-accent-text)] transition-colors" title="Sort by server join date">Joined <span id="um_sort_ico_join" class="font-mono normal-case text-[var(--c-accent-text)]"></span></button>
              </div>
              <div class="lg:col-span-2 text-right">Actions</div>
          </div>
          <div id="userTableBody" role="list" class="divide-y divide-[var(--c-subtle-divide)]">
              <div role="listitem" class="px-4 py-8 text-center text-xs text-[var(--c-text-dim)]">Loading users...</div>
          </div>
      </div>

  </div>

  <div id="users-inactivity-prune" class="card p-6 scroll-mt-28 border border-red-500/20">
      <div class="flex flex-col mb-4">
          <h2 class="section-heading mb-1 !text-red-400 before:!bg-red-500">Inactivity Prune</h2>
          <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed font-bold">Scan and kick members past your inactivity threshold (uses last-message data when present).</p>
      </div>

      <div class="grid grid-cols-1 md:max-w-md gap-6 mb-6">
          <div>
              <label class="field-label">Days of Inactivity</label>
              <input type="number" id="inactivityDays" class="field-input w-full min-h-[44px]" value="30" min="1" max="730" />
              <p class="field-hint">Users inactive for this many days will be flagged here and in User Manager (last-activity column tint).</p>
          </div>
          <div>
              <label class="field-label">Inactivity Kick Protected Role</label>
              <select id="prune_protected_role_id" class="field-input role-select"></select>
              <p class="field-hint">Members with this role are never targeted by Inactivity Prune and are marked as Safe in User Manager.</p>
          </div>
      </div>
      <div class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-2 sm:gap-3">
          <button type="button" id="inactivityScanBtn" onclick="scanInactivityKickTargets()" class="min-h-[44px] px-4 py-2.5 bg-red-500 border border-red-600 text-white shadow-[0_0_15px_rgba(239,68,68,0.25)] rounded-lg hover:bg-red-600 hover:border-red-700 transition-all text-sm font-bold flex items-center justify-center gap-2 w-full sm:w-auto">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              Scan for Users
          </button>
          <button type="button" id="inactivityExecuteBtn" onclick="executeInactivityKicks()" class="hidden min-h-[44px] px-4 py-2.5 bg-red-500 border border-red-600 text-white shadow-[0_0_15px_rgba(239,68,68,0.3)] rounded-lg hover:bg-red-600 transition-all text-sm font-bold flex items-center justify-center gap-2 w-full sm:w-auto">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" /></svg>
              Execute Inactivity Prune
          </button>
      </div>

      <div id="inactivityResultsContainer" class="hidden mt-6 border border-red-500/20 rounded-xl overflow-hidden bg-[var(--c-card)]">
          <div class="bg-red-500/10 px-4 py-2 border-b border-red-500/20 flex justify-between items-center">
              <span class="text-[10px] uppercase font-bold text-red-500 tracking-widest">Dry-Run Preview</span>
              <span id="inactivityTargetCount" class="text-xs font-mono font-bold text-red-500">0 Targets</span>
          </div>
          <div class="max-h-64 overflow-y-auto overflow-x-auto">
              <table class="w-full text-left text-xs min-w-[280px]">
                  <tbody id="inactivityResultsBody" class="divide-y divide-[var(--c-subtle-divide)]">
                  </tbody>
              </table>
          </div>
      </div>
  </div>
</section>



<!-- ─── Component styles (all colors via CSS vars — theme-aware) ─── -->
<style>
  .section-heading {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .section-heading::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 1.25rem;
    background: var(--c-accent);
    border-radius: 9999px;
    flex-shrink: 0;
  }
  .card {
    background: var(--c-card);
    border: 1px solid var(--c-accent-soft-ring);
    border-radius: 1rem;
    padding: 1.5rem;
  }
  .card.border-dashed {
    border-style: dashed;
    border-color: var(--c-accent-soft-ring);
  }
  /* Maintenance grid: subsection headings (match Status “Snapshot / Service health” rhythm). */
