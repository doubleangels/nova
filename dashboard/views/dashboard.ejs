      <div>
        <h3 class="font-bold text-sm text-[var(--c-text)]">Recent Joins</h3>
        <p class="text-[11px] text-[var(--c-text-dim)] mt-0.5 max-w-3xl leading-relaxed">Recorded join events and invite attribution.</p>
