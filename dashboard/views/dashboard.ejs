    <div class="px-5 py-4 border-b border-[var(--c-card-border)] bg-[var(--c-input)]/30">
      <h3 class="font-bold text-sm text-[var(--c-text)]">Active Invites</h3>
    </div>
    <div class="hidden lg:grid lg:grid-cols-12 gap-4 px-5 py-2.5 border-b border-[var(--c-card-border)] bg-[var(--c-input)] text-[9px] uppercase tracking-widest text-[var(--c-text-dim)] font-bold items-center">
        <div class="lg:col-span-3">Code / Tag</div>
        <div class="lg:col-span-2 text-center">Channel</div>
