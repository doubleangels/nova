      <div class="flex flex-wrap items-center gap-2">
        <button type="button" onclick="loadInviteJoinHistory()" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-card)] hover:bg-[var(--c-card-border)] transition-colors text-[var(--c-text)]">
          <svg class="w-3.5 h-3.5 text-[var(--c-text-dim)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
