  window.revokeNonNovaInvites = async function revokeNonNovaInvites() {
    try {
      const preview = await fetch('/api/invites/revoke-external', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dryRun: true })
      });
      const d = await preview.json().catch(() => ({}));
      if (!preview.ok) throw new Error(d.error || 'Could not list invites to revoke.');
      const n = Number(d.count) || 0;
      if (n === 0) {
        showToast('Nothing to revoke — every active invite was created by Nova.', 'success');
        return;
      }
      const samples = Array.isArray(d.sampleCodes) ? d.sampleCodes : [];
      const sampleLine =
        samples.length > 0
          ? `\n\nSample code(s): ${samples.map((c) => String(c)).join(', ')}${n > samples.length ? ' …' : ''}`
          : '';
      const ok = await confirmWithModal({
        title: 'Revoke non-Nova invites',
        message: `Delete ${n} invite link(s) whose creator is not this bot? Invites created by Nova stay active. Stored Nova tags for deleted codes are removed.${sampleLine}`,
        confirmLabel: `Revoke ${n}`
      });
      if (!ok) return;
      const exec = await fetch('/api/invites/revoke-external', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dryRun: false })
      });
      const out = await exec.json().catch(() => ({}));
      if (!exec.ok) throw new Error(out.error || 'Revoke failed.');
      const revoked = out.revoked ?? 0;
      const failed = out.failed ?? 0;
      if (failed > 0) {
        showToast(`Revoked ${revoked} invite(s); ${failed} could not be deleted (rate limit or missing).`, 'error');
      } else {
        showToast(`Revoked ${revoked} invite(s).`, 'success');
      }
      loadInvites(true);
    } catch (e) {
      showToast(e.message || 'Could not revoke invites.', 'error');
    }
  };

  function formatJoinSourceRow(row) {
    const src = String(row.source || 'unknown');
    if (src === 'baseline') {
      return `<span class="text-[var(--c-text-dim)]">${escapeHtml(row.detail || 'Baseline')}</span>`;
    }
    if (src === 'seeded') {
      return `<span class="text-[var(--c-text-dim)] text-xs">${escapeHtml(row.detail || 'Seeded from member join date')}</span>`;
    }
    if (src === 'tagged_invite' && row.tagName) {
      const tag = escapeHtml(row.tagName);
      const code = row.inviteCode ? `<span class="font-mono text-[10px]">${escapeHtml(row.inviteCode)}</span>` : '';
      const ch = row.channelName ? ` · #${escapeHtml(row.channelName)}` : '';
      return `<span class="px-1.5 py-0.5 bg-[var(--c-accent-soft-bg)] text-[var(--c-accent-text)] text-[10px] font-bold rounded uppercase">${tag}</span> ${code}${ch}`;
    }
    if (src === 'invite' && row.inviteCode) {
      const ch = row.channelName ? ` · #${escapeHtml(row.channelName)}` : '';
      return `<span class="font-mono text-xs font-bold text-[var(--c-label)]">${escapeHtml(row.inviteCode)}</span><span class="text-[var(--c-text-dim)] text-[10px]">${ch}</span> <span class="text-[10px] text-[var(--c-text-dim)]">(no tag)</span>`;
    }
    return `<span class="text-[var(--c-text-dim)] text-xs">${escapeHtml(row.detail || 'Unknown source')}</span>`;
  }

