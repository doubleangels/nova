</style>

<!-- ─── Dashboard JavaScript ─── -->
<script>
  function populateSelect(el, options, selectedValue) {
    const want = selectedValue ?? '';
    el.replaceChildren();
    for (const opt of options) {
      const o = document.createElement('option');
      o.value = opt.value;
      o.textContent = opt.text;
      el.appendChild(o);
    }
    el.value = want;
    const valid = want === '' || Array.from(el.options).some(o => o.value === want);
    if (!valid) el.value = '';
  }

  function setButtonState(btn, state) {
    if (!btn) return;
    const label = btn.querySelector('[data-btn-text]');
    if (state === 'loading') {
      btn.disabled = true;
      const cur = (label || btn).textContent.trim();
      btn.dataset.originalBtnText = cur;
      if (label) {
        label.textContent = btn.id === 'createInviteBtn' ? 'Creating…' : 'Sending…';
      } else {
        btn.textContent = 'Saving…';
      }
    } else if (state === 'idle') {
      btn.disabled = false;
      const t = btn.dataset.originalBtnText;
      if (label && t != null) label.textContent = t;
      else if (t != null) btn.textContent = t;
      delete btn.dataset.originalBtnText;
    }
  }

  function buildButtonIcon(kind = 'default') {
    if (kind === 'refresh') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>';
    if (kind === 'save') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
    if (kind === 'search') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>';
    if (kind === 'create') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>';
    if (kind === 'delete') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 7h12M9 7v12m6-12v12M10 7l1-2h2l1 2" /></svg>';
    if (kind === 'download') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v12m0 0l4-4m-4 4l-4-4M4 21h16" /></svg>';
    if (kind === 'upload') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21V9m0 0l-4 4m4-4l4 4M4 3h16" /></svg>';
    if (kind === 'send') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" /></svg>';
    if (kind === 'stop') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><rect x="6" y="6" width="12" height="12" rx="2" stroke-width="2"></rect></svg>';
    if (kind === 'wrench') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>';
    if (kind === 'chevronDown') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>';
    if (kind === 'chevronUp') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" /></svg>';
    if (kind === 'cancelX') return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>';
    return '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="7" stroke-width="2"></circle></svg>';
  }

  function inferButtonIconKind(btn) {
    const text = (btn.textContent || '').trim().toLowerCase();
    const id = (btn.id || '').toLowerCase();
    const title = (btn.title || '').toLowerCase();
    const onclick = (btn.getAttribute('onclick') || '').toLowerCase();
    const hay = `${text} ${id} ${title} ${onclick}`;
    if (btn.classList.contains('um-promo-flair-load')) return 'search';
    if (text === 'cancel' || /\bcancel\b/.test(text)) return 'cancelX';
    if (/\bconfirm\b/.test(text)) return 'save';
    if (hay.includes('save')) return 'save';
    if (onclick.includes('fixreminder') || (text.includes('fix') && text.includes('timer'))) return 'wrench';
    if (onclick.includes('clearmaintcache')) return 'refresh';
    if (hay.includes('refresh') || hay.includes('resync') || hay.includes('reload')) return 'refresh';
    if (hay.includes('dry run') || hay.includes('dryrun')) return 'search';
    if (hay.includes('validate')) return 'save';
    if (hay.includes('scan') || hay.includes('search')) return 'search';
    if (hay.includes('export') || hay.includes('download')) return 'download';
    if (hay.includes('import') || hay.includes('upload') || hay.includes('apply')) return 'upload';
    if (hay.includes('select all')) return 'save';
    if (hay.includes('clear') && onclick.includes('maintclearchannelboxes')) return 'delete';
    if (hay.includes('create') || (hay.includes('add') && !hay.includes('addreddit'))) return 'create';
    if (hay.includes('expand all')) return 'chevronDown';
    if (hay.includes('collapse all')) return 'chevronUp';
    if (hay.includes('delete') || hay.includes('remove') || hay.includes('revoke')) return 'delete';
    if (hay.includes('clear all') || hay.includes('clear chips') || hay.includes('clear session') || hay.includes('log out everyone')) return 'delete';
    if (hay.includes('clear') && !onclick.includes('clearmaintcache')) return 'delete';
    if (hay.includes('send') || hay.includes('execute') || hay.includes('run backfill')) return 'send';
    if (hay.includes('stop')) return 'stop';
    return 'default';
  }

  function ensureNonChipButtonsHaveIcons() {
    document.querySelectorAll('button').forEach((btn) => {
      if (btn.classList.contains('um-chip-btn')) return;
      if (btn.classList.contains('no-auto-icon')) return;
      if (btn.querySelector('svg')) return;
      const override = btn.getAttribute('data-btn-icon');
      const kind = override || inferButtonIconKind(btn);
      btn.classList.add('inline-flex', 'items-center', 'justify-center', 'gap-2');
      btn.insertAdjacentHTML('afterbegin', buildButtonIcon(kind));
    });
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getFieldValue(id) {
    const el = document.getElementById(id);
    if (!el) return undefined;
    if (el.type === 'checkbox') return el.checked;
    return el.value;
  }

  function setFieldValue(id, value) {
    const el = document.getElementById(id);
    if (!el) return;
    if (el.type === 'checkbox') {
      el.checked = !!value;
    } else {
      el.value = value ?? '';
    }
  }

  // ── Color picker sync ─────────────────────────────────────────────────────
  const colorPicker = document.getElementById('base_embed_color');
  const colorText   = document.getElementById('base_embed_color_text');

  function normalizeHex(hex) {
    const m = /^#?([0-9a-f]{6})$/i.exec(String(hex || '').trim());
    return m ? `#${m[1].toUpperCase()}` : '#7C3AED';
  }
  function hexToRgb(hex) {
    const h = normalizeHex(hex).slice(1);
    return {
      r: parseInt(h.slice(0, 2), 16),
      g: parseInt(h.slice(2, 4), 16),
      b: parseInt(h.slice(4, 6), 16),
    };
  }
  function rgbToHex({ r, g, b }) {
    const clamped = [r, g, b].map(v => Math.max(0, Math.min(255, Math.round(v))));
    return `#${clamped.map(v => v.toString(16).padStart(2, '0')).join('').toUpperCase()}`;
  }
  function mix(hexA, hexB, ratio) {
    const a = hexToRgb(hexA);
    const b = hexToRgb(hexB);
    const t = Math.max(0, Math.min(1, ratio));
    return rgbToHex({
      r: a.r + (b.r - a.r) * t,
      g: a.g + (b.g - a.g) * t,
      b: a.b + (b.b - a.b) * t,
    });
  }
  function applyAccentTheme(baseHex) {
    const base = normalizeHex(baseHex);
    const light = document.documentElement.getAttribute('data-theme') === 'light';
    const strong = light ? mix(base, '#000000', 0.12) : mix(base, '#FFFFFF', 0.18);
    /* Light: keep full accent for labels on soft fills (mixing toward slate looked “pastel”). */
    const text = light ? base : mix(base, '#FFFFFF', 0.45);
    const rgb = hexToRgb(base);
    const root = document.documentElement;
    const softBgA = light ? 0.14 : 0.2;
    const softRingA = light ? 0.22 : 0.32;
    const navBgA = light ? 0.12 : 0.22;
    root.style.setProperty('--c-accent', base);
    root.style.setProperty('--c-accent-strong', strong);
    root.style.setProperty('--c-accent-text', text);
    root.style.setProperty('--c-accent-soft-bg', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${softBgA})`);
    root.style.setProperty('--c-accent-soft-ring', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${softRingA})`);
    root.style.setProperty('--c-nav-active-bg', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${navBgA})`);
    root.style.setProperty('--c-nav-active-text', light ? base : text);
  }

  colorPicker?.addEventListener('input', () => {
    colorText.value = colorPicker.value.toUpperCase();
    applyAccentTheme(colorPicker.value);
    
    // Also sync the message embed color if it hasn't been manually touched
    const msgColorText = document.getElementById('msg_embed_color_text');
    const msgColorPicker = document.getElementById('msg_embed_color');
    if (msgColorText && (!msgColorText.value || msgColorText.value === colorText.placeholder)) {
        msgColorText.value = colorText.value;
        msgColorPicker.value = colorPicker.value;
    }
  });
  colorText?.addEventListener('input', () => {
    const v = colorText.value;
    if (/^#[0-9A-Fa-f]{6}$/.test(v)) {
      colorPicker.value = v;
      applyAccentTheme(v);
    }
  });

  window.addEventListener('dashboard-theme-changed', () => {
    const v = colorText?.value;
    if (v && /^#[0-9A-Fa-f]{6}$/i.test(v)) applyAccentTheme(v);
    else if (colorPicker?.value) applyAccentTheme(colorPicker.value);
  });

  // ── Load guild roles/channels ─────────────────────────────────────────────
  // savedSelectValues: optional map of { id -> value } to restore after repopulating
  async function loadGuildData(savedSelectValues = {}) {
    const [rolesRes, channelsRes] = await Promise.all([
      fetch('/api/guild/roles'),
      fetch('/api/guild/channels'),
    ]);

    const roles    = rolesRes.ok    ? await rolesRes.json()    : [];
    const channels = channelsRes.ok ? await channelsRes.json() : [];

    const noneOpt      = { value: '', text: '— None —' };
    const roleOptions    = [noneOpt, ...roles.map(r => ({ value: r.id, text: r.name }))];
    const channelOptions = [noneOpt, ...channels.map(c => ({ value: c.id, text: `#${c.name}` }))];

    document.querySelectorAll('.role-select').forEach(el => {
      populateSelect(el, roleOptions, savedSelectValues[el.id] ?? '');
    });
    document.querySelectorAll('.channel-select').forEach(el => {
      populateSelect(el, channelOptions, savedSelectValues[el.id] ?? '');
    });
  }

  function captureSelectValues() {
    const map = {};
    document.querySelectorAll('.role-select, .channel-select').forEach(el => {
      if (el.value) map[el.id] = el.value;
    });
    return map;
  }

  // ── Debounced settings persistence (replaces manual Save buttons) ─────────
  const SETTINGS_GROUPS = [
    { id: 'general', keys: ['guild_name', 'server_invite_url', 'base_embed_color', 'bot_status', 'bot_status_type'] },
    { id: 'roles', keys: ['noobies_role_id', 'noobies_threshold', 'newuser_been_in_server_before_role_id', 'give_perms_fren_role_id', 'give_perms_position_above_role_id', 'newuser_permission_diff_role_id'] },
    { id: 'moderation_spam', keys: ['anti_spam_enabled', 'anti_spam_threshold', 'anti_spam_window_hours', 'anti_spam_channel_id'] },
    { id: 'moderation_inactivity', keys: ['inactivity_guard_enabled', 'inactivity_guard_timeout_hours'] },
    { id: 'moderation_entry', keys: ['entry_guard_enabled', 'entry_guard_account_age'] },
    { id: 'reminders', keys: ['reminder_channel', 'reminder_role', 'invite_notification_channel', 'reminder_delay_bump_ms', 'reminder_delay_promote_ms', 'reminder_delay_needafriend_ms', 'reddit_promotion_targets', 'reddit_promotion_link', 'reddit_promotion_title', 'reddit_promotion_body', 'needafriend_subreddit', 'needafriend_thread_title', 'needafriend_comment'] },
    { id: 'social_notext', keys: ['notext_channel'] },
    { id: 'user_manager_prune', keys: ['prune_protected_role_id'] },
    { id: 'messaging', keys: ['msg_channel_id'] },
  ];
  const SETTINGS_DEBOUNCE_MS = 650;
  const REMINDER_DELAY_HOUR_KEYS = new Set([
    'reminder_delay_bump_ms',
    'reminder_delay_promote_ms',
    'reminder_delay_needafriend_ms',
  ]);
  const MS_PER_HOUR = 60 * 60 * 1000;
  const settingsDebounceTimers = new Map();
  const pendingChangedSettingsKeys = new Map();
  const saveGlowTimers = new Map();
  let settingsSaveInFlight = 0;
  let settingsSaveFailed = false;
  let settingsHydrating = false;

  const fieldIdToGroupId = new Map();
  SETTINGS_GROUPS.forEach((g) => {
    g.keys.forEach((k) => fieldIdToGroupId.set(k, g.id));
  });
  fieldIdToGroupId.set('base_embed_color_text', 'general');

  const dirtyTrackedIds = new Set([
    ...SETTINGS_GROUPS.flatMap((g) => g.keys),
    'base_embed_color_text',
  ]);

  let hasUnsavedChanges = false;

  function updatePendingSettingsState() {
    hasUnsavedChanges =
      settingsDebounceTimers.size > 0 ||
      settingsSaveInFlight > 0 ||
      settingsSaveFailed;
  }

  function buildSettingsPayload(keys) {
    const payload = {};
    keys.forEach((key) => {
      if (key === 'base_embed_color') {
        payload[key] = colorText?.value || colorPicker?.value || '#999999';
        return;
      }
      const val = getFieldValue(key);
      if (REMINDER_DELAY_HOUR_KEYS.has(key)) {
        const hours = Number(val);
        if (Number.isFinite(hours) && hours > 0) {
          payload[key] = Math.round(hours * MS_PER_HOUR);
        }
        return;
      }
      if (val !== undefined) payload[key] = val;
    });
    return payload;
  }

  function resolveSaveGlowTargets(key) {
    if (key === 'base_embed_color') {
      return [document.getElementById('base_embed_color'), document.getElementById('base_embed_color_text')].filter(Boolean);
    }
    if (key === 'reddit_promotion_targets') {
      const tbody = document.getElementById('redditPromotionTargetsBody');
      return tbody ? [tbody.closest('table') || tbody] : [];
    }
    const el = document.getElementById(key);
    if (!el) return [];
    if (el.type === 'checkbox') {
      const slider = el.closest('.toggle')?.querySelector('.toggle-slider');
      return slider ? [slider] : [];
    }
    return [el];
  }

  function glowSavedFields(keys) {
    for (const key of keys) {
      const targets = resolveSaveGlowTargets(key);
      for (const el of targets) {
        if (!el) continue;
        const timerKey = `${key}:${el.id || el.className || el.tagName}`;
        if (saveGlowTimers.has(timerKey)) {
          clearTimeout(saveGlowTimers.get(timerKey));
        }
        el.classList.add('save-success-glow');
        const tid = setTimeout(() => {
          el.classList.remove('save-success-glow');
          saveGlowTimers.delete(timerKey);
        }, 1000);
        saveGlowTimers.set(timerKey, tid);
      }
    }
  }

  async function performSettingsSave(keys) {
    const payload = buildSettingsPayload(keys);
    try {
      const res = await fetch('/api/settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        settingsSaveFailed = false;
        glowSavedFields(keys);
        updatePendingSettingsState();
        return true;
      }
      settingsSaveFailed = true;
      updatePendingSettingsState();
      showToast(data.error || 'Failed to save.', 'error');
      return false;
    } catch (err) {
      settingsSaveFailed = true;
      updatePendingSettingsState();
      showToast('Network error. Please try again.', 'error');
      return false;
    }
  }

  async function runSettingsSaveForGroup(groupId) {
    const group = SETTINGS_GROUPS.find((g) => g.id === groupId);
    if (!group) return;
    const pending = pendingChangedSettingsKeys.get(groupId);
    const keysToSave = pending && pending.size > 0 ? Array.from(pending) : group.keys;
    pendingChangedSettingsKeys.delete(groupId);
    settingsSaveInFlight++;
    updatePendingSettingsState();
    try {
      await performSettingsSave(keysToSave);
    } finally {
      settingsSaveInFlight--;
      updatePendingSettingsState();
    }
  }

  function scheduleDebouncedSettingsSave(groupId, changedKey = null) {
    if (settingsHydrating) return;
    const group = SETTINGS_GROUPS.find((g) => g.id === groupId);
    if (!group) return;
    if (changedKey) {
      const normalizedKey = changedKey === 'base_embed_color_text' ? 'base_embed_color' : changedKey;
      if (group.keys.includes(normalizedKey)) {
        const set = pendingChangedSettingsKeys.get(groupId) || new Set();
        set.add(normalizedKey);
        pendingChangedSettingsKeys.set(groupId, set);
      }
    }
    const existing = settingsDebounceTimers.get(groupId);
    if (existing) clearTimeout(existing);
    const tid = setTimeout(() => {
      settingsDebounceTimers.delete(groupId);
      updatePendingSettingsState();
      runSettingsSaveForGroup(groupId);
    }, SETTINGS_DEBOUNCE_MS);
    settingsDebounceTimers.set(groupId, tid);
    updatePendingSettingsState();
  }

  async function flushAllPendingSettingsSaves() {
    const pending = [...settingsDebounceTimers.keys()];
    pending.forEach((gid) => {
      const t = settingsDebounceTimers.get(gid);
      if (t) clearTimeout(t);
      settingsDebounceTimers.delete(gid);
    });
    updatePendingSettingsState();
    for (const groupId of pending) {
      await runSettingsSaveForGroup(groupId);
    }
  }

  function onSettingsFieldActivity(e) {
    if (settingsHydrating) return;
    const target = e.target;
    if (!target?.id) return;
    if (!dirtyTrackedIds.has(target.id)) return;
    const groupId = fieldIdToGroupId.get(target.id);
    if (!groupId) return;
    scheduleDebouncedSettingsSave(groupId, target.id);
  }

  function syncRedditPromotionTargetsJson() {
    const tbody = document.getElementById('redditPromotionTargetsBody');
    const hidden = document.getElementById('reddit_promotion_targets');
    if (!tbody || !hidden) return;
    const rows = [];
    tbody.querySelectorAll('tr').forEach((tr) => {
      const sub = tr.querySelector('.um-promo-sub')?.value?.trim();
      const sel = tr.querySelector('.um-promo-flair');
      const tid = sel?.value?.trim() || '';
      let flairText = '';
      if (tid && sel?.selectedOptions?.[0]) {
        flairText = sel.selectedOptions[0].textContent.trim();
      } else if (tr.dataset.flairHint) {
        flairText = String(tr.dataset.flairHint).trim();
      }
      if (!sub) return;
      rows.push({
        subreddit: sub,
        flair_text: flairText,
        flair_template_id: tid
      });
    });
    hidden.value = JSON.stringify(rows);
  }

  function redditPromotionTargetsAfterChange() {
    if (settingsHydrating) return;
    syncRedditPromotionTargetsJson();
    scheduleDebouncedSettingsSave('reminders', 'reddit_promotion_targets');
  }

  async function fetchRedditFlairsForRow(btn) {
    const tr = btn.closest('tr');
    if (!tr) return;
    const subInput = tr.querySelector('.um-promo-sub');
    const raw = subInput?.value?.trim() || '';
    const sub = raw.replace(/^r\//i, '').replace(/[^A-Za-z0-9_]/g, '');
    if (!sub) {
      showToast('Enter a subreddit name first.', 'error');
      return;
    }
    btn.disabled = true;
    try {
      const res = await fetch(`/api/reddit/link-flair?subreddit=${encodeURIComponent(sub)}`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to load flairs.');
      const sel = tr.querySelector('.um-promo-flair');
      if (!sel) return;
      const prev = sel.value;
      const hint = tr.dataset.flairHint || '';
      sel.replaceChildren();
      const o0 = document.createElement('option');
      o0.value = '';
      o0.textContent = '— None —';
      sel.appendChild(o0);
      for (const f of data.flairs || []) {
        const o = document.createElement('option');
        o.value = f.id;
        o.textContent = f.text;
        sel.appendChild(o);
      }
      if (prev && [...sel.options].some((x) => x.value === prev)) {
        sel.value = prev;
      } else if (hint) {
        const low = hint.toLowerCase();
        const match = [...sel.options].find((x) => x.value && x.textContent.toLowerCase().includes(low));
        if (match) sel.value = match.value;
      }
      delete tr.dataset.flairHint;
      redditPromotionTargetsAfterChange();
    } catch (e) {
      showToast(e.message || 'Could not load flairs.', 'error');
    } finally {
      btn.disabled = false;
    }
  }

  function addRedditPromotionRow(data = null, silent = false) {
    const tbody = document.getElementById('redditPromotionTargetsBody');
    if (!tbody) return;

    const sub = data?.subreddit != null ? String(data.subreddit) : '';
    const flair = data?.flair_text != null ? String(data.flair_text) : (data?.flairText != null ? String(data.flairText) : '');
    const flairTid = data?.flair_template_id != null ? String(data.flair_template_id) : (data?.flairTemplateId != null ? String(data.flairTemplateId) : '');

    const tr = document.createElement('tr');
    tr.className = 'align-top';
    if (flair && !flairTid) tr.dataset.flairHint = flair;

    function wrapCell(el) {
      const td = document.createElement('td');
      td.className = 'py-2.5 pr-2';
      td.appendChild(el);
      return td;
    }

    const inSub = document.createElement('input');
    inSub.type = 'text';
    inSub.className = 'field-input um-promo-sub text-sm min-h-[40px]';
    inSub.placeholder = 'MySubreddit';
    inSub.value = sub;

    const flairWrap = document.createElement('div');
    flairWrap.className = 'flex items-center gap-2 min-w-[180px]';
    const selFlair = document.createElement('select');
    selFlair.className = 'field-input um-promo-flair text-sm min-h-[40px]';
    const optNone = document.createElement('option');
    optNone.value = '';
    optNone.textContent = '— None —';
    selFlair.appendChild(optNone);
    if (flairTid) {
      const o = document.createElement('option');
      o.value = flairTid;
      o.textContent = flair || flairTid;
      selFlair.appendChild(o);
      selFlair.value = flairTid;
    }
    const btnLoad = document.createElement('button');
    btnLoad.type = 'button';
    btnLoad.className =
      'um-promo-flair-load px-2.5 py-2 rounded-lg text-[10px] font-semibold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors whitespace-nowrap';
    btnLoad.textContent = 'Find Flairs';
    flairWrap.appendChild(selFlair);
    flairWrap.appendChild(btnLoad);

    const btnRm = document.createElement('button');
    btnRm.type = 'button';
    btnRm.className = 'p-2 rounded-lg text-[var(--c-text-dim)] hover:text-red-400 hover:bg-red-500/10';
    btnRm.title = 'Remove row';
    btnRm.innerHTML = '<svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 7h12M9 7v12m6-12v12M10 7l1-2h2l1 2"/></svg>';
    btnRm.addEventListener('click', () => removeRedditPromotionRow(btnRm));

    const tdLast = document.createElement('td');
    tdLast.className = 'py-2.5 pr-0 text-right';
    tdLast.appendChild(btnRm);

    tr.appendChild(wrapCell(inSub));
    tr.appendChild(wrapCell(flairWrap));
    tr.appendChild(tdLast);

    tbody.appendChild(tr);

    if (!silent) {
      redditPromotionTargetsAfterChange();
      ensureNonChipButtonsHaveIcons();
    }
  }

  function removeRedditPromotionRow(btn) {
    const tr = btn.closest('tr');
    if (tr) tr.remove();
    redditPromotionTargetsAfterChange();
  }

  function initRedditPromotionTableFromSettingsJson(jsonStr) {
    const tbody = document.getElementById('redditPromotionTargetsBody');
    if (!tbody) return;
    tbody.replaceChildren();
    let arr = [];
    try {
      arr = JSON.parse(jsonStr || '[]');
    } catch {
      arr = [];
    }
    if (!Array.isArray(arr) || arr.length === 0) {
      addRedditPromotionRow(null, true);
    } else {
      arr.forEach((row) => addRedditPromotionRow(row, true));
    }
    syncRedditPromotionTargetsJson();
    ensureNonChipButtonsHaveIcons();
  }

  function onRedditPromotionTableInput(e) {
    if (settingsHydrating) return;
    if (e?.target?.classList?.contains('um-promo-flair') && e.target.value) {
      const tr = e.target.closest('tr');
      if (tr) delete tr.dataset.flairHint;
    }
    syncRedditPromotionTargetsJson();
    scheduleDebouncedSettingsSave('reminders', 'reddit_promotion_targets');
  }

  // ── Load settings ─────────────────────────────────────────────────────────
  async function loadSettings() {
    settingsHydrating = true;
    try {
    const res = await fetch('/api/settings');
    if (!res.ok) { showToast('Failed to load settings.', 'error'); return; }
    const s = await res.json();

    const plainFields = [
      'bot_status', 'bot_status_type', 'guild_name', 'server_invite_url',
      'noobies_threshold', 'inactivity_guard_timeout_hours', 'entry_guard_account_age',
      'anti_spam_threshold', 'anti_spam_window_hours',
      'reminder_delay_bump_ms', 'reminder_delay_promote_ms', 'reminder_delay_needafriend_ms',
      'reddit_promotion_link', 'reddit_promotion_title', 'reddit_promotion_body',
      'needafriend_subreddit', 'needafriend_thread_title', 'needafriend_comment',
    ];
    const settingsForDisplay = { ...s };
    REMINDER_DELAY_HOUR_KEYS.forEach((key) => {
      const rawMs = Number(s[key]);
      if (Number.isFinite(rawMs) && rawMs > 0) {
        settingsForDisplay[key] = Math.max(1, Math.round(rawMs / MS_PER_HOUR));
      }
    });
    plainFields.forEach(key => setFieldValue(key, settingsForDisplay[key]));

    // Checkboxes
    setFieldValue('inactivity_guard_enabled',  s.inactivity_guard_enabled);
    setFieldValue('entry_guard_enabled', s.entry_guard_enabled);
    setFieldValue('anti_spam_enabled',  s.anti_spam_enabled);

    // Color picker
    const color = s.base_embed_color || '#999999';
    if (colorPicker) colorPicker.value = color;
    if (colorText)   colorText.value   = color.toUpperCase();
    applyAccentTheme(color);

    // Build the saved-values map from settings, then populate selects
    const selectIds = [
      'give_perms_fren_role_id', 'give_perms_position_above_role_id',
      'noobies_role_id', 'newuser_been_in_server_before_role_id', 'newuser_permission_diff_role_id',
      'anti_spam_channel_id', 'reminder_channel', 'reminder_role', 'prune_protected_role_id', 'notext_channel',
      'invite_notification_channel', 'msg_channel_id'
    ];
    const savedMap = {};
    selectIds.forEach(id => {
      const v = s[id];
      if (v !== undefined && v !== null && v !== '') savedMap[id] = v;
    });
    await loadGuildData(savedMap);

    const targetsJson =
      typeof s.reddit_promotion_targets === 'string'
        ? s.reddit_promotion_targets
        : JSON.stringify(s.reddit_promotion_targets || []);
    initRedditPromotionTableFromSettingsJson(targetsJson);

    settingsSaveFailed = false;
    updatePendingSettingsState();
    } finally {
      settingsHydrating = false;
    }
  }

  // ── Refresh button ────────────────────────────────────────────────────────
  const refreshBtn  = document.getElementById('refreshBtn');
  const refreshIcon = document.getElementById('refreshIcon');

  refreshBtn?.addEventListener('click', async () => {
    refreshBtn.disabled = true;
    refreshIcon.style.transition = 'transform 0.6s ease';
    refreshIcon.style.transform  = 'rotate(360deg)';

    try {
      // Parallel fetch all data points for maximum efficiency
      await Promise.all([
        loadSettings(),
        loadHealthStats(),
        refreshLiveReminders(),
        loadDatabaseEntries(),
        loadAutoReactions(),
        loadUserSummary(true),
        loadInvites(true)
      ]);
      showToast('Dashboard synchronized with live data.', 'success');
    } catch (err) {
      console.error('Refresh failed:', err);
      showToast('Failed to sync all data points.', 'error');
    } finally {
      refreshBtn.disabled = false;
      // Reset rotation so the animation can replay next click
      setTimeout(() => {
        refreshIcon.style.transition = 'none';
        refreshIcon.style.transform  = 'rotate(0deg)';
      }, 650);
    }
  });

  document.addEventListener('input', onSettingsFieldActivity);
  document.addEventListener('change', onSettingsFieldActivity);
  window.addEventListener('beforeunload', (e) => {
    if (!hasUnsavedChanges) return;
    e.preventDefault();
    e.returnValue = '';
  });

  // ── Messaging Center ──────────────────────────────────────────────────────
  const msgModeText   = document.getElementById('msg_mode_text');
  const msgModeEmbed  = document.getElementById('msg_mode_embed');
  const editorText    = document.getElementById('editor_text');
  const editorEmbed   = document.getElementById('editor_embed');
  const embedColorWrap = document.getElementById('embed_color_wrap');
  let isEmbedMode = false;

  /** Must match .msg-mode-seg in markup — click handlers used to drop flex classes and broke icon alignment. */
  const MSG_MODE_SEG_BASE =
    'msg-mode-seg flex-1 min-h-[2.25rem] inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-md text-xs font-semibold transition-all whitespace-nowrap';

  msgModeText?.addEventListener('click', () => {
    isEmbedMode = false;
    editorText.classList.remove('hidden');
    editorEmbed.classList.add('hidden');
    embedColorWrap.classList.add('hidden');
    msgModeText.className = `${MSG_MODE_SEG_BASE} bg-[var(--c-accent)] text-white`;
    msgModeEmbed.className = `${MSG_MODE_SEG_BASE} text-[var(--c-text-dim)] hover:text-[var(--c-label)]`;
  });

  msgModeEmbed?.addEventListener('click', () => {
    isEmbedMode = true;
    editorText.classList.add('hidden');
    editorEmbed.classList.remove('hidden');
    embedColorWrap.classList.remove('hidden');
    msgModeEmbed.className = `${MSG_MODE_SEG_BASE} bg-[var(--c-accent)] text-white`;
    msgModeText.className = `${MSG_MODE_SEG_BASE} text-[var(--c-text-dim)] hover:text-[var(--c-label)]`;
    
    // Init color if empty
    const colorText = document.getElementById('msg_embed_color_text');
    const colorPicker = document.getElementById('msg_embed_color');
    if (!colorText.value) {
        const baseColor = document.getElementById('base_embed_color_text')?.value || '#999999';
        colorText.value = baseColor;
        colorPicker.value = baseColor;
    }
  });

  // Message color picker sync
  const msgColorPicker = document.getElementById('msg_embed_color');
  const msgColorText   = document.getElementById('msg_embed_color_text');
  msgColorPicker?.addEventListener('input', () => { msgColorText.value = msgColorPicker.value.toUpperCase(); });
  msgColorText?.addEventListener('input', () => {
    if (/^#[0-9A-Fa-f]{6}$/.test(msgColorText.value)) msgColorPicker.value = msgColorText.value;
  });

  const sendMessageBtn = document.getElementById('sendMessageBtn');
  sendMessageBtn?.addEventListener('click', async () => {
    const channelId = document.getElementById('msg_channel_id').value;
    if (!channelId) return showToast('Please select a target channel.', 'error');

    const payload = {
      channelId,
      isEmbed: isEmbedMode,
      content: document.getElementById('msg_content').value,
      embedData: isEmbedMode ? {
        title: document.getElementById('msg_embed_title').value,
        description: document.getElementById('msg_embed_description').value,
        color: msgColorText.value,
        thumbnail: document.getElementById('msg_embed_thumbnail').value,
        footer: document.getElementById('msg_embed_footer').value
      } : null
    };

    if (isEmbedMode && !payload.embedData.description && !payload.embedData.title) {
        return showToast('Embed must have at least a title or description.', 'error');
    }

    setButtonState(sendMessageBtn, 'loading');
    try {
      const res = await fetch('/api/messages/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (res.ok) {
        showToast('Message sent successfully!');
        if (!isEmbedMode) document.getElementById('msg_content').value = '';
      } else {
        const d = await res.json();
        showToast(d.error || 'Failed to send.', 'error');
      }
    } catch {
      showToast('Network error.', 'error');
    } finally {
      setButtonState(sendMessageBtn, 'idle');
    }
  });

  const healthTrendState = {
    cpu: [],
    mem: [],
    maxPoints: 24
  };

  function formatUptime(totalSeconds) {
    const sec = Math.max(0, Number(totalSeconds) || 0);
    const days = Math.floor(sec / 86400);
    const hours = Math.floor((sec % 86400) / 3600);
    const mins = Math.floor((sec % 3600) / 60);
    if (days > 0) return `${days}d ${hours}h ${mins}m`;
    if (hours > 0) return `${hours}h ${mins}m`;
    return `${mins}m`;
  }

  function pushTrendPoint(list, value) {
    list.push(Number(value) || 0);
    while (list.length > healthTrendState.maxPoints) list.shift();
  }

  function renderTrend(svgId, values) {
    const svg = document.getElementById(svgId);
    const polyline = svg?.querySelector('polyline');
    if (!svg || !polyline || values.length === 0) return;
    const w = 120;
    const h = 28;
    const min = Math.min(...values);
    const max = Math.max(...values);
    const range = Math.max(1, max - min);
    const points = values.map((v, i) => {
      const x = values.length === 1 ? 0 : (i / (values.length - 1)) * w;
      const y = h - (((v - min) / range) * (h - 2) + 1);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    }).join(' ');
    polyline.setAttribute('points', points);
  }

  function setBadge(el, label, healthy) {
    if (!el) return;
    const ok = healthy === true;
    el.textContent = `${label}: ${ok ? 'OK' : 'Issue'}`;
    el.className = `px-2.5 py-1 rounded-md text-[10px] uppercase tracking-wide font-bold border ${
      ok
        ? 'border-emerald-500/40 bg-emerald-500/10 text-emerald-400'
        : 'border-red-500/40 bg-red-500/10 text-red-400'
    }`;
  }

  function gatewayLabel(status) {
    const map = {
      0: 'READY',
      1: 'CONNECTING',
      2: 'RECONNECTING',
      3: 'IDLE',
      4: 'NEARLY',
      5: 'DISCONNECTED',
      6: 'WAITING'
    };
    return map[Number(status)] || `WS ${status}`;
  }

  // ── Health Monitor ────────────────────────────────────────────────────────
  async function loadHealthStats() {
    try {
      const res = await fetch('/api/health');
      if (!res.ok) throw new Error();
      const data = await res.json();
      
      document.getElementById('health_ping').textContent = `${data.ping} ms`;
      const cpuEl = document.getElementById('health_cpu');
      const cpuSubEl = document.getElementById('health_cpu_sub');
      if (cpuEl && data.cpu && typeof data.cpu.percent === 'number') {
        cpuEl.textContent = `${data.cpu.percent}%`;
      }
      if (cpuSubEl && data.cpu && data.cpu.subtitle) {
        cpuSubEl.textContent = data.cpu.subtitle;
      }
      document.getElementById('health_mem').textContent = `${data.memory.rss} MB`;
      document.getElementById('health_mem_sub').textContent = `System: ${data.memory.systemFree}GB / ${data.memory.systemTotal}GB Free`;
      document.getElementById('health_platform').textContent = data.hostname || data.platform;
      document.getElementById('health_node').textContent = `Node ${data.nodeVersion}`;
      document.getElementById('health_mem')?.setAttribute('title', `${data.memory.rss} MB`);
      document.getElementById('health_mem_sub')?.setAttribute('title', `System: ${data.memory.systemFree}GB / ${data.memory.systemTotal}GB Free`);
      document.getElementById('health_platform')?.setAttribute('title', data.hostname || data.platform || '');
      document.getElementById('health_node')?.setAttribute('title', `Node ${data.nodeVersion}`);

      document.getElementById('health_uptime').textContent = formatUptime(data.uptimeSeconds);
      document.getElementById('health_loop').textContent = `${data.eventLoop?.p95Ms ?? '--'} ms`;

      const reminders = data.queue?.reminders;
      if (reminders) {
        document.getElementById('health_queue_total').textContent = String(reminders.total);
      }

      pushTrendPoint(healthTrendState.cpu, Number(data.cpu?.percent || 0));
      pushTrendPoint(healthTrendState.mem, Number(data.memory?.rss || 0));
      renderTrend('health_cpu_trend', healthTrendState.cpu);
      renderTrend('health_mem_trend', healthTrendState.mem);
      document.getElementById('health_cpu_trend_latest').textContent = `${Number(data.cpu?.percent || 0).toFixed(1)}%`;
      document.getElementById('health_mem_trend_latest').textContent = `${Number(data.memory?.rss || 0).toFixed(2)} MB`;

      const badges = document.getElementById('healthServiceBadges')?.children || [];
      setBadge(badges[0], `Gateway ${gatewayLabel(data.services?.discordGateway)}`, Number(data.services?.discordGateway) === 0);
      setBadge(badges[1], 'API', res.ok);
      setBadge(badges[2], 'DB Read', data.services?.sqliteReadable === true);
      setBadge(badges[3], 'DB Write', data.services?.sqliteWritable === true);
      if (badges[0]) badges[0].setAttribute('title', `Discord gateway status: ${gatewayLabel(data.services?.discordGateway)}`);
      
      // Update ping color based on latency
      const pingEl = document.getElementById('health_ping');
      if (data.ping < 100) pingEl.className = 'text-2xl font-bold text-[var(--c-accent)]';
      else if (data.ping < 300) pingEl.className = 'text-2xl font-bold text-[var(--c-accent)] opacity-80';
      else pingEl.className = 'text-2xl font-bold text-[var(--c-accent)] opacity-60';
      
    } catch {
      console.warn('Failed to fetch health stats.');
    }
  }

