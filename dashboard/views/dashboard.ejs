</section>

<!-- ══════════════════════════════════════════════════════════ MODERATION & SAFETY -->
<section id="moderation" class="mb-10 page-section hidden">
  <div class="mb-6">
    <h2 class="section-heading mb-1">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
      Moderation & Safety
    </h2>
    <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed"><strong class="text-[var(--c-text-muted)]">Anti-Spam</strong>, inactivity kicks, and minimum account age on join.</p>
  </div>

  <!-- Anti-Spam -->
  <div id="moderation-anti-spam" class="premium-card p-6 border-l-4 border-[var(--c-accent)] mb-4 scroll-mt-28">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="card-sub-title text-base font-semibold">Anti-Spam</h3>
        <p class="card-sub-desc text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5">Warns when the same content is repeated across channels inside the tracking window.</p>
      </div>
      <label class="toggle">
        <input type="checkbox" id="anti_spam_enabled" />
        <span class="toggle-slider"></span>
      </label>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label class="field-label">Duplicate Threshold</label>
        <input type="number" id="anti_spam_threshold" min="2" max="10" class="field-input" />
        <p class="field-hint">Number of duplicates needed to trigger a warning (2–10).</p>
      </div>
      <div>
        <label class="field-label">Tracking Window (hours)</label>
        <input type="number" id="anti_spam_window_hours" min="1" max="72" class="field-input" />
        <p class="field-hint">How far back to look for duplicate messages (1–72).</p>
      </div>
      <div class="sm:col-span-2">
        <label class="field-label">Warning Channel</label>
        <select id="anti_spam_channel_id" class="field-input channel-select"></select>
        <p class="field-hint">The channel where the bot will post Anti-Spam alerts.</p>
      </div>
    </div>
  </div>

  <!-- Inactivity Guard -->
  <div id="moderation-inactivity-guard" class="premium-card p-6 border-l-4 border-[var(--c-accent)] mb-4 scroll-mt-28">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="card-sub-title text-base font-semibold">Inactivity Guard</h3>
        <p class="card-sub-desc text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5">Kicks members with <strong class="text-[var(--c-text-muted)]">no messages</strong> longer than your silence window (uses last-message tracking when available).</p>
      </div>
      <label class="toggle">
        <input type="checkbox" id="inactivity_guard_enabled" />
        <span class="toggle-slider"></span>
      </label>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label class="field-label">Silence Timeout (hours)</label>
        <input type="number" id="inactivity_guard_timeout_hours" min="1" max="72" class="field-input" />
        <p class="field-hint">Users silent for this long will be kicked (1–72).</p>
      </div>
    </div>
  </div>

  <!-- Entry Guard -->
  <div id="moderation-entry-guard" class="premium-card p-6 border-l-4 border-[var(--c-accent)] mb-4 scroll-mt-28">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="card-sub-title text-base font-semibold">Entry Guard</h3>
        <p class="card-sub-desc text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5">Kicks joins when the Discord account is <strong class="text-[var(--c-text-muted)]">newer</strong> than your minimum age in days.</p>
      </div>
      <label class="toggle">
        <input type="checkbox" id="entry_guard_enabled" />
        <span class="toggle-slider"></span>
      </label>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label class="field-label">Minimum Account Age (days)</label>
        <input type="number" id="entry_guard_account_age" min="1" max="365" class="field-input" />
        <p class="field-hint">Accounts younger than this are kicked on join (1–365).</p>
      </div>
    </div>
  </div>

  <!-- (Restricted Channels moved to Social & Fun) -->
</section>

