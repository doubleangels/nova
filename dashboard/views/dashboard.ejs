<!-- Page header -->
<div class="mb-8 flex flex-col sm:flex-row sm:items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold" style="color:var(--c-text)">Dashboard</h1>
    <p class="text-sm mt-1" style="color:var(--c-text-muted)">
      Managing <span class="font-medium" style="color:var(--c-accent-strong)"><%= guildName %></span>
      &bull; <span id="memberCountBadge" style="color:var(--c-text-dim)"><%= memberCount %> members</span>
    </p>
  </div>
  <div class="flex items-center gap-2 mt-1 sm:mt-0 flex-shrink-0">
    <!-- Refresh button -->
    <button id="refreshBtn" title="Refresh roles and channels from Discord" class="btn-dash-neutral px-3.5 py-2 text-sm font-medium">
      <svg id="refreshIcon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
      </svg>
      Refresh
    </button>
    <!-- Theme toggle -->
    <button id="themeToggleBtn" title="Toggle light/dark theme" class="btn-dash-neutral !p-0 w-10 h-10">
      <!-- Sun — shown in dark mode -->
      <svg id="themeIconSun" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
      </svg>
      <!-- Moon — shown in light mode, hidden by default -->
      <svg id="themeIconMoon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
      </svg>
    </button>
  </div>
</div>

<!-- Toast notification -->
<div id="toast"
     class="fixed bottom-5 right-5 z-50 hidden px-5 py-3 rounded-xl text-sm font-medium shadow-lg transition-all duration-300 max-w-xs">
</div>

<!-- Confirmation modal -->
<div id="confirmModal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 bg-[var(--c-overlay-scrim)] backdrop-blur-[2px]" id="confirmModalBackdrop"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="w-full max-w-md card">
      <h3 id="confirmModalTitle" class="text-sm font-bold text-[var(--c-text)]">Confirm Action</h3>
      <p id="confirmModalMessage" class="text-xs text-[var(--c-text-dim)] mt-2 whitespace-pre-wrap"></p>
      <div class="mt-5 flex items-center justify-end gap-2">
        <button type="button" id="confirmModalCancel" class="btn-dash-neutral px-4 py-2 text-sm">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          Cancel
        </button>
        <button type="button" id="confirmModalConfirm" class="btn-dash-primary px-4 py-2 text-sm !bg-red-500 hover:!bg-red-600">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <span data-btn-text>Confirm</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════ STATUS & OVERVIEW -->
<section id="status" class="mb-10 page-section">
  <div class="mb-8">
    <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 rounded-2xl bg-[var(--c-accent-soft-bg)] flex items-center justify-center text-[var(--c-accent)]">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
        </div>
        <div>
            <h2 class="text-2xl font-bold border-b border-[var(--c-card-border)] pb-1 inline-block">Welcome back, <%= displayName %>!</h2>
            <p class="text-sm text-[var(--c-text-dim)]">Here's what's happening with Nova and <span class="text-[var(--c-accent)] font-semibold"><%= guildName %></span>.</p>
        </div>
    </div>
  </div>

  <div id="status-snapshot" class="mb-3 scroll-mt-28">
    <p class="dash-cat-label">Snapshot</p>
    <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5 max-w-2xl">Member count, <strong class="text-[var(--c-text-muted)]">Discord</strong> API latency, and host <strong class="text-[var(--c-text-muted)]">CPU / memory</strong> at a glance.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
    <!-- Member Count -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="dash-cat-label">Community</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0-6a5.99 5.99 0 00-4-1.874A5.99 5.99 0 007 15" /></svg>
        </div>
      </div>
      <div>
        <p class="text-2xl font-bold leading-tight"><%= humanCount %> <span class="text-lg opacity-80 font-medium">Users</span></p>
        <p class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide">Server Members</p>
      </div>
    </div>

    <!-- Discord Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="dash-cat-label">Discord Status</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>
        </div>
      </div>
      <div>
        <p id="health_ping" class="text-2xl font-bold leading-tight">-- ms</p>
        <p class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide">API Latency</p>
      </div>
    </div>
    
    <!-- CPU Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="dash-cat-label">CPU</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
      </div>
      <div>
        <p id="health_cpu" class="text-2xl font-bold leading-tight">--</p>
        <p id="health_cpu_sub" class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide truncate" title="Process CPU vs wall time since last refresh; on Linux/macOS, system 1m load average.">--</p>
      </div>
    </div>
 
    <!-- Memory Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="dash-cat-label">Memory Usage</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
        </div>
      </div>
      <div>
        <p id="health_mem" class="text-xl font-bold leading-tight truncate whitespace-nowrap">-- MB</p>
        <p id="health_mem_sub" class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide truncate">--</p>
      </div>
    </div>
 
    <!-- Platform Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="dash-cat-label">Host System</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
        </div>
      </div>
      <div>
        <p id="health_platform" class="text-base font-bold truncate leading-tight">--</p>
        <p id="health_node" class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide truncate">Node --</p>
      </div>
    </div>
  </div>

  <div id="status-health" class="mt-10 mb-3 scroll-mt-28">
    <p class="dash-cat-label">Service Health</p>
    <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5 max-w-2xl"><strong class="text-[var(--c-text-muted)]">Gateway</strong>, dashboard <strong class="text-[var(--c-text-muted)]">API</strong>, and <strong class="text-[var(--c-text-muted)]">SQLite</strong> read/write checks.</p>
  </div>

  <div class="card p-4">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex flex-wrap items-center gap-2" id="healthServiceBadges">
        <span class="px-2.5 py-1 rounded-md text-[10px] uppercase tracking-wide font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] text-[var(--c-text-dim)]">Gateway: --</span>
        <span class="px-2.5 py-1 rounded-md text-[10px] uppercase tracking-wide font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] text-[var(--c-text-dim)]">API: --</span>
        <span class="px-2.5 py-1 rounded-md text-[10px] uppercase tracking-wide font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] text-[var(--c-text-dim)]">DB Read: --</span>
        <span class="px-2.5 py-1 rounded-md text-[10px] uppercase tracking-wide font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] text-[var(--c-text-dim)]">DB Write: --</span>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
        <a href="https://discordstatus.com" target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold tracking-wide text-[var(--c-accent)] hover:opacity-80 whitespace-nowrap">Discord Platform Status</a>
      </div>
    </div>
  </div>

  <div id="status-performance" class="mt-10 mb-3 scroll-mt-28">
    <p class="dash-cat-label">Performance &amp; Runtime</p>
    <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5 max-w-2xl"><strong class="text-[var(--c-text-muted)]">Uptime</strong>, event-loop delay, and short <strong class="text-[var(--c-text-muted)]">CPU / memory</strong> trends from the dashboard poll.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
    <div class="card p-4">
      <p class="text-[10px] text-[var(--c-text-dim)] uppercase tracking-wide">Uptime</p>
      <p id="health_uptime" class="text-sm font-bold mt-1">--</p>
    </div>
    <div class="card p-4">
      <p class="text-[10px] text-[var(--c-text-dim)] uppercase tracking-wide">Event loop (p95)</p>
      <p id="health_loop" class="text-sm font-bold mt-1">-- ms</p>
    </div>
    <div class="card p-4">
      <div class="flex items-center justify-between">
        <p class="text-[10px] text-[var(--c-text-dim)] uppercase tracking-wide">CPU trend</p>
        <span id="health_cpu_trend_latest" class="text-[10px] font-bold text-[var(--c-label)]">--%</span>
      </div>
      <svg id="health_cpu_trend" viewBox="0 0 120 28" class="w-full h-8 mt-2">
        <polyline points="" fill="none" stroke="var(--c-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></polyline>
      </svg>
    </div>
    <div class="card p-4">
      <div class="flex items-center justify-between">
        <p class="text-[10px] text-[var(--c-text-dim)] uppercase tracking-wide">Memory trend</p>
        <span id="health_mem_trend_latest" class="text-[10px] font-bold text-[var(--c-label)]">-- MB</span>
      </div>
      <svg id="health_mem_trend" viewBox="0 0 120 28" class="w-full h-8 mt-2">
        <polyline points="" fill="none" stroke="var(--c-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></polyline>
      </svg>
    </div>
  </div>

  <div id="status-queues" class="mt-10 mb-3 scroll-mt-28">
    <p class="dash-cat-label">Queues &amp; Scheduled Reminders</p>
    <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5 max-w-2xl">Reminder queue size and next fire times for <strong class="text-[var(--c-text-muted)]">Disboard</strong>, <strong class="text-[var(--c-text-muted)]">Reddit</strong>, and <strong class="text-[var(--c-text-muted)]">NeedAFriend</strong>.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between min-h-[7.5rem]">
      <div class="flex items-start justify-between">
        <p class="dash-cat-label">Queue</p>
      </div>
      <div>
        <p id="health_queue_total" class="text-2xl font-bold leading-tight">--</p>
        <p class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide">Scheduled Reminders</p>
      </div>
    </div>
    <div class="lg:col-span-3 grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="card p-5 flex items-center gap-5 bg-[var(--c-input)]/50 border-dashed">
        <div class="w-10 h-10 rounded-xl bg-[#24b8ea]/10 flex items-center justify-center text-[#24b8ea] flex-shrink-0">
          <svg class="w-5 h-5 text-current" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="flex flex-col min-w-0">
          <p class="text-[10px] uppercase font-bold text-[var(--c-text-dim)] tracking-wider mb-0.5">Disboard bump</p>
          <p id="live_rem_bump" class="text-sm font-semibold text-[var(--c-label)] leading-none transition-colors duration-300 tabular-nums">--:--:--</p>
        </div>
      </div>
      <div class="card p-5 flex items-center gap-5 bg-[var(--c-input)]/50 border-dashed">
        <div class="w-10 h-10 rounded-xl bg-[#ff4500]/10 flex items-center justify-center text-[#ff4500] flex-shrink-0">
          <svg class="w-5 h-5 text-current" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="flex flex-col min-w-0">
          <p class="text-[10px] uppercase font-bold text-[var(--c-text-dim)] tracking-wider mb-0.5">Reddit promote</p>
          <p id="live_rem_promote" class="text-sm font-semibold text-[var(--c-label)] leading-none transition-colors duration-300 tabular-nums">--:--:--</p>
        </div>
      </div>
      <div class="card p-5 flex items-center gap-5 bg-[var(--c-input)]/50 border-dashed">
        <div class="w-10 h-10 rounded-xl bg-[#3ba55c]/10 flex items-center justify-center text-[#3ba55c] flex-shrink-0">
          <svg class="w-5 h-5 text-current" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="flex flex-col min-w-0">
          <p class="text-[10px] uppercase font-bold text-[var(--c-text-dim)] tracking-wider mb-0.5">NeedAFriend</p>
          <p id="live_rem_needafriend" class="text-sm font-semibold text-[var(--c-label)] leading-none transition-colors duration-300 tabular-nums">--:--:--</p>
        </div>
      </div>
    </div>
  </div>

  <div id="status-shortcuts" class="mt-10 mb-3 scroll-mt-28">
    <p class="dash-cat-label">Navigate</p>
    <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed mt-0.5 max-w-2xl">Quick links to settings and tools (same destinations as the sidebar).</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-6 border-l-4 border-[var(--c-accent)]">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--c-accent-soft-bg)] flex items-center justify-center text-[var(--c-accent)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
            </div>
            <div>
                <h3 class="font-bold text-sm">Configuration Shortcuts</h3>
                <p class="text-[10px] text-[var(--c-text-dim)]">Jump directly to core setup and automation settings.</p>
            </div>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="#general" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Identity &amp; Appearance</a>
            <a href="#roles" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Roles &amp; Permissions</a>
            <a href="#moderation" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Moderation &amp; Safety</a>
            <a href="#reminders" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Reminders &amp; Schedules</a>
        </div>
    </div>
    <div class="card p-6 border-l-4 border-[var(--c-accent)]">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--c-accent-soft-bg)] flex items-center justify-center text-[var(--c-accent)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>
            </div>
            <div>
                <h3 class="font-bold text-sm">Tools &amp; Operations</h3>
                <p class="text-[10px] text-[var(--c-text-dim)]">Open admin tools for data, messaging, users, and maintenance.</p>
            </div>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="#database" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Database Explorer</a>
            <a href="#invites" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Invite Manager</a>
