<!-- ══════════════════════════════════════════════════════════ MAINTENANCE -->
<section id="maintenance" class="mb-10 page-section hidden">
  <div class="mb-6">
    <h2 class="section-heading mb-1">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582M20 20v-5h-.581M5 9a7 7 0 0114 0v6H5V9z" /></svg>
      Maintenance
    </h2>
    <p class="text-xs text-[var(--c-text-dim)]">Caches, backups, and backfill tools.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-3 border border-[var(--c-card-border)] lg:col-span-2">
      <h3 class="text-sm font-bold text-[var(--c-text)]">Deep Health</h3>
      <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed">Process info, Discord gateway ping/status, and SQLite integrity / read-write probe.</p>
      <div class="flex flex-wrap gap-2">
        <button type="button" onclick="loadDeepHealth()" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors">Refresh</button>
      </div>
      <pre id="deepHealthPre" class="text-[10px] text-[var(--c-text-muted)] font-mono whitespace-pre-wrap break-words max-h-72 overflow-y-auto p-3 rounded-lg bg-[var(--c-input)] border border-[var(--c-input-border)] mt-2">Tap Refresh.</pre>
    </div>

    <div class="card p-5 space-y-3 border border-[var(--c-card-border)]">
      <h3 class="text-sm font-bold text-[var(--c-text)]">Keyv Storage Report</h3>
      <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed">Row counts and payload size by namespace (from the <code class="text-[10px]">keyv</code> table). Largest keys help spot heavy rows.</p>
      <div class="flex flex-wrap gap-2">
        <button type="button" onclick="loadStorageReport()" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors">Refresh Report</button>
      </div>
      <pre id="storageReportPre" class="text-[10px] text-[var(--c-text-muted)] font-mono whitespace-pre-wrap break-words max-h-56 overflow-y-auto p-3 rounded-lg bg-[var(--c-input)] border border-[var(--c-input-border)] mt-2">Open this section or tap Refresh Report.</pre>
    </div>

    <div class="card p-5 space-y-3 border border-[var(--c-card-border)]">
      <h3 class="text-sm font-bold text-[var(--c-text)]">SQLite Maintenance</h3>
      <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed"><strong class="text-[var(--c-text-muted)]">ANALYZE</strong> updates query statistics. <strong class="text-[var(--c-text-muted)]">PRAGMA optimize</strong> runs internal cleanup. <strong class="text-[var(--c-text-muted)]">VACUUM</strong> compacts the file but needs exclusive access and can fail while the bot holds the database.</p>
      <div class="flex flex-wrap gap-2">
        <button type="button" onclick="runSqliteMaint('analyze')" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors">Analyze</button>
        <button type="button" onclick="runSqliteMaint('optimize')" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors">Optimize</button>
        <button type="button" onclick="runSqliteMaint('vacuum')" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-amber-500/30 bg-amber-500/10 text-amber-200 hover:bg-amber-500/20 transition-colors">Vacuum</button>
      </div>
      <pre id="sqliteMaintPre" class="hidden text-[10px] text-[var(--c-text-muted)] font-mono whitespace-pre-wrap break-words max-h-32 overflow-y-auto p-3 rounded-lg bg-[var(--c-input)] border border-[var(--c-input-border)] mt-2"></pre>
    </div>

    <div class="card p-5 space-y-3 border border-[var(--c-card-border)]">
      <h3 class="text-sm font-bold text-[var(--c-text)]">Discord Alignment</h3>
      <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed">Refetch channels and roles from Discord into the cache, then invalidate dashboard API caches (same targets as clearing User Summary / Member Fetch / Invites).</p>
      <button type="button" onclick="maintDiscordResync()" class="px-4 py-2 rounded-lg text-sm font-bold bg-[var(--c-accent)] text-white hover:opacity-90 transition-opacity">Resync Channels &amp; Roles</button>
      <p id="discordResyncHint" class="text-[10px] text-[var(--c-text-dim)] font-mono hidden"></p>
    </div>

    <div class="card p-5 space-y-4 border border-[var(--c-card-border)]">
      <h3 class="text-sm font-bold text-[var(--c-text)]">Dashboard Cache</h3>
      <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed">Clears in-memory caches used by the User Manager, member fetch, and invite list so the next load hits Discord and the database again.</p>
      <div class="flex flex-wrap gap-2">
        <button type="button" onclick="clearMaintCache(['user_summary'])" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors">User Summary</button>
        <button type="button" onclick="clearMaintCache(['guild_members'])" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors">Member Fetch</button>
        <button type="button" onclick="clearMaintCache(['invites'])" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-input-border)] bg-[var(--c-input)] hover:bg-[var(--c-card-border)] transition-colors">Invites List</button>
        <button type="button" onclick="clearMaintCache(['all'])" class="px-3 py-1.5 rounded-lg text-xs font-bold border border-[var(--c-accent-soft-ring)] bg-[var(--c-accent-soft-bg)] text-[var(--c-accent-text)] hover:opacity-90 transition-colors">Clear All</button>
      </div>
    </div>

    <div class="card p-5 space-y-4 border border-[var(--c-card-border)]">
      <h3 class="text-sm font-bold text-[var(--c-text)]">Seed Last Message Times</h3>
      <p class="text-[11px] text-[var(--c-text-dim)] leading-relaxed">Scans channel history and writes <code class="text-[10px]">last_message:&lt;userId&gt;</code> keys. Existing newer timestamps are kept. Only one job runs at a time.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="field-label text-[10px]">Max Messages Per Channel</label>
          <input type="number" id="maintMaxPerChannel" class="field-input w-full text-sm min-h-[44px]" value="10000" min="100" max="50000" />
        </div>
        <div>
          <label class="field-label text-[10px]">Delay Between Fetches (ms)</label>
          <input type="number" id="maintDelayMs" class="field-input w-full text-sm min-h-[44px]" value="300" min="0" max="5000" />
        </div>
      </div>
      <div>
        <label class="field-label text-[10px]">Channels</label>
        <label class="flex items-start gap-2.5 text-xs text-[var(--c-label)] cursor-pointer mb-2">
          <input type="checkbox" id="maintUseAllChannels" checked class="mt-0.5 rounded bg-[var(--c-input)] border-[var(--c-input-border)] text-[var(--c-accent)] focus:ring-[var(--c-accent)] shrink-0" onchange="maintOnAllChannelsChange()" />
          <span>All channels the bot can read (text, announcement &amp; thread channels)</span>
        </label>
        <div id="maintChannelListWrap" class="rounded-lg border border-[var(--c-input-border)] bg-[var(--c-input)]/30 overflow-hidden">
          <div id="maintChannelToolbar" class="flex flex-wrap justify-between items-center gap-2 px-2 py-1.5 border-b border-[var(--c-card-border)] bg-[var(--c-card)]/80">
            <span class="text-[9px] font-bold uppercase tracking-wider text-[var(--c-text-dim)]">Or choose specific channels</span>
            <span class="flex gap-2">
              <button type="button" id="maintChSelectAllBtn" onclick="maintSelectAllChannelBoxes()" class="text-[10px] font-bold text-[var(--c-accent)] hover:underline disabled:opacity-40 disabled:pointer-events-none">Select All</button>
