  // ─── Database Migration Logic ──────────────────────────────────────────────
  let migrationPollTimer = null;
  let currentMigrationJobId = null;

  function migrationStopPoll() {
    if (migrationPollTimer) {
      clearInterval(migrationPollTimer);
      migrationPollTimer = null;
    }
    currentMigrationJobId = null;
  }

  function migrationApplyJobToUI(j) {
    const wrap = document.getElementById('migrationProgressWrap');
    const bar = document.getElementById('migrationProgressBar');
    const pct = document.getElementById('migrationPercentLabel');
    const phase = document.getElementById('migrationPhaseLabel');
    const line = document.getElementById('migrationStatusLine');
    const btn = document.getElementById('runMigrationBtn');
    const stopBtn = document.getElementById('stopMigrationBtn');

    if (wrap) wrap.classList.remove('hidden');
    const p = Math.max(0, Math.min(100, Number(j.percent) || 0));
    if (bar) bar.style.width = `${p}%`;
    if (pct) pct.textContent = `${p}%`;

    let phaseText = 'Migrating';
    if (j.status === 'done') phaseText = 'Complete';
    else if (j.status === 'error') phaseText = 'Error';
    else if (j.status === 'stopped') phaseText = 'Stopped';
    if (phase) phase.textContent = phaseText;

    if (line) {
      if (j.status === 'running') {
        line.textContent = `Moved ${j.migrated || 0} / ${j.total || '—'} keys...`;
      } else if (j.status === 'done') {
        line.textContent = `Finished! Migrated ${j.migrated || 0} total keys.`;
      } else if (j.status === 'error') {
        line.textContent = `Failed: ${j.error || 'Unknown error'}`;
      } else if (j.status === 'stopped') {
        line.textContent = 'Migration stopped by user.';
      }
    }

    if (btn) btn.disabled = j.status === 'running';
    if (stopBtn) stopBtn.classList.toggle('hidden', j.status !== 'running');

    if (j.status === 'done') {
      showToast('Database migration completed successfully!');
      loadMigrationStatus();
      loadStorageReport();
    } else if (j.status === 'error') {
      showToast(j.error || 'Migration failed.', 'error');
    }
  }

  function migrationStartPolling(jobId) {
    migrationStopPoll();
    currentMigrationJobId = jobId;
    migrationPollTimer = setInterval(async () => {
      try {
        const res = await fetch(`/api/maintenance/jobs/${encodeURIComponent(jobId)}`);
        if (!res.ok) return;
        const j = await res.json();
        migrationApplyJobToUI(j);
        if (j.status === 'done' || j.status === 'error' || j.status === 'stopped') {
          migrationStopPoll();
        }
      } catch (_) {}
    }, 800);
  }

  window.runDatabaseMigration = async () => {
    const ok = await confirmWithModal({
      title: 'Start Database Migration',
      message: 'This will move legacy data to new namespaces. The dashboard will track progress. Continue?',
      confirmLabel: 'Migrate'
    });
    if (!ok) return;

    try {
      const btn = document.getElementById('runMigrationBtn');
      if (btn) btn.disabled = true;
      
      const res = await fetch('/api/maintenance/migrate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json().catch(() => ({}));
      
      if (res.status === 409 && data.jobId) {
        showToast('A migration is already running.');
        migrationStartPolling(data.jobId);
        return;
      }

      if (res.ok && data.jobId) {
        showToast('Migration started!');
        migrationStartPolling(data.jobId);
      } else {
        if (btn) btn.disabled = false;
        showToast(data.error || 'Failed to start migration.', 'error');
      }
    } catch (e) {
      const btn = document.getElementById('runMigrationBtn');
      if (btn) btn.disabled = false;
      showToast('Network error while starting migration.', 'error');
    }
  };

  window.stopDatabaseMigration = async () => {
    if (!currentMigrationJobId) return;
    try {
      const res = await fetch('/api/maintenance/migrate/stop', { method: 'POST' });
      if (res.ok) showToast('Stopping migration...');
      else showToast('Failed to stop migration.', 'error');
    } catch (e) {
      showToast('Network error while stopping.', 'error');
    }
  };

  async function migrationCheckActiveJob() {
    try {
      const res = await fetch('/api/maintenance/migration-status');
      if (!res.ok) return;
      const data = await res.json();
      if (data.activeJobId) {
        migrationStartPolling(data.activeJobId);
      }
    } catch (_) {}
  }

  function maintStopPoll() {
    if (maintSeedPollTimer) {
      clearInterval(maintSeedPollTimer);
      maintSeedPollTimer = null;
    }
    maintCurrentJobId = null;
  }

  function maintApplyJobToUI(j) {
    const wrap = document.getElementById('maintSeedProgressWrap');
    const bar = document.getElementById('maintSeedProgressBar');
    const pct = document.getElementById('maintSeedPercentLabel');
    const phase = document.getElementById('maintSeedPhaseLabel');
    const line = document.getElementById('maintSeedStatusLine');
    const btn = document.getElementById('maintStartSeedBtn');
    const stopBtn = document.getElementById('maintStopSeedBtn');
    const sum = document.getElementById('maintSeedSummary');
    const errEl = document.getElementById('maintSeedErrors');

    if (wrap) wrap.classList.remove('hidden');
    const p = Math.max(0, Math.min(100, Number(j.percent) || 0));
    if (bar) bar.style.width = `${p}%`;
    if (pct) pct.textContent = `${p}%`;

    let phaseText = 'Scanning';
    if (j.status === 'done') phaseText = 'Complete';
    else if (j.status === 'error') phaseText = 'Error';
    else if ((j.writeIndex || 0) > 0 || (j.percent || 0) >= 85) phaseText = 'Writing';
    if (j.strategy === 'member_search' && j.status === 'running' && (j.percent || 0) < 85) {
      phaseText = 'Searching';
    }
    if (phase) phase.textContent = phaseText;

    if (line) {
      if (j.strategy === 'member_search') {
        const tag = j.currentMemberTag || j.currentUserId || '—';
        const idx = Number.isFinite(j.memberIndex) ? j.memberIndex + 1 : 0;
        const tot = j.membersTotal || 0;
        line.textContent = `${tag} · member ${idx}/${tot} · search calls ${j.messagesScanned ?? 0} · users in map ${j.usersTracked ?? 0}`;
      } else {
        const ch = j.currentChannelName ? `#${j.currentChannelName}` : '—';
        const idx = Number.isFinite(j.channelIndex) ? j.channelIndex + 1 : 0;
        const tot = j.channelsTotal || 0;
        line.textContent = `${ch} · channel ${idx}/${tot} · messages ${j.messagesScanned ?? 0} · users in map ${j.usersTracked ?? 0}`;
      }
    }

    if (btn) btn.disabled = j.status === 'running';
    if (stopBtn) stopBtn.classList.toggle('hidden', j.status !== 'running');

    if (j.status === 'done' && j.result) {
      const r = j.result;
      if (sum) sum.classList.remove('hidden');
      const set = (id, v) => {
        const el = document.getElementById(id);
        if (el) el.textContent = v == null ? '—' : String(v);
      };
      set('maintSumMessages', r.messagesScanned);
      set('maintSumTracked', r.usersTracked);
      set('maintSumUpdated', r.usersUpdated);
      set('maintSumSkipped', r.usersSkipped);
      if (errEl) {
        const parts = [];
        if (r.channelErrors && r.channelErrors.length) {
          parts.push(r.channelErrors.map((e) => `${e.channelName}: ${e.message}`).join('\n'));
        }
        if (r.searchErrors && r.searchErrors.length) {
          parts.push(
            r.searchErrors.map((e) => `${e.username || e.userId || 'user'}: ${e.message}`).join('\n')
          );
        }
        if (parts.length) {
          errEl.classList.remove('hidden');
          errEl.textContent = parts.join('\n\n');
        } else {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
      }
      const dry = r.dryRun ? ' (dry run)' : '';
      showToast(`Backfill finished${dry}: ${r.usersUpdated} updated, ${r.usersSkipped} skipped.`);
    } else if (j.status === 'stopped') {
      if (sum) sum.classList.add('hidden');
      if (errEl) {
        errEl.classList.remove('hidden');
        errEl.textContent = j.error || 'Stopped by user.';
      }
      showToast('Backfill stopped.');
    } else if (j.status === 'error') {
      if (sum) sum.classList.add('hidden');
      if (errEl) {
        errEl.classList.remove('hidden');
        errEl.textContent = j.error || 'Unknown error';
      }
      showToast(j.error || 'Backfill failed.', 'error');
    }
  }

  function maintStartPolling(jobId) {
    maintStopPoll();
    maintCurrentJobId = jobId;
    maintSeedPollTimer = setInterval(async () => {
      try {
        const res = await fetch(`/api/maintenance/jobs/${encodeURIComponent(jobId)}`);
        if (!res.ok) return;
        const j = await res.json();
        maintApplyJobToUI(j);
        if (j.status === 'done' || j.status === 'error' || j.status === 'stopped') {
          maintStopPoll();
          const btn = document.getElementById('maintStartSeedBtn');
          if (btn) btn.disabled = false;
          const stopBtn = document.getElementById('maintStopSeedBtn');
          if (stopBtn) stopBtn.classList.add('hidden');
        }
      } catch (_) {}
    }, 600);
  }

  async function stopMaintSeed() {
    if (!maintCurrentJobId) {
      showToast('No active job to stop.', 'error');
      return;
    }
    try {
      const res = await fetch('/api/maintenance/seed-last-messages/stop', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed to stop backfill.');
      showToast('Stop requested. Waiting for job to halt…');
    } catch (e) {
      showToast(e.message || 'Failed to stop backfill.', 'error');
    }
  }

  async function startMaintSeed() {
    const btn = document.getElementById('maintStartSeedBtn');
    const strategy = document.getElementById('maintSeedStrategy')?.value || 'channel_scan';
    const maxPerChannel = parseInt(document.getElementById('maintMaxPerChannel')?.value, 10);
    const maxMembers = parseInt(document.getElementById('maintMaxMembers')?.value, 10);
    const delayMs = parseInt(document.getElementById('maintDelayMs')?.value, 10);
    const dryRun = document.getElementById('maintDryRun')?.checked;
    const onlyMissing = document.getElementById('maintOnlyMissing')?.checked;
    const useAllChannels = document.getElementById('maintUseAllChannels')?.checked !== false;
    let channelIds;
    if (strategy === 'member_search') {
      channelIds = undefined;
    } else if (useAllChannels) {
      channelIds = undefined;
    } else {
      channelIds = Array.from(document.querySelectorAll('.maint-channel-cb:checked')).map((cb) => cb.value);
      if (channelIds.length === 0) {
        showToast('Select at least one channel, or turn "All channels" back on.', 'error');
        if (btn) btn.disabled = false;
        return;
      }
    }

    document.getElementById('maintSeedSummary')?.classList.add('hidden');
    document.getElementById('maintSeedErrors')?.classList.add('hidden');
    document.getElementById('maintSeedProgressWrap')?.classList.remove('hidden');
    maintApplyJobToUI({
      status: 'running',
      percent: 0,
      channelIndex: 0,
      channelsTotal: 0,
      currentChannelName: null,
      messagesScanned: 0,
      usersTracked: 0
    });
    if (btn) btn.disabled = true;

    try {
      const res = await fetch('/api/maintenance/seed-last-messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          strategy,
          maxPerChannel: Number.isFinite(maxPerChannel) ? maxPerChannel : 10000,
          maxMembers: Number.isFinite(maxMembers) ? maxMembers : 50000,
          delayMs: Number.isFinite(delayMs) ? delayMs : 300,
          dryRun,
          onlyMissing: !!onlyMissing,
          channelIds
        })
      });
      const data = await res.json().catch(() => ({}));
      if (res.status === 409) {
        showToast(data.error || 'A job is already running.', 'error');
        if (data.jobId) maintStartPolling(data.jobId);
        else if (btn) btn.disabled = false;
        return;
      }
      if (!res.ok) {
        showToast(data.error || 'Failed to start backfill.', 'error');
        if (btn) btn.disabled = false;
        return;
      }
      if (data.jobId) maintStartPolling(data.jobId);
    } catch {
      showToast('Network error starting backfill.', 'error');
      if (btn) btn.disabled = false;
    }
  }

  async function maintCheckActiveJob() {
    if (maintSeedPollTimer) return;
    try {
      const res = await fetch('/api/maintenance/seed-last-messages/active');
      if (!res.ok) return;
      const { active, jobId } = await res.json();
      if (active && jobId) {
        document.getElementById('maintSeedProgressWrap')?.classList.remove('hidden');
        maintStartPolling(jobId);
      }
    } catch (_) {}
  }

  ensureNonChipButtonsHaveIcons();

  (function wireRedditPromotionTargetsDelegation() {
    const tbody = document.getElementById('redditPromotionTargetsBody');
    if (!tbody || tbody.dataset.wired) return;
    tbody.dataset.wired = '1';
    tbody.addEventListener('input', onRedditPromotionTableInput);
    tbody.addEventListener('change', onRedditPromotionTableInput);
    tbody.addEventListener('click', (ev) => {
      const btn = ev.target.closest('.um-promo-flair-load');
      if (btn) fetchRedditFlairsForRow(btn);
    });
  })();

  // ── SPA Visibility Logic ──────────────────────────────────────────────────
  /** Longest-first so `users` wins over hypothetical shorter prefixes. */
  const DASHBOARD_SECTION_IDS = [
    'maintenance',
    'moderation',
    'reminders',
    'messaging',
    'database',
    'invites',
    'general',
    'status',
    'roles',
    'social',
    'users'
  ];

  function normalizeDashboardNavHash(raw) {
    let h = (raw || '#status').split('?')[0] || '#status';
    if (h === '#inactivity') {
      if (window.location.hash === '#inactivity') {
        history.replaceState(null, '', '#users-inactivity-prune');
      }
      h = '#users-inactivity-prune';
    }

    const slug = h.startsWith('#') ? h.slice(1) : h;
    if (!slug) return { sectionHash: '#status', scrollToId: null };

    if (DASHBOARD_SECTION_IDS.includes(slug)) {
      return { sectionHash: `#${slug}`, scrollToId: null };
    }

    for (const sid of DASHBOARD_SECTION_IDS) {
      if (slug.startsWith(`${sid}-`)) {
        return { sectionHash: `#${sid}`, scrollToId: slug };
      }
    }

    return { sectionHash: h, scrollToId: null };
  }

  window.dashboardResolveNavHash = normalizeDashboardNavHash;

  function updateVisibility() {
    const { sectionHash, scrollToId } = normalizeDashboardNavHash(window.location.hash);
    document.querySelectorAll('.page-section').forEach((s) => {
      s.classList.toggle('hidden', `#${s.id}` !== sectionHash);
    });

    if (sectionHash === '#users') {
      const tbody = document.getElementById('userTableBody');
      if (tbody && tbody.children.length === 1 && tbody.innerHTML.includes('Loading')) {
        loadUserSummary(false);
      }
    }
    if (sectionHash === '#maintenance') {
      loadMaintenanceChannels();
      maintCheckActiveJob();
      loadStorageReport();
      loadDeepHealth();
      loadMigrationStatus();
      migrationCheckActiveJob();
    }

    if (scrollToId) {
      requestAnimationFrame(() => {
        document.getElementById(scrollToId)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    } else {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    ensureNonChipButtonsHaveIcons();
  }
  window.addEventListener('hashchange', async (e) => {
    await flushAllPendingSettingsSaves();
    if (!hasUnsavedChanges) {
      updateVisibility();
      return;
    }
    const ok = await confirmWithModal({
      title: 'Unsaved Changes',
      message: settingsSaveFailed
        ? 'Some settings could not be saved. Continue navigating anyway?'
        : 'You still have settings changes in progress. Continue navigating?',
      confirmLabel: 'Discard'
    });
    if (ok) {
      settingsDebounceTimers.forEach((t) => clearTimeout(t));
      settingsDebounceTimers.clear();
      settingsSaveFailed = false;
      updatePendingSettingsState();
      updateVisibility();
      return;
    }
    if (e?.oldURL) {
      const prevHash = new URL(e.oldURL).hash || '#status';
      history.replaceState(null, '', prevHash);
      updateVisibility();
    }
  });
  updateVisibility();

  // ── Init ──────────────────────────────────────────────────────────────────
  wireDbNamespaceNav();
  loadSettings();
  loadDatabaseEntries();
  loadHealthStats();
  loadInvites();
  loadInviteJoinHistory();
  const HEALTH_STATS_POLL_MS = 1000; // status cards: uptime, loop, trends, queue (1s)
  setInterval(loadHealthStats, HEALTH_STATS_POLL_MS);
</script>
