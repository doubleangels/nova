      document.getElementById('health_mem').textContent = `${data.memory.rss} MB`;
      document.getElementById('health_mem_sub').textContent = `System: ${data.memory.systemFree}GB / ${data.memory.systemTotal}GB Free`;
      document.getElementById('health_platform').textContent = data.platform;
