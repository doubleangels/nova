  // ── Advanced Database Explorer ───────────────────────────────────────────
  let allDbEntries = [];
  let curNamespace = 'main';
  let expandedCats = new Set(['config', 'tags', 'general']);
  const autoSaveTimers = new Map();

  /**
   * Returns a display-friendly representation of a DB value.
   * Primitives (string, number, boolean, null) are shown as-is.
   * Arrays and objects are pretty-printed JSON.
   */
  function displayDbValue(val) {
    if (val === null || val === undefined) return '';
    if (typeof val === 'object') return JSON.stringify(val, null, 2);
    return String(val);
  }

  /**
   * Parses a textarea string back into the correct JS type before saving.
   * Tries JSON.parse first; falls back to the raw string.
   */
  function parseDbValue(str) {
    const trimmed = str.trim();
    // Try to parse as JSON (handles numbers, booleans, null, arrays, objects)
    try { return JSON.parse(trimmed); } catch {}
    // Otherwise it's a plain string
    return trimmed;
  }

  async function loadDatabaseEntries() {
    const refreshIcon = document.getElementById('refreshDbIcon');
    if (refreshIcon) {
        refreshIcon.style.transition = 'transform 0.6s ease';
        refreshIcon.style.transform  = 'rotate(360deg)';
    }
    
    try {
      const res = await fetch('/api/database/raw');
      if (!res.ok) throw new Error();
      allDbEntries = await res.json();
      
      // Ensure current namespace still exists, else pick first available
      const namespaces = [...new Set(allDbEntries.map(e => e.namespace))];
      if (namespaces.length > 0 && !namespaces.includes(curNamespace)) {
          curNamespace = namespaces[0];
      }
      
      renderDbExplorer();
    } catch {
      showToast('Failed to load database entries.', 'error');
    } finally {
        if (refreshIcon) {
            setTimeout(() => {
                refreshIcon.style.transition = 'none';
                refreshIcon.style.transform  = 'rotate(0deg)';
            }, 650);
        }
    }
  }

  async function exportDatabaseJson() {
    const btn = document.getElementById('exportDbJsonBtn');
    if (btn) btn.disabled = true;
    try {
      const res = await fetch('/api/database/export');
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error || 'Export failed');
      }
      const blob = await res.blob();
      let filename = 'nova-database-backup.json';
      const cd = res.headers.get('Content-Disposition');
      if (cd) {
        const m = /filename\*=UTF-8''([^;\s]+)|filename="([^"]+)"/i.exec(cd);
        const raw = m ? decodeURIComponent((m[1] || m[2] || '').replace(/"/g, '')) : '';
        if (raw) filename = raw;
      }
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      showToast('Database backup downloaded.');
    } catch (e) {
      showToast(e.message || 'Failed to export database.', 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  /** @type {object | null} Parsed backup root object from file (format nova-keyv-backup). */
  let pendingDbBackupJson = null;
  let importDbBackupValidated = false;

  function setImportDbUiStatus(msg, isError) {
    const el = document.getElementById('importDbJsonStatus');
    if (!el) return;
    if (!msg) {
      el.classList.add('hidden');
      el.textContent = '';
      return;
    }
    el.classList.remove('hidden');
    el.textContent = msg;
    el.classList.toggle('text-red-400/90', !!isError);
    el.classList.toggle('text-[var(--c-text-muted)]', !isError);
  }

  document.getElementById('importDbJsonInput')?.addEventListener('change', (ev) => {
    const f = ev.target && ev.target.files && ev.target.files[0];
    pendingDbBackupJson = null;
    importDbBackupValidated = false;
    const vBtn = document.getElementById('validateDbJsonBtn');
    const aBtn = document.getElementById('applyDbJsonBtn');
    const label = document.getElementById('importDbJsonFileLabel');
    setImportDbUiStatus('');
    if (!f) {
      if (label) { label.classList.add('hidden'); label.textContent = ''; }
      if (vBtn) vBtn.disabled = true;
      if (aBtn) aBtn.disabled = true;
      return;
    }
    if (label) {
      label.classList.remove('hidden');
      label.textContent = f.name;
    }
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const parsed = JSON.parse(String(reader.result || ''));
        pendingDbBackupJson = parsed;
        importDbBackupValidated = false;
        if (vBtn) vBtn.disabled = false;
        if (aBtn) aBtn.disabled = true;
        showToast('Backup file loaded. Run Validate before Import.');
      } catch (e) {
        pendingDbBackupJson = null;
        if (vBtn) vBtn.disabled = true;
        if (aBtn) aBtn.disabled = true;
        showToast(e.message || 'Invalid JSON file.', 'error');
      }
    };
    reader.onerror = () => {
      pendingDbBackupJson = null;
      if (vBtn) vBtn.disabled = true;
      if (aBtn) aBtn.disabled = true;
      showToast('Could not read file.', 'error');
    };
    reader.readAsText(f);
  });

  async function validateDatabaseJsonImport() {
    if (!pendingDbBackupJson) {
      showToast('Choose a backup file first.', 'error');
      return;
    }
    const btn = document.getElementById('validateDbJsonBtn');
    if (btn) btn.disabled = true;
    setImportDbUiStatus('Validating…', false);
    try {
      const res = await fetch('/api/database/import/validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ backup: pendingDbBackupJson })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Validation failed');
      importDbBackupValidated = true;
      const aBtn = document.getElementById('applyDbJsonBtn');
      if (aBtn) aBtn.disabled = false;
      const ns = data.namespaces && typeof data.namespaces === 'object'
        ? Object.entries(data.namespaces).map(([k, v]) => `${k}: ${v}`).join(', ')
        : '';
      const warn = Array.isArray(data.warnings) && data.warnings.length
        ? '\n\nWarnings:\n' + data.warnings.join('\n')
        : '';
      setImportDbUiStatus(`OK — ${data.entryCount} entries${ns ? '\nNamespaces: ' + ns : ''}${warn}`, false);
      showToast('Backup passed validation.');
    } catch (e) {
      importDbBackupValidated = false;
      const aBtn = document.getElementById('applyDbJsonBtn');
      if (aBtn) aBtn.disabled = true;
      setImportDbUiStatus(e.message || 'Validation failed', true);
      showToast(e.message || 'Validation failed', 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  async function applyDatabaseJsonImport() {
    if (!pendingDbBackupJson) {
      showToast('Choose a backup file first.', 'error');
      return;
    }
    if (!importDbBackupValidated) {
      showToast('Validate the backup before importing.', 'error');
      return;
    }
    if (!confirm('Import will upsert keys from this backup into the live database. Continue?')) return;
    const btn = document.getElementById('applyDbJsonBtn');
    if (btn) btn.disabled = true;
    setImportDbUiStatus('Importing…', false);
    try {
      const res = await fetch('/api/database/import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ backup: pendingDbBackupJson, dryRun: false })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Import failed');
      const warn = Array.isArray(data.warnings) && data.warnings.length
        ? '\n\nWarnings:\n' + data.warnings.join('\n')
        : '';
      setImportDbUiStatus(`Imported ${data.imported} rows.${warn}`, false);
      showToast(`Imported ${data.imported} keys.`);
      try { await loadDatabaseEntries(); } catch (_) {}
    } catch (e) {
      setImportDbUiStatus(e.message || 'Import failed', true);
      showToast(e.message || 'Import failed', 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  // ── User Manager System ────────────────────────────────────────────────────────
  let userManagerCache = null;
  /** @type {Set<string>} Selected filter chip keys (AND together). */
  let userManagerSelectedChips = new Set();

  function userManagerRoot() {
    return document.getElementById('users');
  }

  function userManagerIsBot(u) {
    return u.isBot === true || u.isBot === 1 || String(u.isBot).toLowerCase() === 'true';
  }

  function userManagerPrivilege(u) {
    const v = u && u.privilege;
    if (v === 'admin' || v === 'Admin') return 'admin';
    if (v === 'mod' || v === 'Mod') return 'mod';
    return null;
  }

  function escapeHtmlUserManager(s) {
    if (s == null) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function userManagerInactiveDays() {
    const el = document.getElementById('inactivityDays');
    const n = parseInt(el && el.value, 10);
    if (!Number.isFinite(n) || n < 1) return 30;
    return Math.min(730, n);
  }

  function userManagerIsInactive(u, days) {
    if (userManagerIsBot(u)) return false;
    const thresholdMs = days * 24 * 60 * 60 * 1000;
    const now = Date.now();
    const last = u.lastMessageAt;
    const lastNum =
      last != null && last !== ''
        ? typeof last === 'number'
          ? last
          : Number(last)
        : null;
    if (lastNum != null && !Number.isNaN(lastNum)) {
      return now - lastNum > thresholdMs;
    }
    const joinTs = new Date(u.joinedAt).getTime();
    if (Number.isNaN(joinTs)) return false;
    return now - joinTs > thresholdMs;
  }

  function formatRelativeActivity(lastMessageAt) {
    if (lastMessageAt == null || typeof lastMessageAt !== 'number') {
      return { text: 'No messages', cls: 'text-[var(--c-text-dim)] italic', title: 'No message activity recorded yet for this member' };
    }
    const now = Date.now();
    let diffSec = Math.floor((now - lastMessageAt) / 1000);
    if (diffSec < 0) diffSec = 0;
    const absTitle = new Date(lastMessageAt).toLocaleString();
    if (diffSec < 60) return { text: 'Just now', cls: 'text-emerald-400', title: absTitle };
    const diffMin = Math.floor(diffSec / 60);
    if (diffMin < 60) return { text: `${diffMin}m ago`, cls: 'text-[var(--c-text-muted)]', title: absTitle };
    const diffH = Math.floor(diffMin / 60);
    if (diffH < 48) return { text: `${diffH}h ago`, cls: 'text-[var(--c-text-muted)]', title: absTitle };
    const diffD = Math.floor(diffH / 24);
    if (diffD < 14) return { text: `${diffD}d ago`, cls: 'text-[var(--c-text-muted)]', title: absTitle };
    const diffW = Math.floor(diffD / 7);
    if (diffW < 8) return { text: `${diffW}w ago`, cls: 'text-[var(--c-text-dim)]', title: absTitle };
    const diffMo = Math.floor(diffD / 30);
    return { text: `${Math.max(1, diffMo)}mo ago`, cls: 'text-[var(--c-text-dim)]', title: absTitle };
  }

  function userManagerSyncChipStyles() {
    const root = userManagerRoot();
    if (!root) return;
    root.querySelectorAll('[data-um-chip]').forEach((btn) => {
      const key = btn.getAttribute('data-um-chip');
      const on = key && userManagerSelectedChips.has(key);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      btn.classList.toggle('ring-2', !!on);
      btn.classList.toggle('ring-[var(--c-accent)]', !!on);
      btn.classList.toggle('ring-offset-2', !!on);
      btn.classList.toggle('ring-offset-[var(--c-card)]', !!on);
    });
  }

  function userManagerToggleChip(key) {
    if (!userManagerCache) return;
    if (userManagerSelectedChips.has(key)) userManagerSelectedChips.delete(key);
    else userManagerSelectedChips.add(key);
    userManagerSyncChipStyles();
    renderUserManagerTable();
  }

  function userManagerPassesChipFilters(u, chips) {
    if (!chips || chips.size === 0) return true;
    const bot = userManagerIsBot(u);
    const p = userManagerPrivilege(u);

    if (chips.has('admin') && p !== 'admin') return false;
    if (chips.has('mod') && p !== 'mod') return false;

    if (chips.has('safe') && !u.hasSafeRole) return false;

    const wantHumans = chips.has('humans');
    const wantBots = chips.has('bots');
    if (!(wantHumans && wantBots)) {
      if (wantHumans && bot) return false;
      if (wantBots && !bot) return false;
    }

    return true;
  }

  function userManagerUpdateChips() {
    if (!userManagerCache || !userManagerCache.recent) return;
    const list = userManagerCache.recent;
    let admin = 0;
    let mod = 0;
    let umHumans = 0;
    let umBots = 0;
    let safe = 0;
    for (const u of list) {
      const p = userManagerPrivilege(u);
      const bot = userManagerIsBot(u);
      if (p === 'admin') admin++;
      else if (p === 'mod') mod++;
      if (bot) umBots++;
      else umHumans++;
      if (u.hasSafeRole) safe++;
    }
    const set = (id, n) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(n);
    };
    set('usr_chip_admin', admin);
    set('usr_chip_mod', mod);
    set('usr_chip_um_humans', umHumans);
    set('usr_chip_um_bots', umBots);
    set('usr_chip_safe', safe);
    userManagerSyncChipStyles();
  }

  function userManagerResetFilters() {
    userManagerSelectedChips.clear();
    userManagerSyncChipStyles();
    renderUserManagerTable();
  }

  function renderUserManagerTable() {
    if (!userManagerCache || !userManagerCache.recent) return;
    const tbody = document.getElementById('userTableBody');
    const hint = document.getElementById('userManagerFilterHint');
    const days = userManagerInactiveDays();
    userManagerUpdateChips();

    const filtered = userManagerCache.recent.filter((u) =>
      userManagerPassesChipFilters(u, userManagerSelectedChips)
    );

    tbody.innerHTML = '';
    if (filtered.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'px-4 py-10 text-center text-xs text-[var(--c-text-dim)]';
      empty.setAttribute('role', 'status');
      empty.textContent = 'No members match these filters.';
      tbody.appendChild(empty);
    } else {
      const safeCheckSvg =
        '<svg class="w-4 h-4 mx-auto text-[var(--c-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
      const safeEmpty = '<span class="inline-flex w-8 justify-center text-[var(--c-text-dim)] opacity-25 select-none" aria-hidden="true">—</span>';
      filtered.forEach((u) => {
        const row = document.createElement('div');
        row.setAttribute('role', 'listitem');
        const bot = userManagerIsBot(u);
        const privilege = userManagerPrivilege(u);
        const rowTint =
          privilege === 'admin'
            ? ' border-l-[3px] border-l-red-500 bg-red-500/[0.08] hover:bg-red-500/[0.12]'
            : privilege === 'mod'
              ? ' border-l-[3px] border-l-yellow-500 bg-yellow-500/[0.07] hover:bg-yellow-500/[0.11]'
              : ' border-l-[3px] border-l-transparent hover:bg-white/[0.02]';
        row.className = 'transition-colors' + rowTint;

        const avatarSrc = u.avatar || 'https://cdn.discordapp.com/embed/avatars/0.png';
        const createdDate = new Date(u.joinedAt).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric'
        });
        const safeInner = u.hasSafeRole
          ? `<span class="inline-flex w-8 justify-center" title="Has protected (safe) role">${safeCheckSvg}</span>`
          : safeEmpty;

        const last = u.lastMessageAt;
        const lastNum =
          last != null && last !== ''
            ? typeof last === 'number'
              ? last
              : Number(last)
            : NaN;
        const hasTracked = Number.isFinite(lastNum);
        const inactiveRow = userManagerIsInactive(u, days);

        let lastCellHtml;
        let lastCellTitle;
        if (!hasTracked) {
          lastCellHtml =
            '<span style="color:var(--c-text);font-style:italic">No messages</span>';
          lastCellTitle = 'No message activity recorded yet for this member';
        } else {
          const rel = formatRelativeActivity(lastNum);
          const actCls = inactiveRow && !bot ? 'text-orange-400/90' : rel.cls;
          lastCellTitle = rel.title;
          lastCellHtml = `<span class="${actCls}">${escapeHtmlUserManager(rel.text)}</span>`;
        }

        const dn = escapeHtmlUserManager(u.displayName);
        const un = escapeHtmlUserManager(u.username);

        row.innerHTML = `
          <div class="lg:grid lg:grid-cols-12 lg:gap-4 lg:items-center px-3 sm:px-4 py-3">
            <div class="lg:col-span-5 flex items-start justify-between gap-2 min-w-0">
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div class="relative shrink-0">
                  <img src="${avatarSrc}" class="w-9 h-9 sm:w-8 sm:h-8 rounded-full border border-[var(--c-input-border)]" alt="">
                  ${bot ? '<div class="absolute -bottom-1 -right-1 px-1 rounded bg-blue-500 text-[8px] font-bold text-white leading-tight">BOT</div>' : ''}
                </div>
                <div class="flex flex-col min-w-0">
                  <span class="text-sm font-bold truncate ${privilege === 'admin' ? 'text-red-400' : privilege === 'mod' ? 'text-yellow-400' : 'text-[var(--c-text)]'}">${dn}</span>
                  <span class="text-[10px] text-[var(--c-text-dim)] truncate">@${un}</span>
                </div>
              </div>
              <div class="lg:hidden shrink-0 pt-0.5" aria-label="Safe role">${safeInner}</div>
            </div>
            <div class="hidden lg:flex lg:col-span-1 justify-center items-center" aria-label="Safe role">${safeInner}</div>
            <div class="mt-3 lg:mt-0 lg:col-span-3 text-xs sm:text-sm">
              <span class="block lg:hidden text-[9px] font-bold uppercase tracking-wider text-[var(--c-text-dim)] mb-1">Last activity</span>
              <div class="text-right" title="${escapeHtmlUserManager(lastCellTitle)}">${lastCellHtml}</div>
            </div>
            <div class="mt-2 lg:mt-0 lg:col-span-3 text-xs text-[var(--c-text-muted)]">
              <span class="block lg:hidden text-[9px] font-bold uppercase tracking-wider text-[var(--c-text-dim)] mb-1">Joined</span>
              <div class="text-right">${createdDate}</div>
            </div>
          </div>
        `;
        tbody.appendChild(row);
      });
    }

    if (hint) {
      const allN = userManagerCache.recent.length;
      const selective = userManagerSelectedChips.size > 0;
      if (filtered.length !== allN || selective) {
        hint.classList.remove('hidden');
        hint.textContent = `Showing ${filtered.length} of ${allN} members (${days} day${days === 1 ? '' : 's'} inactive threshold; chips use AND).`;
      } else {
        hint.classList.add('hidden');
        hint.textContent = '';
      }
    }
  }

  async function loadUserSummary(forceRefresh = false) {
    const refreshIcon = document.getElementById('refreshUsersIcon');
    if (refreshIcon) {
      refreshIcon.style.transition = 'transform 0.6s ease';
      refreshIcon.style.transform = 'rotate(360deg)';
    }
    try {
      const url = forceRefresh ? '/api/users/summary?refresh=1' : '/api/users/summary';
      const res = await fetch(url);
      if (res.ok) {
        const data = await res.json();
        document.getElementById('usr_total').textContent = data.total || 0;
        document.getElementById('usr_humans').textContent = data.humans || 0;
        document.getElementById('usr_bots').textContent = data.bots || 0;
        userManagerCache = data;
        renderUserManagerTable();
        if (data.stale) {
          showToast('User list is cached (Discord member fetch rate limit). Try again in a moment.', 'success');
        }
      }
    } catch (e) {
      console.error('Failed to load user summary', e);
    } finally {
      if (refreshIcon) {
        setTimeout(() => {
          refreshIcon.style.transition = 'none';
          refreshIcon.style.transform = 'rotate(0deg)';
        }, 650);
      }
    }
  }

  (function initUserManagerFilterListeners() {
    const root = userManagerRoot();
    if (!root) return;
    root.addEventListener('input', (e) => {
      if (e.target && e.target.id === 'inactivityDays') renderUserManagerTable();
    });
  })();

  async function scanInactivityKickTargets() {
      const days = document.getElementById('inactivityDays').value;
      const excludedRole = document.getElementById('prune_protected_role_id')?.value || '';
      const btn = document.getElementById('inactivityScanBtn');
      const prevLabel = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Scanning…';

      try {
          const res = await fetch(`/api/users/inactivity/dry-run?days=${days}&excludedRole=${excludedRole}`);
          const data = await res.json();
          
          if (!res.ok) throw new Error(data.error);

          const container = document.getElementById('inactivityResultsContainer');
          const countSpan = document.getElementById('inactivityTargetCount');
          const tbody = document.getElementById('inactivityResultsBody');
          const execBtn = document.getElementById('inactivityExecuteBtn');

          container.classList.remove('hidden');
          countSpan.textContent = `${data.targetCount} Targets`;
          execBtn.textContent = `Execute Inactivity Prune (${data.targetCount} users)`;

          if (data.targetCount > 0) {
              execBtn.classList.remove('hidden');
              execBtn.disabled = false;
              execBtn.classList.remove('opacity-50', 'cursor-not-allowed');
              tbody.innerHTML = data.targets.map(t => `
                  <tr class="hover:bg-white/[0.02] transition-colors">
                      <td class="px-4 py-2 font-medium text-[var(--c-text)]">${t.displayName} <span class="text-[10px] text-[var(--c-text-dim)]">@${t.username}</span></td>
                      <td class="px-4 py-2 text-right text-red-400 opacity-80">${t.reason}</td>
                  </tr>
              `).join('');
          } else {
              execBtn.classList.add('hidden', 'opacity-50', 'cursor-not-allowed');
              execBtn.disabled = true;
              tbody.innerHTML = `<tr><td colspan="2" class="px-4 py-4 text-center text-[var(--c-text-dim)]">No inactive users found matching this criteria.</td></tr>`;
          }
      } catch (err) {
          showToast('Failed to scan for Inactivity Prune targets.', 'error');
      } finally {
          btn.disabled = false;
          btn.textContent = prevLabel;
      }
  }

  async function executeInactivityKicks() {
      if (!confirm('WARNING: This will permanently kick the listed users from the server. This action cannot be undone. Are you sure you want to proceed?')) return;
      
      const days = document.getElementById('inactivityDays').value;
      const excludedRole = document.getElementById('prune_protected_role_id')?.value || '';
      const btn = document.getElementById('inactivityExecuteBtn');
      const scanBtn = document.getElementById('inactivityScanBtn');
      
      btn.disabled = true;
      btn.textContent = 'Executing Inactivity Prune...';
      scanBtn.disabled = true;

      try {
          const res = await fetch('/api/users/inactivity/execute', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ days, excludedRole })
          });
          const data = await res.json();
          
          if (!res.ok) throw new Error(data.error);
          
          showToast(`Successfully kicked ${data.kicked} users. ${data.failed > 0 ? `(${data.failed} failed)` : ''}`, 'success');
          
          document.getElementById('inactivityResultsContainer').classList.add('hidden');
          btn.classList.add('hidden');
          loadUserSummary(true);
      } catch (err) {
          showToast('Failed to execute Inactivity Prune.', 'error');
      } finally {
          btn.disabled = false;
          scanBtn.disabled = false;
      }
  }

  function getCategory(key) {
      const parts = key.split(':');
      return parts.length > 1 ? parts[0] : 'general';
  }

  function renderDbExplorer() {
    const nsList  = document.getElementById('dbNamespaceList');
    const content = document.getElementById('dbContentArea');
    const search  = document.getElementById('dbSearch').value.toLowerCase();
    
    // 1. Group Data
    const namespaces = [...new Set(allDbEntries.map(e => e.namespace))].sort();
    const nsCounts = {};
    allDbEntries.forEach(e => nsCounts[e.namespace] = (nsCounts[e.namespace] || 0) + 1);

    // 2. Render Namespace Sidebar
    nsList.innerHTML = namespaces.map(ns => `
        <button type="button" onclick="switchNamespace('${ns}')" class="flex w-full lg:w-full min-w-[7.5rem] shrink-0 snap-start items-center justify-between gap-2 px-3 py-2.5 rounded-lg text-sm transition-all ${curNamespace === ns ? 'bg-[var(--c-accent-soft-bg)] text-[var(--c-accent-text)] font-semibold' : 'text-[var(--c-text-dim)] hover:bg-[var(--c-nav-hover-bg)] hover:text-[var(--c-label)]'}">
            <span class="truncate">${ns}</span>
            <span class="text-[10px] opacity-60 bg-black/20 px-1.5 py-0.5 rounded-full shrink-0">${nsCounts[ns]}</span>
        </button>
    `).join('') || '<div class="p-4 text-center text-xs text-[var(--c-text-dim)] w-full min-w-[200px] flex-shrink-0">No namespaces found</div>';

    // 3. Filter and Group by Category for current namespace
    const filtered = allDbEntries.filter(e => {
        if (e.namespace !== curNamespace) return false;
        if (!search) return true;
        return e.key.toLowerCase().includes(search) || String(e.value).toLowerCase().includes(search);
    });

    const groups = {};
    filtered.forEach(e => {
        const cat = getCategory(e.key);
        if (!groups[cat]) groups[cat] = [];
        groups[cat].push(e);
    });

    // 4. Render Content
    const sortedCats = Object.keys(groups).sort((a,b) => {
        if (a === 'config') return -1;
        if (b === 'config') return 1;
        if (a === 'general') return 1;
        return a.localeCompare(b);
    });

    if (sortedCats.length === 0) {
        content.innerHTML = `<div class="card p-12 text-center text-[var(--c-text-dim)] bg-transparent border-dashed">No entries found in "${curNamespace}" match your search.</div>`;
        return;
    }

    content.innerHTML = sortedCats.map(cat => {
        const isOpen = expandedCats.has(cat);
        const items = groups[cat];
        
        return `
            <div class="card p-0 overflow-hidden border-[var(--c-card-border)]">
                <button onclick="toggleCategory('${cat}')" class="w-full flex items-center justify-between px-5 py-3 hover:bg-[var(--c-input)] transition-colors text-left border-b border-transparent data-[open=true]:border-[var(--c-card-border)]" data-open="${isOpen}">
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--c-accent)] transition-transform ${isOpen ? 'rotate-90' : ''}" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-xs font-bold uppercase tracking-wider text-[var(--c-label)]">${cat}</span>
                        <span class="text-[10px] text-[var(--c-text-dim)] font-normal">(${items.length} items)</span>
                    </div>
                </button>
                
                <div class="${isOpen ? '' : 'hidden'}">
                    <div class="divide-y divide-[var(--c-card-border)]">
                            ${items.map(e => {
                                const cleanKey = e.key.includes(':') ? e.key.split(':').slice(1).join(':') : e.key;
                                const fullKeyJs = JSON.stringify(e.fullKey);
                                const statusId = `status-${e.fullKey.replace(/:/g, '-')}`;
                                return `
                                    <div class="px-3 sm:px-5 py-3 sm:py-3.5 hover:bg-[var(--c-input)]/40 transition-colors group">
                                        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,14rem)_minmax(0,1fr)] gap-3 lg:gap-4 items-stretch lg:items-start">
                                            <div class="min-w-0 lg:pl-4">
                                                <div class="text-sm font-medium text-[var(--c-label)] break-words">${cleanKey}</div>
                                                <div class="text-[10px] text-[var(--c-text-dim)] font-mono mt-0.5 break-all opacity-80 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">full: ${e.key}</div>
                                            </div>
                                            <div class="relative flex flex-col sm:flex-row items-stretch sm:items-stretch gap-2 min-w-0 h-full">
                                                <div id="${statusId}" class="hidden sm:block absolute sm:left-0 sm:top-3 w-1.5 h-1.5 rounded-full bg-[var(--c-accent)] opacity-0 transition-opacity duration-300 sm:-translate-x-4" title="Synced"></div>
                                                <div class="flex-1 min-w-0 sm:pl-1 h-full">
                                                    <textarea 
                                                        class="w-full h-full min-h-[44px] bg-[var(--c-input)] border border-[var(--c-input-border)] rounded-md px-2 py-2 text-xs font-mono text-[var(--c-text-muted)] focus:border-[var(--c-accent)] focus:ring-1 focus:ring-[var(--c-accent-soft-ring)] outline-none transition-all resize-none overflow-hidden" 
                                                        rows="1"
                                                        oninput="autoResize(this); scheduleSave(${fullKeyJs}, this.value)"
                                                        onfocus="autoResize(this)"
                                                    >${displayDbValue(e.value)}</textarea>
                                                </div>
                                                <button type="button" onclick="deleteDbEntry(${fullKeyJs})" class="p-2.5 min-h-[44px] min-w-[44px] sm:min-w-0 sm:min-h-0 sm:p-2 self-end sm:self-start text-[var(--c-text-dim)] hover:text-[var(--c-accent)] hover:bg-[var(--c-input)] rounded-lg transition-all sm:opacity-0 sm:group-hover:opacity-100 shrink-0" title="Delete entry">
                                                    <svg class="w-4 h-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                `;
                            }).join('')}
                    </div>
                </div>
            </div>
        `;
    }).join('');

    // Trigger initial resize for visible textareas
    setTimeout(() => {
        document.querySelectorAll('#dbContentArea textarea').forEach(autoResize);
    }, 10);
  }

  window.switchNamespace = (ns) => { curNamespace = ns; dbPage = 1; renderDbExplorer(); };
  window.toggleCategory = (cat) => { 
    if (expandedCats.has(cat)) expandedCats.delete(cat); 
    else expandedCats.add(cat); 
    renderDbExplorer(); 
    // Trigger resize after re-rendering
    setTimeout(() => {
        document.querySelectorAll('#dbContentArea textarea').forEach(autoResize);
    }, 50);
  };
  window.expandAllCategories = () => { 
    [...new Set(allDbEntries.filter(e => e.namespace === curNamespace).map(e => getCategory(e.key)))].forEach(c => expandedCats.add(c)); 
    renderDbExplorer(); 
    setTimeout(() => {
        document.querySelectorAll('#dbContentArea textarea').forEach(autoResize);
    }, 50);
  };
  window.collapseAllCategories = () => { expandedCats.clear(); renderDbExplorer(); };

  window.autoResize = (el) => {
    el.style.height = 'auto';
    el.style.height = (el.scrollHeight) + 'px';
  };

  window.deleteDbEntry = async (fullKey) => {
    if (!confirm(`Are you sure you want to delete "${fullKey}"?\nThis action is irreversible.`)) return;
    
    try {
        const res = await fetch('/api/database/raw', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fullKey })
        });
        if (res.ok) {
            showToast('Entry deleted successfully.');
            // Update local state and re-render
            allDbEntries = allDbEntries.filter(e => e.fullKey !== fullKey);
            renderDbExplorer();
        } else {
            showToast('Failed to delete entry.', 'error');
        }
    } catch {
        showToast('Network error while deleting.', 'error');
    }
  };

  window.scheduleSave = (fullKey, valueStr) => {
    const statusId = `status-${fullKey.replace(/:/g, '-')}`;
    const statusEl = document.getElementById(statusId);
    
    // Show "dirty" state
    if (statusEl) {
        statusEl.classList.remove('bg-[var(--c-accent)]', 'opacity-0');
        statusEl.classList.add('bg-[var(--c-accent)]', 'opacity-80', 'animate-pulse');
    }

    if (autoSaveTimers.has(fullKey)) clearTimeout(autoSaveTimers.get(fullKey));

    autoSaveTimers.set(fullKey, setTimeout(async () => {
        let value;
        try {
            value = parseDbValue(valueStr);
        } catch {
            value = valueStr;
        }

        if (statusEl) {
            statusEl.classList.remove('animate-pulse');
            statusEl.classList.add('bg-[var(--c-accent)]'); // Saving state
        }

        try {
            const res = await fetch('/api/database/raw', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ fullKey, value })
            });
            if (res.ok) {
                if (statusEl) {
                    statusEl.classList.remove('bg-[var(--c-accent)]');
                    statusEl.classList.add('bg-[var(--c-accent)]');
                    setTimeout(() => statusEl.classList.add('opacity-0'), 2000);
                }
            } else {
                showToast('Failed to auto-save change.', 'error');
                if (statusEl) {
                    statusEl.classList.add('bg-[var(--c-accent)]');
                }
            }
        } catch {
            if (statusEl) {
                statusEl.classList.add('bg-[var(--c-accent)]');
            }
        }
    }, 1500));
  };

  document.getElementById('dbSearch')?.addEventListener('input', renderDbExplorer);

  // ── Live Reminders System ───────────────────────────────────────────────────
  let liveReminders = { bump: null, promote: null, needafriend: null };

  async function refreshLiveReminders() {
    try {
      const res = await fetch('/api/reminders/live');
      if (res.ok) {
        liveReminders = await res.json();
        updateRemindersUI();
      }
    } catch (e) {
      console.error('Failed to fetch reminders', e);
    }
  }

  function updateRemindersUI() {
    const now = Date.now();
    const remColors = { bump: '#24b8ea', promote: '#ff4500', needafriend: '#3ba55c' };
    ['bump', 'promote', 'needafriend'].forEach(type => {
      const targetTime = liveReminders[type] ? new Date(liveReminders[type]).getTime() : null;
      const displayIdStatus = `rem_stat_${type}`;
      const displayIdLive   = `live_rem_${type}`;
      
      const statusEl = document.getElementById(displayIdStatus);
      const liveEl   = document.getElementById(displayIdLive);
      
      if (!targetTime || targetTime <= now) {
        if (statusEl) { statusEl.textContent = 'READY'; statusEl.style.color = remColors[type]; }
        if (liveEl)   { liveEl.textContent = 'READY'; liveEl.style.color = remColors[type]; }
        return;
      }
      
      const diff = targetTime - now;
      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      const timeStr = `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
      
      if (statusEl) {
          statusEl.textContent = timeStr;
          statusEl.style.color = ''; // Resets inline styling 
      }
      if (liveEl) {
          liveEl.textContent = timeStr;
          liveEl.style.color = (h === 0 && m < 10) ? '#f87171' : ''; // Fallback for expiring warning (rose-400 equivalent)
      }
    });
  }

  window.fixReminder = async (type) => {
    const btn = document.getElementById(`fixBtn_${type}`);
    const originalText = btn.textContent;
    btn.textContent = 'FIXING...';
    btn.disabled = true;

    try {
      const res = await fetch('/api/reminders/fix', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type })
      });
      if (res.ok) {
        showToast(`${type.charAt(0).toUpperCase() + type.slice(1)} timer reset successfully.`);
        await refreshLiveReminders();
      } else {
        showToast('Failed to reset timer.', 'error');
      }
    } catch (e) {
      showToast('Network error while resetting timer.', 'error');
    } finally {
      btn.textContent = originalText;
      btn.disabled = false;
    }
  };

  // Start polling
  setInterval(updateRemindersUI, 1000);
  setInterval(refreshLiveReminders, 30000);
  refreshLiveReminders();

  // ── Auto-Reactions System ──────────────────────────────────────────────────
  async function loadAutoReactions() {
    try {
      const res = await fetch('/api/fun/auto-reactions');
      if (res.ok) {
        const reactions = await res.json();
        renderAutoReactions(reactions);
      }
    } catch (e) {
      console.error('Failed to load auto-reactions', e);
    }
  }

  function renderAutoReactions(reactions) {
    const tbody = document.getElementById('autoReactionTableBody');
    if (!tbody) return;
    
    if (reactions.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" class="px-4 py-8 text-center text-xs text-[var(--c-text-dim)]">No reactions configured. Click "Add New Pattern" to start!</td></tr>';
      return;
    }

    tbody.innerHTML = reactions.map((r, i) => `
      <tr class="group hover:bg-[var(--c-input)]/50 transition-colors">
        <td class="px-4 py-3">
          <input type="text" class="field-input py-1.5 text-xs font-mono ar-regex" value="${r.regex}" placeholder="e.g. hello|hi" />
        </td>
        <td class="px-4 py-3">
          <input type="text" class="field-input py-1.5 text-xs font-mono ar-emoji" value="${r.emoji}" placeholder="e.g. 👋 or :smile:" />
        </td>
        <td class="px-4 py-3 text-right">
          <button onclick="removeAutoReactionRow(this)" class="p-1.5 text-[var(--c-text-dim)] hover:text-[var(--c-accent)] hover:bg-[var(--c-accent-soft-bg)] rounded-lg transition-all opacity-0 group-hover:opacity-100">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </td>
      </tr>
    `).join('');
  }

  window.addAutoReactionRow = () => {
    const tbody = document.getElementById('autoReactionTableBody');
    if (tbody.innerHTML.includes('No reactions configured')) tbody.innerHTML = '';
    
    const tr = document.createElement('tr');
    tr.className = 'group hover:bg-[var(--c-input)]/50 transition-colors';
    tr.innerHTML = `
      <td class="px-4 py-3">
        <input type="text" class="field-input py-1.5 text-xs font-mono ar-regex" placeholder="e.g. hello|hi" />
      </td>
      <td class="px-4 py-3">
        <input type="text" class="field-input py-1.5 text-xs font-mono ar-emoji" placeholder="e.g. 👋 or :smile:" />
      </td>
      <td class="px-4 py-3 text-right">
        <button onclick="removeAutoReactionRow(this)" class="p-1.5 text-[var(--c-text-dim)] hover:text-red-500 hover:bg-red-500/10 rounded-lg transition-all opacity-0 group-hover:opacity-100">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      </td>
    `;
    tbody.appendChild(tr);
  };

  window.removeAutoReactionRow = (btn) => {
    btn.closest('tr').remove();
    const tbody = document.getElementById('autoReactionTableBody');
    if (tbody.children.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" class="px-4 py-8 text-center text-xs text-[var(--c-text-dim)]">No reactions configured. Click "Add New Pattern" to start!</td></tr>';
    }
  };

  window.saveAutoReactions = async () => {
    const btn = document.getElementById('saveReactionsBtn');
    const rows = document.querySelectorAll('#autoReactionTableBody tr');
    const reactions = [];
    
    rows.forEach(row => {
      const regex = row.querySelector('.ar-regex')?.value.trim();
      const emoji = row.querySelector('.ar-emoji')?.value.trim();
      if (regex && emoji) reactions.push({ regex, emoji });
    });

    setButtonState(btn, 'loading');
    try {
      const res = await fetch('/api/fun/auto-reactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reactions })
      });
      if (res.ok) {
        showToast('Auto-reactions saved successfully.');
        await loadAutoReactions();
      } else {
        showToast('Failed to save auto-reactions.', 'error');
      }
    } catch (e) {
      showToast('Network error while saving.', 'error');
    } finally {
      setButtonState(btn, 'idle');
    }
  };

  loadAutoReactions();
  document.getElementById('refreshDbBtn')?.addEventListener('click', loadDatabaseEntries);

  // ── Maintenance (cache + seed last messages) ───────────────────────────────
  let maintSeedPollTimer = null;
  let maintCurrentJobId = null;

  function maintOnAllChannelsChange() {
    const useAll = document.getElementById('maintUseAllChannels')?.checked;
    document.querySelectorAll('.maint-channel-cb').forEach((cb) => {
      cb.disabled = !!useAll;
    });
    const sa = document.getElementById('maintChSelectAllBtn');
    const cl = document.getElementById('maintChClearBtn');
    if (sa) sa.disabled = !!useAll;
    if (cl) cl.disabled = !!useAll;
  }

  function maintSelectAllChannelBoxes() {
    if (document.getElementById('maintUseAllChannels')?.checked) return;
    document.querySelectorAll('.maint-channel-cb').forEach((cb) => {
      cb.checked = true;
    });
  }

  function maintClearChannelBoxes() {
    if (document.getElementById('maintUseAllChannels')?.checked) return;
    document.querySelectorAll('.maint-channel-cb').forEach((cb) => {
      cb.checked = false;
    });
  }

  async function loadMaintenanceChannels() {
    const list = document.getElementById('maintChannelList');
    if (!list || list.dataset.loaded === '1') return;
    try {
      const res = await fetch('/api/guild/channels');
      if (!res.ok) {
        list.innerHTML = '<p class="text-[10px] text-red-400/90 px-1">Could not load channels.</p>';
        return;
      }
      const channels = await res.json();
      list.innerHTML = '';
      channels.forEach((c) => {
        const id = `maint_ch_${c.id}`;
        const row = document.createElement('label');
        row.className =
          'flex items-center gap-2.5 px-2 py-1 rounded-md hover:bg-[var(--c-card)]/80 cursor-pointer text-xs text-[var(--c-text)]';
        const input = document.createElement('input');
        input.type = 'checkbox';
        input.className =
          'maint-channel-cb rounded bg-[var(--c-input)] border-[var(--c-input-border)] text-[var(--c-accent)] focus:ring-[var(--c-accent)] shrink-0';
        input.value = c.id;
        input.id = id;
        input.disabled = document.getElementById('maintUseAllChannels')?.checked !== false;
        const span = document.createElement('span');
        span.className = 'font-mono text-[11px] truncate';
        span.textContent = `#${c.name}`;
        row.appendChild(input);
        row.appendChild(span);
        list.appendChild(row);
      });
      list.dataset.loaded = '1';
      maintOnAllChannelsChange();
    } catch (_) {
      list.innerHTML = '<p class="text-[10px] text-red-400/90 px-1">Could not load channels.</p>';
    }
  }

  async function clearMaintCache(targets) {
    try {
      const res = await fetch('/api/maintenance/cache/clear', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targets })
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        showToast(`Cleared cache: ${(data.cleared || []).join(', ') || 'ok'}`);
      } else {
        showToast(data.error || 'Failed to clear cache.', 'error');
      }
    } catch {
      showToast('Network error clearing cache.', 'error');
    }
  }

  async function loadStorageReport() {
    const pre = document.getElementById('storageReportPre');
    if (pre) pre.textContent = 'Loading…';
    try {
      const res = await fetch('/api/maintenance/storage-report');
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed');
      const lines = [];
      lines.push(`File: ${data.filePath}`);
      lines.push(`File size: ${(data.fileBytes / 1024).toFixed(1)} KB`);
      lines.push(`Total rows: ${data.totalRows}`);
      lines.push('');
      lines.push('By namespace (rows / value bytes):');
      (data.byNamespace || []).forEach((r) => {
        lines.push(`  ${r.ns}: ${r.rowCount} rows, ${r.valueBytes} B`);
      });
      lines.push('');
      lines.push('Largest keys (serialized value size):');
      (data.largestKeys || []).forEach((r) => {
        const k = String(r.key).startsWith('sessions:')
          ? `sessions:…${String(r.key).slice(-10)}`
          : r.key;
        lines.push(`  ${r.bytes} B  ${k}`);
      });
      if (pre) pre.textContent = lines.join('\n');
    } catch (e) {
      if (pre) pre.textContent = e.message || 'Error';
      showToast('Failed to load storage report.', 'error');
    }
  }

  async function runSqliteMaint(op) {
    const pre = document.getElementById('sqliteMaintPre');
    if (pre) {
      pre.classList.remove('hidden');
      pre.textContent = 'Running…';
    }
    try {
      const res = await fetch('/api/maintenance/sqlite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ operation: op })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed');
      const before = (data.fileBytesBefore / 1024).toFixed(1);
      const after = (data.fileBytesAfter / 1024).toFixed(1);
      if (pre) pre.textContent = `OK: ${data.operation || op}\nBefore: ${before} KB\nAfter: ${after} KB`;
      showToast(`SQLite ${op} completed.`);
      loadStorageReport();
    } catch (e) {
      if (pre) pre.textContent = e.message || 'Error';
      showToast(e.message || 'SQLite operation failed.', 'error');
    }
  }

  async function maintDiscordResync() {
    const hint = document.getElementById('discordResyncHint');
    try {
      const res = await fetch('/api/maintenance/discord/resync', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channels: true, roles: true })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed');
      if (hint) {
        hint.classList.remove('hidden');
        hint.textContent = 'Channels and roles refetched; API caches cleared.';
      }
      showToast('Discord caches refreshed.');
    } catch (e) {
      showToast(e.message || 'Resync failed.', 'error');
    }
  }

  async function maintCleanupSessions(dryRun) {
    const pre = document.getElementById('cleanupSessionsPre');
    if (pre) {
      pre.classList.remove('hidden');
      pre.textContent = '…';
    }
    try {
      const res = await fetch('/api/maintenance/cleanup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dryRun, target: 'expired_sessions' })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed');
      const msg = `scanned=${data.scanned} expired=${data.expiredFound} deleted=${data.deleted} dryRun=${data.dryRun}`;
      if (pre) pre.textContent = msg;
      showToast(dryRun ? 'Dry Run Complete.' : `Deleted ${data.deleted} expired session row(s).`);
    } catch (e) {
      if (pre) pre.textContent = e.message || 'Error';
      showToast(e.message || 'Cleanup failed.', 'error');
    }
  }

  async function maintClearAllSessions() {
    if (!confirm('This logs out every dashboard user. Continue?')) return;
    try {
      const res = await fetch('/api/maintenance/sessions/clear-all', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ confirm: 'CLEAR_ALL_SESSIONS' })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed');
      showToast(`Removed ${data.deleted} session row(s). Redirecting…`);
      window.location.href = '/login';
    } catch (e) {
      showToast(e.message || 'Failed to clear sessions.', 'error');
    }
  }

  async function loadDeepHealth() {
    const pre = document.getElementById('deepHealthPre');
    if (pre) pre.textContent = 'Loading…';
    try {
      const res = await fetch('/api/health/deep');
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed');
      if (pre) pre.textContent = JSON.stringify(data, null, 2);
    } catch (e) {
      if (pre) pre.textContent = e.message || 'Error';
      showToast('Failed to load deep health.', 'error');
    }
  }

  function maintStopPoll() {
    if (maintSeedPollTimer) {
      clearInterval(maintSeedPollTimer);
      maintSeedPollTimer = null;
    }
    maintCurrentJobId = null;
  }

  function maintApplyJobToUI(j) {
    const wrap = document.getElementById('maintSeedProgressWrap');
    const bar = document.getElementById('maintSeedProgressBar');
    const pct = document.getElementById('maintSeedPercentLabel');
    const phase = document.getElementById('maintSeedPhaseLabel');
    const line = document.getElementById('maintSeedStatusLine');
    const btn = document.getElementById('maintStartSeedBtn');
    const stopBtn = document.getElementById('maintStopSeedBtn');
    const sum = document.getElementById('maintSeedSummary');
    const errEl = document.getElementById('maintSeedErrors');

    if (wrap) wrap.classList.remove('hidden');
    const p = Math.max(0, Math.min(100, Number(j.percent) || 0));
    if (bar) bar.style.width = `${p}%`;
    if (pct) pct.textContent = `${p}%`;

    let phaseText = 'Scanning';
    if (j.status === 'done') phaseText = 'Complete';
    else if (j.status === 'error') phaseText = 'Error';
    else if ((j.writeIndex || 0) > 0 || (j.percent || 0) >= 85) phaseText = 'Writing';
    if (phase) phase.textContent = phaseText;

    if (line) {
      const ch = j.currentChannelName ? `#${j.currentChannelName}` : '—';
      const idx = Number.isFinite(j.channelIndex) ? j.channelIndex + 1 : 0;
      const tot = j.channelsTotal || 0;
      line.textContent = `${ch} · channel ${idx}/${tot} · messages ${j.messagesScanned ?? 0} · users in map ${j.usersTracked ?? 0}`;
    }

    if (btn) btn.disabled = j.status === 'running';
    if (stopBtn) stopBtn.classList.toggle('hidden', j.status !== 'running');

    if (j.status === 'done' && j.result) {
      const r = j.result;
      if (sum) sum.classList.remove('hidden');
      const set = (id, v) => {
        const el = document.getElementById(id);
        if (el) el.textContent = v == null ? '—' : String(v);
      };
      set('maintSumMessages', r.messagesScanned);
      set('maintSumTracked', r.usersTracked);
      set('maintSumUpdated', r.usersUpdated);
      set('maintSumSkipped', r.usersSkipped);
      if (errEl) {
        if (r.channelErrors && r.channelErrors.length) {
          errEl.classList.remove('hidden');
          errEl.textContent = r.channelErrors.map((e) => `${e.channelName}: ${e.message}`).join('\n');
        } else {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
      }
      const dry = r.dryRun ? ' (dry run)' : '';
      showToast(`Backfill finished${dry}: ${r.usersUpdated} updated, ${r.usersSkipped} skipped.`);
    } else if (j.status === 'stopped') {
      if (sum) sum.classList.add('hidden');
      if (errEl) {
        errEl.classList.remove('hidden');
        errEl.textContent = j.error || 'Stopped by user.';
      }
      showToast('Backfill stopped.');
    } else if (j.status === 'error') {
      if (sum) sum.classList.add('hidden');
      if (errEl) {
        errEl.classList.remove('hidden');
        errEl.textContent = j.error || 'Unknown error';
      }
      showToast(j.error || 'Backfill failed.', 'error');
    }
  }

  function maintStartPolling(jobId) {
    maintStopPoll();
    maintCurrentJobId = jobId;
    maintSeedPollTimer = setInterval(async () => {
      try {
        const res = await fetch(`/api/maintenance/jobs/${encodeURIComponent(jobId)}`);
        if (!res.ok) return;
        const j = await res.json();
        maintApplyJobToUI(j);
        if (j.status === 'done' || j.status === 'error' || j.status === 'stopped') {
          maintStopPoll();
          const btn = document.getElementById('maintStartSeedBtn');
          if (btn) btn.disabled = false;
          const stopBtn = document.getElementById('maintStopSeedBtn');
          if (stopBtn) stopBtn.classList.add('hidden');
        }
      } catch (_) {}
    }, 600);
  }

  async function stopMaintSeed() {
    if (!maintCurrentJobId) {
      showToast('No active job to stop.', 'error');
      return;
    }
    try {
      const res = await fetch('/api/maintenance/seed-last-messages/stop', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Failed to stop backfill.');
      showToast('Stop requested. Waiting for job to halt…');
    } catch (e) {
      showToast(e.message || 'Failed to stop backfill.', 'error');
    }
  }

  async function startMaintSeed() {
    const btn = document.getElementById('maintStartSeedBtn');
    const maxPerChannel = parseInt(document.getElementById('maintMaxPerChannel')?.value, 10);
    const delayMs = parseInt(document.getElementById('maintDelayMs')?.value, 10);
    const onlyMissing = document.getElementById('maintOnlyMissing')?.checked;
    const dryRun = document.getElementById('maintDryRun')?.checked;
    const useAllChannels = document.getElementById('maintUseAllChannels')?.checked !== false;
    let channelIds;
    if (useAllChannels) {
      channelIds = undefined;
    } else {
      channelIds = Array.from(document.querySelectorAll('.maint-channel-cb:checked')).map((cb) => cb.value);
      if (channelIds.length === 0) {
        showToast('Select at least one channel, or turn "All channels" back on.', 'error');
        if (btn) btn.disabled = false;
        return;
      }
    }

    document.getElementById('maintSeedSummary')?.classList.add('hidden');
    document.getElementById('maintSeedErrors')?.classList.add('hidden');
    document.getElementById('maintSeedProgressWrap')?.classList.remove('hidden');
    maintApplyJobToUI({
      status: 'running',
      percent: 0,
      channelIndex: 0,
      channelsTotal: 0,
      currentChannelName: null,
      messagesScanned: 0,
      usersTracked: 0
    });
    if (btn) btn.disabled = true;

    try {
      const res = await fetch('/api/maintenance/seed-last-messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          maxPerChannel: Number.isFinite(maxPerChannel) ? maxPerChannel : 10000,
          delayMs: Number.isFinite(delayMs) ? delayMs : 300,
          onlyMissing,
          dryRun,
          channelIds
        })
      });
      const data = await res.json().catch(() => ({}));
      if (res.status === 409) {
        showToast(data.error || 'A job is already running.', 'error');
        if (data.jobId) maintStartPolling(data.jobId);
        else if (btn) btn.disabled = false;
        return;
      }
      if (!res.ok) {
        showToast(data.error || 'Failed to start backfill.', 'error');
        if (btn) btn.disabled = false;
        return;
      }
      if (data.jobId) maintStartPolling(data.jobId);
    } catch {
      showToast('Network error starting backfill.', 'error');
      if (btn) btn.disabled = false;
    }
  }

  async function maintCheckActiveJob() {
    if (maintSeedPollTimer) return;
    try {
      const res = await fetch('/api/maintenance/seed-last-messages/active');
      if (!res.ok) return;
      const { active, jobId } = await res.json();
      if (active && jobId) {
        document.getElementById('maintSeedProgressWrap')?.classList.remove('hidden');
        maintStartPolling(jobId);
      }
    } catch (_) {}
  }

  // Attach save handlers for non-hierarchical sections
  document.querySelectorAll('.save-btn').forEach(btn => {
    if (btn.id !== 'sendMessageBtn') btn.addEventListener('click', () => saveSection(btn));
  });

  // ── SPA Visibility Logic ──────────────────────────────────────────────────
  function updateVisibility() {
    const hash = window.location.hash || '#status';
    document.querySelectorAll('.page-section').forEach(s => {
        s.classList.toggle('hidden', `#${s.id}` !== hash);
    });
    
    if (hash === '#users') {
        const tbody = document.getElementById('userTableBody');
        if (tbody && tbody.children.length === 1 && tbody.innerHTML.includes('Loading')) {
            loadUserSummary(false);
        }
    }

    if (hash === '#maintenance') {
      loadMaintenanceChannels();
      maintCheckActiveJob();
      loadStorageReport();
      loadDeepHealth();
    }
    
    // Smooth scroll to top on section change
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  window.addEventListener('hashchange', updateVisibility);
  updateVisibility();

  // ── Init ──────────────────────────────────────────────────────────────────
  loadSettings();
  loadDatabaseEntries();
  loadHealthStats();
  loadInvites();
  setInterval(loadHealthStats, 30000); // Refresh stats every 30s
</script>
