        <div class="flex items-center justify-between p-5 border-b border-[var(--c-card-border)]">
            <h3 class="font-bold text-lg">Create New Invite</h3>
            <button onclick="closeInviteModal()" class="text-[var(--c-text-dim)] hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
