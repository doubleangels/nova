<!-- Page header -->
<div class="mb-8 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold" style="color:var(--c-text)">Dashboard</h1>
    <p class="text-sm mt-1" style="color:var(--c-text-muted)">
      Managing <span class="font-medium" style="color:var(--c-accent-strong)"><%= guildName %></span>
      &bull; <span id="memberCountBadge" style="color:var(--c-text-dim)"><%= memberCount %> members</span>
    </p>
  </div>
  <div class="flex items-center gap-2 mt-1 flex-shrink-0">
    <!-- Refresh button -->
    <button id="refreshBtn" title="Refresh roles and channels from Discord"
            style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.875rem;background:var(--c-input);border:1px solid var(--c-input-border);border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:var(--c-label);cursor:pointer;transition:background-color 0.2s;white-space:nowrap">
      <svg id="refreshIcon" xmlns="http://www.w3.org/2000/svg" style="width:1rem;height:1rem;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
      </svg>
      Refresh
    </button>
    <!-- Theme toggle -->
    <button id="themeToggleBtn" title="Toggle light/dark theme"
            style="display:flex;align-items:center;justify-content:center;width:2.375rem;height:2.375rem;background:var(--c-input);border:1px solid var(--c-input-border);border-radius:0.5rem;cursor:pointer;transition:background-color 0.2s;flex-shrink:0;color:var(--c-label)">
      <!-- Sun — shown in dark mode -->
      <svg id="themeIconSun" xmlns="http://www.w3.org/2000/svg" style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
      </svg>
      <!-- Moon — shown in light mode, hidden by default -->
      <svg id="themeIconMoon" xmlns="http://www.w3.org/2000/svg" style="width:1rem;height:1rem;display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
      </svg>
    </button>
  </div>
</div>

<!-- Toast notification -->
<div id="toast"
     class="fixed bottom-5 right-5 z-50 hidden px-5 py-3 rounded-xl text-sm font-medium shadow-lg transition-all duration-300 max-w-xs">
</div>

<!-- ══════════════════════════════════════════════════════════ STATUS & OVERVIEW -->
<section id="status" class="mb-10 page-section">
  <div class="mb-8">
    <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 rounded-2xl bg-[var(--c-accent-soft-bg)] flex items-center justify-center text-[var(--c-accent)]">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
        </div>
        <div>
            <h2 class="text-2xl font-bold border-b border-white/5 pb-1 inline-block">Welcome back, <%= displayName %>!</h2>
            <p class="text-sm text-[var(--c-text-dim)]">Here's what's happening with Nova and <span class="text-[var(--c-accent)] font-semibold"><%= guildName %></span>.</p>
        </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
    <!-- Member Count -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--c-text-dim)]">Community</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0-6a5.99 5.99 0 00-4-1.874A5.99 5.99 0 007 15" /></svg>
        </div>
      </div>
      <div>
        <p class="text-2xl font-bold leading-tight"><%= humanCount %> <span class="text-lg opacity-80 font-medium">Users</span></p>
        <p class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide">Server Members</p>
      </div>
    </div>

    <!-- Discord Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--c-text-dim)]">Discord Status</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>
        </div>
      </div>
      <div>
        <p id="health_ping" class="text-2xl font-bold leading-tight">-- ms</p>
        <p class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide">API Latency</p>
      </div>
    </div>
    
    <!-- Uptime Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--c-text-dim)]">Bot Uptime</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
      </div>
      <div>
        <p id="health_uptime" class="text-xl font-bold leading-tight">--</p>
        <p class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-wide">Process Uptime</p>
      </div>
    </div>
 
    <!-- Memory Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--c-text-dim)]">Memory Usage</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
        </div>
      </div>
      <div>
        <p id="health_mem" class="text-xl font-bold leading-tight">-- MB</p>
        <p id="health_mem_sub" class="text-[8px] text-[var(--c-text-muted)] uppercase truncate">--</p>
      </div>
    </div>
 
    <!-- Platform Card -->
    <div class="premium-card p-5 group border-b-2 border-[var(--c-accent-soft-ring)] flex flex-col justify-between h-[120px]">
      <div class="flex items-start justify-between">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--c-text-dim)]">Host System</p>
        <div class="icon-box bg-[var(--c-accent-soft-bg)] text-[var(--c-accent)] group-hover:scale-110 -mt-1 -mr-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
        </div>
      </div>
      <div>
        <p id="health_platform" class="text-xs font-bold truncate leading-tight">--</p>
        <p id="health_node" class="text-[10px] text-[var(--c-text-muted)] uppercase tracking-tight">Node --</p>
      </div>
    </div>
  </div>

  <!-- Live Reminders Monitoring -->
  <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="card p-5 flex items-center gap-5 bg-[var(--c-input)]/50 border-dashed">
      <div class="w-10 h-10 rounded-xl bg-[var(--c-accent)]/10 flex items-center justify-center text-[var(--c-accent)] flex-shrink-0">
        <svg class="w-5 h-5 text-[var(--c-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      </div>
      <div class="flex flex-col">
        <p class="text-[10px] uppercase font-bold text-[var(--c-text-dim)] tracking-wider mb-0.5">Disboard Bump</p>
        <p id="live_rem_bump" class="text-sm font-mono font-bold text-[var(--c-label)] italic leading-none">--:--:--</p>
      </div>
    </div>
    <div class="card p-5 flex items-center gap-5 bg-[var(--c-input)]/50 border-dashed">
      <div class="w-10 h-10 rounded-xl bg-[var(--c-accent)]/10 flex items-center justify-center text-[var(--c-accent)] flex-shrink-0">
        <svg class="w-5 h-5 text-[var(--c-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      </div>
      <div class="flex flex-col">
        <p class="text-[10px] uppercase font-bold text-[var(--c-text-dim)] tracking-wider mb-0.5">Reddit Promo</p>
        <p id="live_rem_promote" class="text-sm font-mono font-bold text-[var(--c-label)] italic leading-none">--:--:--</p>
      </div>
    </div>
    <div class="card p-5 flex items-center gap-5 bg-[var(--c-input)]/50 border-dashed">
      <div class="w-10 h-10 rounded-xl bg-[var(--c-accent)]/10 flex items-center justify-center text-[var(--c-accent)] flex-shrink-0">
        <svg class="w-5 h-5 text-[var(--c-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      </div>
      <div class="flex flex-col">
        <p class="text-[10px] uppercase font-bold text-[var(--c-text-dim)] tracking-wider mb-0.5">NeedAFriend</p>
        <p id="live_rem_needafriend" class="text-sm font-mono font-bold text-[var(--c-label)] italic leading-none">--:--:--</p>
      </div>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-6 border-l-4 border-[var(--c-accent)]">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--c-accent-soft-bg)] flex items-center justify-center text-[var(--c-accent)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
            </div>
            <div>
                <h3 class="font-bold text-sm">Bot Configuration</h3>
                <p class="text-[10px] text-[var(--c-text-dim)]">Adjust core personality and automation.</p>
            </div>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="#general" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Appearance</a>
            <a href="#moderation" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Security</a>
            <a href="#roles" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Roles</a>
            <a href="#reminders" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Logistics</a>
        </div>
    </div>
    <div class="card p-6 border-l-4 border-[var(--c-accent)]">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--c-accent-soft-bg)] flex items-center justify-center text-[var(--c-accent)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>
            </div>
            <div>
                <h3 class="font-bold text-sm">Data Explorer</h3>
                <p class="text-[10px] text-[var(--c-text-dim)]">Inspect and modify raw key-value storage.</p>
            </div>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="#database" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Storage Browser</a>
            <a href="#invites" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Invite Manager</a>
            <a href="#messaging" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Messaging</a>
            <a href="#social" class="px-3 py-2 bg-[var(--c-input)] rounded-lg text-xs font-medium hover:bg-[var(--c-accent-soft-bg)] hover:text-[var(--c-accent-text)] transition-all hover:scale-105 border border-transparent hover:border-[var(--c-accent-soft-ring)]">Social & Fun</a>
        </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ IDENTITY & APPEARANCE -->
<section id="general" class="mb-10 page-section hidden">
  <div class="mb-6">
    <h2 class="section-heading mb-1">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
      Identity & Appearance
    </h2>
    <p class="text-xs text-[var(--c-text-dim)]">Customize how Nova represents your community across Discord.</p>
  </div>

  <div class="premium-card p-6 border-l-4 border-[var(--c-accent)]">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

      <div>
        <label class="field-label">Guild/Server Name</label>
        <input type="text" id="guild_name" class="field-input" maxlength="100" />
        <p class="field-hint">The display name of your server used throughout the dashboard and embeds.</p>
      </div>

      <div>
        <label class="field-label">Server Invite URL</label>
        <input type="url" id="server_invite_url" class="field-input" placeholder="https://discord.gg/..." />
        <p class="field-hint">Included in bot notifications and automated kick messages.</p>
      </div>

      <div class="sm:col-span-2">
        <label class="field-label">Embed Accent Color</label>
        <div class="flex items-center gap-3 mt-1">
          <input type="color" id="base_embed_color" class="h-10 w-20" />
          <input type="text" id="base_embed_color_text" placeholder="#999999"
                 class="field-input w-40" maxlength="7" pattern="^#[0-9A-Fa-f]{6}$" />
        </div>
        <p class="field-hint">Determines the color strip on the side of bot response embeds.</p>
      </div>

      <div class="sm:col-span-2 flex items-start gap-4">
        <div class="flex-1">
          <label class="field-label">Bot Status Text</label>
          <input type="text" id="bot_status" placeholder="for ways to help! ❤️"
                 class="field-input" maxlength="128" />
          <p class="field-hint">The custom status message shown in the bot's Discord profile.</p>
        </div>
        <div class="w-48">
          <label class="field-label">Activity Type</label>
          <select id="bot_status_type" class="field-input">
            <option value="watching">Watching</option>
            <option value="playing">Playing</option>
            <option value="listening">Listening to</option>
            <option value="streaming">Streaming</option>
            <option value="competing">Competing in</option>
            <option value="custom">Custom</option>
          </select>
        </div>
      </div>

    </div>
    <div class="mt-6 flex justify-end">
      <button class="save-btn" data-section="general"
              data-keys="guild_name,server_invite_url,base_embed_color,bot_status,bot_status_type">
        Save Identity Settings
      </button>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════════════════ ROLES & PERMISSIONS -->
<section id="roles" class="mb-10 page-section hidden">
  <div class="mb-6">
    <h2 class="section-heading mb-1">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0-6a5.99 5.99 0 00-4-1.874A5.99 5.99 0 007 15" /></svg>
      Roles & Permissions
    </h2>
    <p class="text-xs text-[var(--c-text-dim)]">Configure automated role assignments and command access levels.</p>
  </div>
  
  <div class="premium-card p-6 border-l-4 border-[var(--c-accent)]">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      
      <!-- Member Management Roles -->
      <div class="space-y-5">
        
        <div>
          <label class="field-label">Noobies Role</label>
          <select id="noobies_role_id" class="field-input role-select"></select>
          <p class="field-hint">Assigned to new members until they reach the message threshold.</p>
        </div>

        <div>
          <label class="field-label">Returning Member Role</label>
          <select id="newuser_been_in_server_before_role_id" class="field-input role-select"></select>
          <p class="field-hint">Applied to members who rejoin the server.</p>
        </div>

        <div>
          <label class="field-label">Noobies Message Threshold</label>
          <input type="number" id="noobies_threshold" min="1" max="5000" class="field-input" />
          <p class="field-hint">Number of messages needed to lose the Noobies role (default: 100).</p>
        </div>
      </div>

      <!-- Command & Assistant Roles -->
      <div class="space-y-5">
        
        <div>
          <label class="field-label">Fren Role</label>
          <select id="give_perms_fren_role_id" class="field-input role-select"></select>
          <p class="field-hint">Added alongside custom roles when using /giveperms.</p>
        </div>

        <div>
          <label class="field-label">Position Above Role</label>
          <select id="give_perms_position_above_role_id" class="field-input role-select"></select>
          <p class="field-hint">Determines the hierarchy position of new custom roles.</p>
        </div>
      </div>

      <!-- Validation Roles -->
      <div class="sm:col-span-2 space-y-5">
        
        <div class="max-w-md">
          <label class="field-label">Permission Reference Role</label>
          <select id="newuser_permission_diff_role_id" class="field-input role-select"></select>
          <p class="field-hint">Used by /newuser to highlight significant permission differences.</p>
        </div>
      </div>

    </div>

    <div class="mt-8 flex justify-end">
      <button class="save-btn" data-section="roles"
              data-keys="noobies_role_id,noobies_threshold,newuser_been_in_server_before_role_id,give_perms_fren_role_id,give_perms_position_above_role_id,newuser_permission_diff_role_id">
        Save Role Settings
      </button>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════ MODERATION & SAFETY -->
<section id="moderation" class="mb-10 page-section hidden">
  <div class="mb-6">
    <h2 class="section-heading mb-1">
