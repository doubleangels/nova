</style>

<!-- ─── Dashboard JavaScript ─── -->
<script>
  // ── Native <select> helpers (roles / channels) ───────────────────────────
  function populateSelect(el, options, selectedValue) {
    const want = selectedValue ?? '';
    el.replaceChildren();
    for (const opt of options) {
      const o = document.createElement('option');
      o.value = opt.value;
      o.textContent = opt.text;
      el.appendChild(o);
    }
    el.value = want;
    const valid = want === '' || Array.from(el.options).some(o => o.value === want);
    if (!valid) el.value = '';
  }

  // ── Utility ──────────────────────────────────────────────────────────────
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.className = `fixed bottom-5 right-5 z-50 px-5 py-3 rounded-xl text-sm font-medium shadow-lg max-w-xs transition-all duration-300 ${
      type === 'success'
        ? 'bg-[var(--c-accent)] text-white'
        : 'bg-[var(--c-accent)] opacity-60 text-white'
    }`;
    toast.style.opacity = '1';
    setTimeout(() => { toast.className += ' opacity-0'; setTimeout(() => toast.classList.add('hidden'), 300); }, 3000);
  }

  function setButtonState(btn, state) {
    if (state === 'loading') {
      btn.disabled = true;
      btn.dataset.originalText = btn.textContent;
      btn.textContent = 'Saving…';
    } else if (state === 'idle') {
      btn.disabled = false;
      btn.textContent = btn.dataset.originalText || btn.textContent;
    }
  }

  function getFieldValue(id) {
    const el = document.getElementById(id);
    if (!el) return undefined;
    if (el.type === 'checkbox') return el.checked;
    return el.value;
  }

  function setFieldValue(id, value) {
    const el = document.getElementById(id);
    if (!el) return;
    if (el.type === 'checkbox') {
      el.checked = !!value;
    } else {
      el.value = value ?? '';
    }
  }

  // ── Color picker sync ─────────────────────────────────────────────────────
  const colorPicker = document.getElementById('base_embed_color');
  const colorText   = document.getElementById('base_embed_color_text');

  function normalizeHex(hex) {
    const m = /^#?([0-9a-f]{6})$/i.exec(String(hex || '').trim());
    return m ? `#${m[1].toUpperCase()}` : '#7C3AED';
  }
  function hexToRgb(hex) {
    const h = normalizeHex(hex).slice(1);
    return {
      r: parseInt(h.slice(0, 2), 16),
      g: parseInt(h.slice(2, 4), 16),
      b: parseInt(h.slice(4, 6), 16),
    };
  }
  function rgbToHex({ r, g, b }) {
    const clamped = [r, g, b].map(v => Math.max(0, Math.min(255, Math.round(v))));
    return `#${clamped.map(v => v.toString(16).padStart(2, '0')).join('').toUpperCase()}`;
  }
  function mix(hexA, hexB, ratio) {
    const a = hexToRgb(hexA);
    const b = hexToRgb(hexB);
    const t = Math.max(0, Math.min(1, ratio));
    return rgbToHex({
      r: a.r + (b.r - a.r) * t,
      g: a.g + (b.g - a.g) * t,
      b: a.b + (b.b - a.b) * t,
    });
  }
  function applyAccentTheme(baseHex) {
    const base = normalizeHex(baseHex);
    const strong = mix(base, '#FFFFFF', 0.18);
    const text = mix(base, '#FFFFFF', 0.45);
    const rgb = hexToRgb(base);
    const root = document.documentElement;
    root.style.setProperty('--c-accent', base);
    root.style.setProperty('--c-accent-strong', strong);
    root.style.setProperty('--c-accent-text', text);
    root.style.setProperty('--c-accent-soft-bg', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, 0.22)`);
    root.style.setProperty('--c-accent-soft-ring', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, 0.35)`);
    root.style.setProperty('--c-nav-active-bg', `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, 0.22)`);
    root.style.setProperty('--c-nav-active-text', text);
  }

  colorPicker?.addEventListener('input', () => {
    colorText.value = colorPicker.value.toUpperCase();
    applyAccentTheme(colorPicker.value);
    
    // Also sync the message embed color if it hasn't been manually touched
    const msgColorText = document.getElementById('msg_embed_color_text');
    const msgColorPicker = document.getElementById('msg_embed_color');
    if (msgColorText && (!msgColorText.value || msgColorText.value === colorText.placeholder)) {
        msgColorText.value = colorText.value;
        msgColorPicker.value = colorPicker.value;
    }
  });
  colorText?.addEventListener('input', () => {
    const v = colorText.value;
    if (/^#[0-9A-Fa-f]{6}$/.test(v)) {
      colorPicker.value = v;
      applyAccentTheme(v);
    }
  });

  // ── Load guild roles/channels ─────────────────────────────────────────────
  // savedSelectValues: optional map of { id -> value } to restore after repopulating
  async function loadGuildData(savedSelectValues = {}) {
    const [rolesRes, channelsRes] = await Promise.all([
      fetch('/api/guild/roles'),
      fetch('/api/guild/channels'),
    ]);

    const roles    = rolesRes.ok    ? await rolesRes.json()    : [];
    const channels = channelsRes.ok ? await channelsRes.json() : [];

    const noneOpt      = { value: '', text: '— None —' };
    const roleOptions    = [noneOpt, ...roles.map(r => ({ value: r.id, text: r.name }))];
    const channelOptions = [noneOpt, ...channels.map(c => ({ value: c.id, text: `#${c.name}` }))];

    document.querySelectorAll('.role-select').forEach(el => {
      populateSelect(el, roleOptions, savedSelectValues[el.id] ?? '');
    });
    document.querySelectorAll('.channel-select').forEach(el => {
      populateSelect(el, channelOptions, savedSelectValues[el.id] ?? '');
    });
  }

  function captureSelectValues() {
    const map = {};
    document.querySelectorAll('.role-select, .channel-select').forEach(el => {
      if (el.value) map[el.id] = el.value;
    });
    return map;
  }

  // ── Load settings ─────────────────────────────────────────────────────────
  async function loadSettings() {
    const res = await fetch('/api/settings');
    if (!res.ok) { showToast('Failed to load settings.', 'error'); return; }
    const s = await res.json();

    const plainFields = [
      'bot_status', 'bot_status_type', 'guild_name', 'server_invite_url',
      'noobies_threshold', 'inactivity_guard_timeout_hours', 'entry_guard_account_age',
      'anti_spam_threshold', 'anti_spam_window_hours',
    ];
    plainFields.forEach(key => setFieldValue(key, s[key]));

    // Checkboxes
    setFieldValue('inactivity_guard_enabled',  s.inactivity_guard_enabled);
    setFieldValue('entry_guard_enabled', s.entry_guard_enabled);
    setFieldValue('anti_spam_enabled',  s.anti_spam_enabled);

    // Color picker
    const color = s.base_embed_color || '#999999';
    if (colorPicker) colorPicker.value = color;
    if (colorText)   colorText.value   = color.toUpperCase();
    applyAccentTheme(color);

    // Build the saved-values map from settings, then populate selects
    const selectIds = [
      'give_perms_fren_role_id', 'give_perms_position_above_role_id',
      'noobies_role_id', 'newuser_been_in_server_before_role_id', 'newuser_permission_diff_role_id',
      'anti_spam_channel_id', 'reminder_channel', 'reminder_role', 'notext_channel',
      'invite_notification_channel', 'msg_channel_id'
    ];
    const savedMap = {};
    selectIds.forEach(id => {
      const v = s[id];
      if (v !== undefined && v !== null && v !== '') savedMap[id] = v;
    });
    await loadGuildData(savedMap);
  }

  // ── Refresh button ────────────────────────────────────────────────────────
  const refreshBtn  = document.getElementById('refreshBtn');
  const refreshIcon = document.getElementById('refreshIcon');

  refreshBtn?.addEventListener('click', async () => {
    refreshBtn.disabled = true;
    refreshIcon.style.transition = 'transform 0.6s ease';
    refreshIcon.style.transform  = 'rotate(360deg)';

    try {
      // Parallel fetch all data points for maximum efficiency
      await Promise.all([
        loadSettings(),           // Refreshes settings, roles, and channels
        loadHealthStats(),        // Refreshes metrics (Latency, Uptime, Memory)
        refreshLiveReminders(),   // Refreshes bump/promo timers
        loadInvites(),            // Refreshes invite list
        loadDatabaseEntries(),    // Refreshes raw database rows
        loadAutoReactions()       // Refreshes keyword auto-reactions
      ]);
      showToast('Dashboard synchronized with live data.', 'success');
    } catch (err) {
      console.error('Refresh failed:', err);
      showToast('Failed to sync all data points.', 'error');
    } finally {
      refreshBtn.disabled = false;
      // Reset rotation so the animation can replay next click
      setTimeout(() => {
        refreshIcon.style.transition = 'none';
        refreshIcon.style.transform  = 'rotate(0deg)';
      }, 650);
    }
  });

  // ── Save section ──────────────────────────────────────────────────────────
  async function saveSection(btn) {
    const keys = btn.dataset.keys.split(',');
    const payload = {};

    keys.forEach(key => {
      const val = getFieldValue(key);
      if (val !== undefined) {
        // Use the color text box value (hex string) for embed color
        if (key === 'base_embed_color') {
          payload[key] = colorText?.value || colorPicker?.value || '#999999';
        } else {
          payload[key] = val;
        }
      }
    });

    setButtonState(btn, 'loading');
    try {
      const res = await fetch('/api/settings', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        showToast('Settings saved!', 'success');
      } else {
        showToast(data.error || 'Failed to save.', 'error');
      }
    } catch (err) {
      showToast('Network error. Please try again.', 'error');
    } finally {
      setButtonState(btn, 'idle');
    }
  }

  // ── Messaging Center ──────────────────────────────────────────────────────
  const msgModeText   = document.getElementById('msg_mode_text');
  const msgModeEmbed  = document.getElementById('msg_mode_embed');
  const editorText    = document.getElementById('editor_text');
  const editorEmbed   = document.getElementById('editor_embed');
  const embedColorWrap = document.getElementById('embed_color_wrap');
  let isEmbedMode = false;

  msgModeText?.addEventListener('click', () => {
    isEmbedMode = false;
    editorText.classList.remove('hidden');
    editorEmbed.classList.add('hidden');
    embedColorWrap.classList.add('hidden');
    msgModeText.className = "flex-1 px-3 py-1.5 rounded-md text-xs font-semibold transition-all bg-[var(--c-accent)] text-white";
    msgModeEmbed.className = "flex-1 px-3 py-1.5 rounded-md text-xs font-semibold transition-all text-[var(--c-text-dim)] hover:text-[var(--c-label)]";
  });

  msgModeEmbed?.addEventListener('click', () => {
    isEmbedMode = true;
    editorText.classList.add('hidden');
    editorEmbed.classList.remove('hidden');
    embedColorWrap.classList.remove('hidden');
    msgModeEmbed.className = "flex-1 px-3 py-1.5 rounded-md text-xs font-semibold transition-all bg-[var(--c-accent)] text-white";
    msgModeText.className = "flex-1 px-3 py-1.5 rounded-md text-xs font-semibold transition-all text-[var(--c-text-dim)] hover:text-[var(--c-label)]";
    
    // Init color if empty
    const colorText = document.getElementById('msg_embed_color_text');
    const colorPicker = document.getElementById('msg_embed_color');
    if (!colorText.value) {
        const baseColor = document.getElementById('base_embed_color_text')?.value || '#999999';
        colorText.value = baseColor;
        colorPicker.value = baseColor;
    }
  });

  // Message color picker sync
  const msgColorPicker = document.getElementById('msg_embed_color');
  const msgColorText   = document.getElementById('msg_embed_color_text');
  msgColorPicker?.addEventListener('input', () => { msgColorText.value = msgColorPicker.value.toUpperCase(); });
  msgColorText?.addEventListener('input', () => {
    if (/^#[0-9A-Fa-f]{6}$/.test(msgColorText.value)) msgColorPicker.value = msgColorText.value;
  });

  const sendMessageBtn = document.getElementById('sendMessageBtn');
  sendMessageBtn?.addEventListener('click', async () => {
    const channelId = document.getElementById('msg_channel_id').value;
    if (!channelId) return showToast('Please select a target channel.', 'error');

    const payload = {
      channelId,
      isEmbed: isEmbedMode,
      content: document.getElementById('msg_content').value,
      embedData: isEmbedMode ? {
        title: document.getElementById('msg_embed_title').value,
        description: document.getElementById('msg_embed_description').value,
        color: msgColorText.value,
        thumbnail: document.getElementById('msg_embed_thumbnail').value,
        footer: document.getElementById('msg_embed_footer').value
      } : null
    };

    if (isEmbedMode && !payload.embedData.description && !payload.embedData.title) {
        return showToast('Embed must have at least a title or description.', 'error');
    }

    setButtonState(sendMessageBtn, 'loading');
    try {
      const res = await fetch('/api/messages/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (res.ok) {
        showToast('Message sent successfully!');
        if (!isEmbedMode) document.getElementById('msg_content').value = '';
      } else {
        const d = await res.json();
        showToast(d.error || 'Failed to send.', 'error');
      }
    } catch {
      showToast('Network error.', 'error');
    } finally {
      setButtonState(sendMessageBtn, 'idle');
    }
  });

  // ── Health Monitor ────────────────────────────────────────────────────────
  async function loadHealthStats() {
    try {
      const res = await fetch('/api/health');
      if (!res.ok) throw new Error();
      const data = await res.json();
      
      document.getElementById('health_ping').textContent = `${data.ping} ms`;
      document.getElementById('health_uptime').textContent = data.uptime;
      document.getElementById('health_mem').textContent = `${data.memory.rss} MB`;
      document.getElementById('health_mem_sub').textContent = `System: ${data.memory.systemFree}GB / ${data.memory.systemTotal}GB Free`;
      document.getElementById('health_platform').textContent = data.platform;
      document.getElementById('health_node').textContent = `Node ${data.nodeVersion}`;
      
      // Update ping color based on latency
      const pingEl = document.getElementById('health_ping');
      if (data.ping < 100) pingEl.className = 'text-2xl font-bold text-[var(--c-accent)]';
      else if (data.ping < 300) pingEl.className = 'text-2xl font-bold text-[var(--c-accent)] opacity-80';
      else pingEl.className = 'text-2xl font-bold text-[var(--c-accent)] opacity-60';
      
    } catch {
      console.warn('Failed to fetch health stats.');
    }
  }

  // ── Invite Manager ────────────────────────────────────────────────────────
  let allInvites = [];

  async function loadInvites() {
    try {
      const res = await fetch('/api/invites');
      if (!res.ok) throw new Error();
      allInvites = await res.json();
      renderInvites();
    } catch {
      showToast('Failed to load invites.', 'error');
    }
  }

  function renderInvites() {
    const tbody = document.getElementById('inviteTableBody');
    
    tbody.innerHTML = allInvites.map(inv => {
        const expires = inv.expiresAt ? new Date(inv.expiresAt).toLocaleString() : 'Never';
        const isExpiringSoon = inv.expiresAt && (new Date(inv.expiresAt) - new Date() < 3600000); // 1hr
        
        return `
            <tr class="hover:bg-[var(--c-input)]/50 transition-colors">
                <td class="px-5 py-4">
                    <div class="flex items-center gap-2">
