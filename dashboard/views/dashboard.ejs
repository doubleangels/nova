  async function scanInactivityKickTargets() {
      const days = document.getElementById('inactivityDays').value;
      const excludedRole = document.getElementById('prune_protected_role_id')?.value || '';
      const btn = document.getElementById('inactivityScanBtn');
      const prevLabel = btn.textContent;
      const dangerClasses = ['bg-red-500', 'border-red-600', 'text-white', 'shadow-[0_0_15px_rgba(239,68,68,0.25)]', 'hover:bg-red-600', 'hover:border-red-700'];
      const neutralClasses = ['bg-[var(--c-input)]', 'border-[var(--c-input-border)]', 'text-[var(--c-label)]', 'shadow-none', 'hover:bg-[var(--c-card-border)]', 'hover:border-[var(--c-input-border)]'];
      btn.disabled = true;
      btn.textContent = 'Scanning…';

      try {
          const res = await fetch(`/api/users/inactivity/dry-run?days=${encodeURIComponent(days)}&excludedRole=${encodeURIComponent(excludedRole)}`);
          const data = await res.json().catch(() => ({}));
          
          if (!res.ok) throw new Error(data.error || `Scan failed (${res.status}).`);

          const container = document.getElementById('inactivityResultsContainer');
          const countSpan = document.getElementById('inactivityTargetCount');
          const tbody = document.getElementById('inactivityResultsBody');
          const execBtn = document.getElementById('inactivityExecuteBtn');

          container.classList.remove('hidden');
          countSpan.textContent = `${data.targetCount} Targets`;
          execBtn.textContent = `Execute Inactivity Prune (${data.targetCount} users)`;

          if (data.targetCount > 0) {
              execBtn.classList.remove('hidden');
              execBtn.disabled = false;
              execBtn.classList.remove('opacity-50', 'cursor-not-allowed');
              tbody.innerHTML = data.targets.map(t => `
                  <tr class="um-row-hover transition-colors">
                      <td class="px-4 py-2 font-medium text-[var(--c-text)]">${escapeHtml(t.displayName)} <span class="text-[10px] text-[var(--c-text-dim)]">@${escapeHtml(t.username)}</span></td>
                      <td class="px-4 py-2 text-right text-red-400 opacity-80">${escapeHtml(t.reason)}</td>
                  </tr>
              `).join('');
          } else {
              execBtn.classList.add('hidden', 'opacity-50', 'cursor-not-allowed');
              execBtn.disabled = true;
              tbody.innerHTML = `<tr><td colspan="2" class="px-4 py-4 text-center text-[var(--c-text-dim)]">No inactive users found matching this criteria.</td></tr>`;
          }
          // After first scan, shift to neutral "Re-Scan" state.
          btn.classList.remove(...dangerClasses);
          btn.classList.add(...neutralClasses);
          btn.textContent = 'Re-Scan Users';
      } catch (err) {
          showToast(err.message || 'Failed to scan for Inactivity Prune targets.', 'error');
      } finally {
          btn.disabled = false;
          if (btn.textContent === 'Scanning…') {
            btn.textContent = prevLabel;
          }
      }
  }

  async function executeInactivityKicks() {
      const ok = await confirmWithModal({
        title: 'Execute Inactivity Prune',
        message: 'This will permanently kick the listed users from the server. This action cannot be undone.',
        confirmLabel: 'Execute'
      });
      if (!ok) return;
      
      const days = document.getElementById('inactivityDays').value;
      const excludedRole = document.getElementById('prune_protected_role_id')?.value || '';
      const btn = document.getElementById('inactivityExecuteBtn');
      const scanBtn = document.getElementById('inactivityScanBtn');
      const prevExecLabel = btn.textContent;

      btn.disabled = true;
      btn.textContent = 'Executing Inactivity Prune...';
      scanBtn.disabled = true;

      try {
          const res = await fetch('/api/users/inactivity/execute', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ days, excludedRole })
          });
          const data = await res.json().catch(() => ({}));
          
          if (!res.ok) throw new Error(data.error || `Execute failed (${res.status}).`);
          
          showToast(`Successfully kicked ${data.kicked} users. ${data.failed > 0 ? `(${data.failed} failed)` : ''}`, 'success');
          
          document.getElementById('inactivityResultsContainer').classList.add('hidden');
          btn.classList.add('hidden');
          loadUserSummary(true);
      } catch (err) {
          showToast(err.message || 'Failed to execute Inactivity Prune.', 'error');
      } finally {
          btn.disabled = false;
          scanBtn.disabled = false;
          if (btn.textContent === 'Executing Inactivity Prune...') {
            btn.textContent = prevExecLabel;
          }
      }
  }

  function getCategory(key) {
      const parts = key.split(':');
      return parts.length > 1 ? parts[0] : 'general';
  }

  function renderDbExplorer() {
    const nsList  = document.getElementById('dbNamespaceList');
    const content = document.getElementById('dbContentArea');
    const search  = document.getElementById('dbSearch').value.toLowerCase();
    
    // 1. Group Data
    const namespaces = [...new Set(allDbEntries.map(e => e.namespace))].sort();
    const nsCounts = {};
    allDbEntries.forEach(e => nsCounts[e.namespace] = (nsCounts[e.namespace] || 0) + 1);

    // 2. Render Namespace Sidebar (delegated click on #dbNamespaceList — no inline handlers)
    nsList.innerHTML =
      namespaces
        .map((ns) => {
          const isSel = curNamespace === ns;
          const badgeClass = isSel
            ? 'inline-flex min-w-[2rem] justify-center items-center text-[11px] font-bold tabular-nums px-2 py-0.5 rounded-full shrink-0 bg-[var(--c-accent)] text-white shadow-sm'
            : 'inline-flex min-w-[2rem] justify-center items-center text-[11px] font-bold tabular-nums px-2 py-0.5 rounded-full shrink-0 text-[var(--c-label)] bg-[var(--c-input)] border border-[var(--c-accent-soft-ring)]';
          const rowClass = isSel
            ? 'bg-[var(--c-accent-soft-bg)] text-[var(--c-accent-text)] font-semibold'
            : 'text-[var(--c-text-dim)] hover:bg-[var(--c-nav-hover-bg)] hover:text-[var(--c-label)] border border-transparent hover:border-[var(--c-accent-soft-ring)]';
          return `
        <button type="button" data-db-namespace="${escapeHtml(ns)}" aria-pressed="${isSel ? 'true' : 'false'}" class="db-ns-btn cursor-pointer flex w-full lg:w-full min-w-[7.5rem] shrink-0 snap-start items-center justify-between gap-2 px-3 py-2.5 rounded-lg text-sm text-left transition-colors outline-none focus:outline-none ${rowClass}">
            <span class="truncate">${escapeHtml(ns)}</span>
            <span class="${badgeClass}">${nsCounts[ns]}</span>
        </button>`;
        })
        .join('') ||
      '<div class="p-4 text-center text-xs text-[var(--c-text-dim)] w-full min-w-[200px] flex-shrink-0">No namespaces found</div>';

    // 3. Filter and Group by Category for current namespace
    const filtered = allDbEntries.filter(e => {
        if (e.namespace !== curNamespace) return false;
        if (!search) return true;
        return e.key.toLowerCase().includes(search) || valueToSearchText(e.value).toLowerCase().includes(search);
    });

    const groups = {};
    filtered.forEach(e => {
        const cat = getCategory(e.key);
        if (!groups[cat]) groups[cat] = [];
        groups[cat].push(e);
    });

    // 4. Render Content
    const sortedCats = Object.keys(groups).sort((a,b) => {
        if (a === 'config') return -1;
        if (b === 'config') return 1;
        if (a === 'general') return 1;
        return a.localeCompare(b);
    });

    if (sortedCats.length === 0) {
        content.innerHTML = `<div class="card p-12 text-center text-[var(--c-text-dim)] bg-transparent border border-dashed border-[var(--c-accent-soft-ring)]">No entries found in "${escapeHtml(curNamespace)}" match your search.</div>`;
        return;
    }

    content.innerHTML = sortedCats.map(cat => {
        const isOpen = expandedCats.has(cat);
        const items = groups[cat];
        
        return `
            <div class="card p-0 overflow-hidden">
                <button type="button" class="no-auto-icon w-full flex items-center justify-between px-5 py-3 hover:bg-[var(--c-input)] transition-colors text-left border-b border-transparent data-[open=true]:border-[var(--c-accent-soft-ring)]" data-open="${isOpen}" data-db-category="${escapeHtml(cat)}">
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--c-accent)] transition-transform ${isOpen ? 'rotate-90' : ''}" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        <span class="text-xs font-bold uppercase tracking-wider text-[var(--c-label)]">${escapeHtml(cat)}</span>
                        <span class="text-[10px] text-[var(--c-text-dim)] font-normal">(${items.length} items)</span>
                    </div>
                </button>
                
                <div class="${isOpen ? '' : 'hidden'}">
                    <div class="divide-y divide-[var(--c-card-border)]">
                            ${items.map(e => {
                                const cleanKey = e.key.includes(':') ? e.key.split(':').slice(1).join(':') : e.key;
                                const statusId = `status-${e.fullKey.replace(/:/g, '-')}`;
                                return `
                                    <div class="px-3 sm:px-5 py-3 sm:py-3.5 hover:bg-[var(--c-input)]/40 transition-colors group">
                                        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,14rem)_minmax(0,1fr)] gap-3 lg:gap-4 items-stretch lg:items-start">
                                            <div class="min-w-0 lg:pl-4">
                                                <div class="text-sm font-medium text-[var(--c-label)] break-words">${escapeHtml(cleanKey)}</div>
                                                <div class="text-[10px] text-[var(--c-text-dim)] font-mono mt-0.5 break-all opacity-80 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">full: ${escapeHtml(e.key)}</div>
                                            </div>
                                            <div class="relative flex flex-col sm:flex-row items-stretch sm:items-stretch gap-2 min-w-0 h-full">
                                                <div id="${statusId}" class="hidden sm:block absolute sm:left-0 sm:top-3 w-1.5 h-1.5 rounded-full bg-[var(--c-accent)] opacity-0 transition-opacity duration-300 sm:-translate-x-4" title="Synced"></div>
                                                <div class="flex-1 min-w-0 sm:pl-1 h-full">
                                                    <textarea 
                                                        class="db-explorer-value w-full h-full min-h-[44px] bg-[var(--c-input)] border border-[var(--c-input-border)] rounded-md px-2 py-2 text-xs font-mono text-[var(--c-text-muted)] focus:border-[var(--c-accent)] focus:ring-1 focus:ring-[var(--c-accent-soft-ring)] outline-none transition-all resize-none overflow-hidden" 
                                                        rows="1"
                                                        data-db-full-key="${escapeHtml(e.fullKey)}"
                                                    >${escapeHtml(displayDbValue(e.value))}</textarea>
                                                </div>
                                                <button type="button" data-db-full-key="${escapeHtml(e.fullKey)}" class="p-2.5 min-h-[44px] min-w-[44px] sm:min-w-0 sm:min-h-0 sm:p-2 self-end sm:self-start text-[var(--c-text-dim)] hover:text-[var(--c-accent)] hover:bg-[var(--c-input)] rounded-lg transition-all sm:opacity-0 sm:group-hover:opacity-100 shrink-0" title="Delete entry">
                                                    <svg class="w-4 h-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                `;
                            }).join('')}
                    </div>
                </div>
            </div>
        `;
    }).join('');

    content.querySelectorAll('[data-db-category]').forEach((btn) => {
        btn.addEventListener('click', () => {
            const cat = btn.dataset.dbCategory;
            if (!cat) return;
            toggleCategory(cat);
        });
    });

    content.querySelectorAll('#dbContentArea textarea.db-explorer-value[data-db-full-key]').forEach((ta) => {
      const fk = ta.getAttribute('data-db-full-key');
      if (!fk) return;
      ta.addEventListener('input', function onDbExplorerInput() {
        window.autoResize(this);
        window.scheduleSave(fk, this.value);
      });
      ta.addEventListener('focus', function onDbExplorerFocus() {
        window.autoResize(this);
      });
    });
    content.querySelectorAll('#dbContentArea button[data-db-full-key]').forEach((btn) => {
      btn.addEventListener('click', (ev) => {
        ev.stopPropagation();
        const fk = btn.getAttribute('data-db-full-key');
        if (fk) window.deleteDbEntry(fk);
      });
    });

    // Trigger initial resize for visible textareas
    setTimeout(() => {
        document.querySelectorAll('#dbContentArea textarea').forEach(autoResize);
    }, 10);
    ensureNonChipButtonsHaveIcons();
  }

  window.toggleCategory = (cat) => { 
    if (expandedCats.has(cat)) expandedCats.delete(cat); 
    else expandedCats.add(cat); 
    renderDbExplorer(); 
    // Trigger resize after re-rendering
    setTimeout(() => {
        document.querySelectorAll('#dbContentArea textarea').forEach(autoResize);
    }, 50);
  };
  window.expandAllCategories = () => { 
    [...new Set(allDbEntries.filter(e => e.namespace === curNamespace).map(e => getCategory(e.key)))].forEach(c => expandedCats.add(c)); 
    renderDbExplorer(); 
    setTimeout(() => {
        document.querySelectorAll('#dbContentArea textarea').forEach(autoResize);
    }, 50);
  };
  window.collapseAllCategories = () => { expandedCats.clear(); renderDbExplorer(); };

  window.autoResize = (el) => {
    el.style.height = 'auto';
    el.style.height = (el.scrollHeight) + 'px';
  };

  function dbRawDeleteUrl(fullKey, dryRun) {
    const p = new URLSearchParams();
    p.set('fullKey', fullKey);
    if (dryRun) p.set('dryRun', 'true');
    return `/api/database/raw?${p.toString()}`;
  }

  window.deleteDbEntry = async (fullKey) => {
    let previewText = '';
    try {
      const p = await fetch(dbRawDeleteUrl(fullKey, true), { method: 'DELETE' });
      const d = await p.json().catch(() => ({}));
      if (p.ok) previewText = `\nPreview action: ${d.action || 'delete_raw_key'}.`;
    } catch (_) {}
    const ok = await confirmWithModal({
      title: 'Delete Database Entry',
      message: `Delete "${fullKey}"? This action is irreversible.${previewText}`,
      confirmLabel: 'Delete'
    });
    if (!ok) return;
    
    try {
        const res = await fetch(dbRawDeleteUrl(fullKey, false), { method: 'DELETE' });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
            showToast('Entry deleted successfully.');
            allDbEntries = allDbEntries.filter(e => e.fullKey !== fullKey);
            renderDbExplorer();
        } else {
            showToast(data.error || 'Failed to delete entry.', 'error');
        }
    } catch {
        showToast('Network error while deleting.', 'error');
    }
  };

  window.scheduleSave = (fullKey, valueStr) => {
    const statusId = `status-${fullKey.replace(/:/g, '-')}`;
    const statusEl = document.getElementById(statusId);
    
    // Show "dirty" state
    if (statusEl) {
        statusEl.classList.remove('bg-[var(--c-accent)]', 'opacity-0');
        statusEl.classList.add('bg-[var(--c-accent)]', 'opacity-80', 'animate-pulse');
    }

    if (autoSaveTimers.has(fullKey)) clearTimeout(autoSaveTimers.get(fullKey));

    autoSaveTimers.set(fullKey, setTimeout(async () => {
        let value;
        try {
            value = parseDbValue(valueStr);
        } catch {
            value = valueStr;
        }

        if (statusEl) {
            statusEl.classList.remove('animate-pulse');
            statusEl.classList.add('bg-[var(--c-accent)]'); // Saving state
        }

        try {
            const res = await fetch('/api/database/raw', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ fullKey, value })
            });
            if (res.ok) {
                if (statusEl) {
                    statusEl.classList.remove('bg-[var(--c-accent)]');
                    statusEl.classList.add('bg-[var(--c-accent)]');
                    setTimeout(() => statusEl.classList.add('opacity-0'), 2000);
                }
            } else {
                showToast('Failed to auto-save change.', 'error');
                if (statusEl) {
                    statusEl.classList.add('bg-[var(--c-accent)]');
                }
            }
        } catch {
            if (statusEl) {
                statusEl.classList.add('bg-[var(--c-accent)]');
            }
        }
    }, 1500));
  };

  document.getElementById('dbSearch')?.addEventListener('input', renderDbExplorer);

  // ── Live Reminders System ───────────────────────────────────────────────────
