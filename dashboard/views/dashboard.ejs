          <input type="text" class="field-input py-1.5 text-xs font-mono ar-pattern" value="${safePattern}" placeholder="e.g. dubz" />
        </td>
        <td class="px-2 py-3 text-center align-middle">
          <input type="checkbox" class="ar-use-regex rounded border-[var(--c-input-border)] text-[var(--c-accent)] focus:ring-[var(--c-accent)]" title="Regular expression"${regexChecked} />
        </td>
        <td class="px-4 py-3">
          <input type="text" class="field-input py-1.5 text-xs font-mono ar-emoji" value="${safeEmoji}" placeholder="Unicode emoji or <:name:id>" />
