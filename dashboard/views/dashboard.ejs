<!-- ══════════════════════════════════════════════════════════ INVITE MANAGER -->
<section id="invites" class="mb-10 page-section hidden">
  <div class="flex items-center justify-between mb-4">
    <h2 class="section-heading mb-0">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
      </svg>
      Invite Manager
    </h2>
    <div class="flex flex-wrap items-center justify-end gap-2">
        <button type="button" onclick="void revokeNonNovaInvites()" class="btn-dash-danger btn-dash-sm" title="Delete every invite not created by this bot (keeps Nova-created links)">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
