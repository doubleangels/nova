<!DOCTYPE html>
<html lang="en" class="h-full">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <title>
    <%= title %> — Nova Dashboard
  </title>
  <% if (botIcon) { %>
    <link rel="icon" type="image/png" href="<%= botIcon %>" />
    <% } %>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
      <!-- Apply saved theme before paint to prevent flash -->
      <script>(function () { var t = localStorage.getItem('dashboard-theme') || 'dark'; document.documentElement.setAttribute('data-theme', t); })()</script>
      <script src="https://cdn.tailwindcss.com"></script>
      <script>
        tailwind.config = {
          theme: {
            extend: {
              fontFamily: {
                sans: ['Inter', 'ui-sans-serif', 'system-ui', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                mono: ['Inter', 'ui-sans-serif', 'system-ui', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
              },
            },
          },
        };
      </script>
      <style>
        /* ── Theme tokens ────────────────────────────────────────────────────── */
        :root {
          /* Bot-Dynamic Accents */
          <% if (typeof accentHex !== 'undefined') { %>
          --c-accent: <%= accentHex %>;
          --c-accent-rgb: <%= accentRgb.r %>, <%= accentRgb.g %>, <%= accentRgb.b %>;
          --c-accent-strong: <%= accentHex %>;
          --c-accent-soft-bg: rgba(var(--c-accent-rgb), 0.12);
          --c-accent-soft-ring: rgba(var(--c-accent-rgb), 0.25);
          --c-accent-text: <%= accentHex %>;
          <% } else { %>
          --c-accent: #7c3aed;
          --c-accent-rgb: 124, 58, 237;
          --c-accent-strong: #8b5cf6;
          --c-accent-soft-bg: rgba(124, 58, 237, 0.12);
          --c-accent-soft-ring: rgba(124, 58, 237, 0.25);
          --c-accent-text: #c4b5fd;
          <% } %>

          /* Surfaces: cool-neutral dark — clearer steps between bg / chrome / cards */
          --c-bg: #070708;
          --c-sidebar: #0b0b0e;
          --c-sidebar-border: #1a1a22;
          --c-topbar: #0b0b0e;
          --c-topbar-border: #1a1a22;
          --c-text: #f4f4f5;
          --c-text-muted: #a1a1ad;
          --c-text-dim: #6e6e7a;
          --c-nav-text: #d4d4dc;
          --c-nav-hover-bg: #15151b;
          --c-nav-hover-text: #ffffff;
          --c-nav-active-bg: rgba(var(--c-accent-rgb), 0.22);
          --c-nav-active-text: #ffffff;
          --c-card: #111117;
          --c-card-border: #27272f;
          --c-input: #16161d;
          --c-input-border: #32323c;
          --c-input-text: #fafafa;
          --c-input-ph: #5b5b66;
          --c-label: #d8d8e0;
          --c-hint: #6f6f7a;
          --c-toggle-off: #3a3a44;

          --c-overlay-scrim: rgba(2, 4, 10, 0.62);
          --c-card-hover-shadow: rgba(0, 0, 0, 0.55);
          --c-blob-secondary: #3555ff;
          --c-ring-on-canvas: rgba(255, 255, 255, 0.1);
          --c-sidebar-veil: rgba(255, 255, 255, 0.03);
          --c-row-hover: rgba(255, 255, 255, 0.04);
          --c-subtle-divide: rgba(255, 255, 255, 0.06);

          --glass-bg: rgba(12, 12, 16, 0.82);
          --glass-border: rgba(255, 255, 255, 0.06);
          --glass-blur: 14px;

          /* btn-dash-*: same surfaces as --c-card / --c-input in dark */
          --c-dash-btn-secondary-bg: var(--c-card);
          --c-dash-btn-secondary-hover: var(--c-accent-soft-bg);
          --c-dash-btn-neutral-bg: var(--c-card);
          --c-dash-btn-neutral-text: var(--c-label);
          --c-dash-btn-neutral-border: var(--c-input-border);
          --c-dash-btn-neutral-hover-bg: var(--c-input);
        }

        html[data-theme="light"] {
          --c-bg: #ebeef4;
          --c-sidebar: #fafbfc;
          --c-sidebar-border: #dde2eb;
          --c-topbar: #fafbfc;
          --c-topbar-border: #dde2eb;
          --c-text: #0c1220;
          --c-text-muted: #3d4a5f;
          --c-text-dim: #5a677a;
          --c-nav-text: #2a3648;
          --c-nav-hover-bg: #e8ecf3;
          --c-nav-hover-text: #0c1220;
          --c-nav-active-bg: rgba(var(--c-accent-rgb), 0.11);
          --c-nav-active-text: var(--c-accent);
          --c-card: #ffffff;
          --c-card-border: #dfe3ec;
          --c-input: #f4f6f9;
          --c-input-border: #c3cad6;
          --c-input-text: #0c1220;
          --c-input-ph: #6b7788;
          --c-label: #273143;
          --c-hint: #5a677a;
          --c-toggle-off: #c3cad6;

          /* Dark theme uses --c-accent-text as a *light* tint on dark UI; light needs the real accent. */
          --c-accent-text: var(--c-accent);
          --c-accent-soft-bg: rgba(var(--c-accent-rgb), 0.13);
          --c-accent-soft-ring: rgba(var(--c-accent-rgb), 0.22);

          --c-overlay-scrim: rgba(12, 18, 34, 0.45);
          --c-card-hover-shadow: rgba(15, 23, 42, 0.11);
          --c-blob-secondary: #5b6cff;
          --c-ring-on-canvas: rgba(12, 18, 34, 0.1);
          --c-sidebar-veil: rgba(12, 18, 34, 0.04);
          --c-row-hover: rgba(12, 18, 34, 0.05);
          --c-subtle-divide: rgba(12, 18, 34, 0.08);

          --glass-bg: rgba(255, 255, 255, 0.92);
          --glass-border: rgba(12, 18, 34, 0.08);

          /* Keep dashboard action buttons identical to dark theme (solid fills, borders) */
          --c-dash-btn-secondary-bg: #111117;
          --c-dash-btn-secondary-hover: rgba(var(--c-accent-rgb), 0.12);
          --c-dash-btn-neutral-bg: #111117;
          --c-dash-btn-neutral-text: #d8d8e0;
          --c-dash-btn-neutral-border: #32323c;
          --c-dash-btn-neutral-hover-bg: #16161d;
        }

        /* ── Shell ───────────────────────────────────────────────────────────── */
        html {
          font-family: Inter, ui-sans-serif, system-ui, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
          color-scheme: dark;
          scrollbar-color: var(--c-card-border) var(--c-bg);
          scrollbar-width: thin;
        }

        html[data-theme="light"] {
          color-scheme: light;
        }

        body {
          background-color: var(--c-bg) !important;
          color: var(--c-text);
          font-family: inherit;
        }

        #sidebar,
        #mobileSidebar {
          background-color: var(--c-sidebar) !important;
          border-color: var(--c-sidebar-border) !important;
        }

        #mobileTopbar {
          background-color: var(--c-topbar) !important;
          border-color: var(--c-topbar-border) !important;
        }

        /* ── Sidebar internals ───────────────────────────────────────────────── */
        .sb-header {
          border-color: var(--c-sidebar-border);
        }

        .sb-guild-name {
          color: var(--c-text);
        }

        .sb-sub {
          color: var(--c-text-muted);
        }

        .sb-section-label {
          color: var(--c-text-dim);
        }

        .sb-username {
          color: var(--c-text-muted);
        }

        .sb-footer {
          border-color: var(--c-sidebar-border);
        }

        .sidebar-link {
          color: var(--c-nav-text);
        }

        .sidebar-link:hover {
          background-color: var(--c-nav-hover-bg) !important;
          color: var(--c-nav-hover-text) !important;
        }

        .sidebar-link.active {
          background-color: var(--c-nav-active-bg) !important;
          color: var(--c-nav-active-text) !important;
        }

        .sb-sublink {
          display: block;
          font-size: 11px;
          font-weight: 600;
          line-height: 1.25;
          padding: 0.35rem 0.5rem 0.35rem 0.25rem;
          margin-left: 0.125rem;
          border-radius: 0.375rem;
          color: var(--c-text-dim);
          text-decoration: none;
          transition: color 0.15s ease, background-color 0.15s ease;
        }

        .sb-sublink:hover {
          color: var(--c-nav-hover-text);
          background-color: var(--c-nav-hover-bg);
        }

        .sb-sublink.active {
          color: var(--c-nav-active-text);
          background-color: var(--c-nav-active-bg);
        }

        .brand-accent {
          color: var(--c-accent-strong) !important;
        }

        /* ── Unified Components ────────────────────────────────────────────── */
        .premium-card {
          background: var(--c-card);
          border: 1px solid var(--c-accent-soft-ring);
          border-radius: 1.25rem;
          transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.2s ease;
        }

        .premium-card:hover {
          box-shadow: 0 18px 50px -18px var(--c-card-hover-shadow);
        }

        .glass-panel {
          background: var(--glass-bg);
          backdrop-filter: blur(var(--glass-blur));
          border: 1px solid var(--glass-border);
          border-radius: 1.25rem;
        }

        .icon-box {
          width: 2.5rem;
          height: 2.5rem;
          border-radius: 0.75rem;
          display: flex;
          align-items: center;
          justify-content: center;
          transition: all 0.2s ease;
        }

        .icon-box-sm {
          width: 2rem;
          height: 2rem;
          border-radius: 0.625rem;
        }

        /* Ambient background blobs (like Login) */
        .ambient-blob {
          position: fixed;
          border-radius: 9999px;
          filter: blur(80px);
          pointer-events: none;
          z-index: -1;
          opacity: 0.15;
        }

        html[data-theme="light"] .ambient-blob {
          opacity: 0.05;
        }

        .blob-1 { width: 500px; height: 500px; background: var(--c-accent); top: -200px; right: -100px; }
        .blob-2 { width: 400px; height: 400px; background: var(--c-blob-secondary); bottom: -100px; left: -100px; }

        input[type="color"] {
          padding: 2px 4px;
          cursor: pointer;
        }

        /* Modal & Toast Animations */
        @keyframes modal-in { from { opacity: 0; transform: translateY(10px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
        .toast-item { animation: toast-in 0.3s cubic-bezier(0.2, 0, 0, 1); }
        @keyframes toast-in { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
      </style>
</head>

<body class="h-full antialiased overflow-x-hidden font-sans">

  <!-- Ambient background -->
  <div class="ambient-blob blob-1"></div>
  <div class="ambient-blob blob-2"></div>

  <!-- Global UI Helpers (Defined early so body scripts can use them) -->
  <script>
    window.showToast = (message, type = 'success') => {
      const container = document.getElementById('toastContainer');
      if (!container) return;
      const toast = document.createElement('div');
      const isError = type === 'error';
      const colorCls = isError ? 'bg-red-500 shadow-red-500/10' : 'bg-[var(--c-accent)] shadow-purple-500/10';
      toast.className = `toast-item pointer-events-auto px-5 py-3 rounded-xl text-sm font-medium shadow-2xl text-white ${colorCls} min-w-[240px] flex items-center justify-between gap-4 border border-white/10`;
      toast.innerHTML = `<span>${message}</span><button onclick="this.parentElement.remove()" class="opacity-50 hover:opacity-100 transition-opacity"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg></button>`;
      container.appendChild(toast);
      setTimeout(() => {
        if (toast.parentElement) {
          toast.classList.add('opacity-0', 'translate-x-10', 'transition-all', 'duration-500');
          setTimeout(() => toast.remove(), 500);
        }
      }, 5000);
    };

    window.confirmWithModal = ({ title, message, confirmLabel = 'Confirm', cancelLabel = 'Cancel' }) => {
      return new Promise((resolve) => {
        const modal = document.getElementById('modalContainer');
        const titleEl = document.getElementById('modalTitle');
        const msgEl = document.getElementById('modalMessage');
        const confirmBtn = document.getElementById('modalConfirm');
        const cancelBtn = document.getElementById('modalCancel');

        if (!modal || !titleEl || !msgEl || !confirmBtn || !cancelBtn) {
          console.warn('Modal components missing, falling back to window.confirm');
          resolve(window.confirm(message));
          return;
        }

        titleEl.textContent = title;
        msgEl.textContent = message;
        confirmBtn.textContent = confirmLabel;
        cancelBtn.textContent = cancelLabel;

        const cleanup = (res) => {
          modal.classList.add('hidden');
          confirmBtn.onclick = null;
          cancelBtn.onclick = null;
          resolve(res);
        };

        confirmBtn.onclick = () => cleanup(true);
        cancelBtn.onclick = () => cleanup(false);
        modal.onclick = (e) => { if (e.target === modal) cleanup(false); };
        modal.classList.remove('hidden');
      });
    };
  </script>

  <!-- Mobile top bar -->
  <div id="mobileTopbar" class="lg:hidden flex items-center gap-3 px-4 py-3 border-b sticky top-0 z-40 bg-[var(--c-topbar)]">
    <button id="menuToggle" class="p-2 rounded-md shrink-0" style="color:var(--c-text-muted)">
      <svg id="menuOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menuClose" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="flex items-center gap-3 min-w-0">
      <% if (typeof guildIcon !== 'undefined' && guildIcon) { %>
        <img src="<%= guildIcon %>" class="w-8 h-8 rounded-lg ring-1 ring-[var(--c-ring-on-canvas)]" alt="Server icon" />
      <% } else { %>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-xs" style="background:var(--c-accent)">N</div>
      <% } %>
      <div class="min-w-0">
        <p class="sb-guild-name font-bold leading-tight text-sm truncate uppercase tracking-wide">
          <%= typeof guildName !== 'undefined' ? guildName : 'Da Frens' %>
        </p>
      </div>
    </div>
  </div>

  <div class="flex h-full min-h-screen">
    <!-- Desktop sidebar -->
    <aside id="sidebar" class="hidden lg:flex flex-col w-64 border-r fixed top-0 left-0 h-full z-30 overflow-y-auto">
      <%- include('partials/sidebar') %>
    </aside>

    <!-- Mobile overlay + sidebar -->
    <div id="mobileOverlay" class="hidden fixed inset-0 z-20 lg:hidden w-full h-full bg-[var(--c-overlay-scrim)] backdrop-blur-[2px]"></div>
    <aside id="mobileSidebar" class="hidden flex-col fixed top-0 left-0 h-full w-64 border-r z-30 overflow-y-auto pt-[56px] pb-6 lg:hidden">
      <%- include('partials/sidebar') %>
    </aside>

    <!-- Main content -->
    <main class="flex-1 lg:ml-64 overflow-y-auto">
      <div class="max-w-4xl mx-auto px-4 py-8">
        <%- body %>
      </div>
    </main>
  </div>

  <!-- Global UI Components -->
  <div id="toastContainer" class="fixed bottom-5 right-5 z-[100] flex flex-col gap-3 pointer-events-none"></div>

  <div id="modalContainer" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-[var(--c-overlay-scrim)] backdrop-blur-sm">
    <div class="glass-panel w-full max-w-md p-6 space-y-6 shadow-2xl animate-[modal-in_0.2s_ease-out]">
      <div class="space-y-2">
        <h3 id="modalTitle" class="text-lg font-bold text-[var(--c-text)]">Confirm Action</h3>
        <p id="modalMessage" class="text-sm text-[var(--c-text-dim)] leading-relaxed"></p>
      </div>
      <div class="flex justify-end gap-3">
        <button id="modalCancel" class="px-4 py-2 rounded-lg text-sm font-bold text-[var(--c-text-muted)] hover:bg-[var(--c-nav-hover-bg)] transition-colors">Cancel</button>
        <button id="modalConfirm" class="px-4 py-2 rounded-lg text-sm font-bold bg-[var(--c-accent)] hover:bg-[var(--c-accent-strong)] text-white transition-colors">Confirm</button>
      </div>
    </div>
  </div>

  <script>
    // ── CSRF wrapper for mutating fetch calls ──────────────────────────────────
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
    const _nativeFetch = window.fetch.bind(window);
    window.fetch = (input, init = {}) => {
      const req = new Request(input, init);
      const method = String(req.method || 'GET').toUpperCase();
      const isUnsafe = method === 'POST' || method === 'PUT' || method === 'PATCH' || method === 'DELETE';
      const isLocalUrl = (() => {
        try {
          const u = new URL(req.url, window.location.origin);
          return u.origin === window.location.origin;
        } catch {
          return false;
        }
      })();
      if (!isUnsafe || !isLocalUrl || !csrfToken) {
        return _nativeFetch(input, init);
      }
      const headers = new Headers(init.headers || req.headers || {});
      if (!headers.has('x-csrf-token')) headers.set('x-csrf-token', csrfToken);
      return _nativeFetch(input, { ...init, headers });
    };

    // ── Theme ──────────────────────────────────────────────────────────────────
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('dashboard-theme', theme);
      const sun = document.getElementById('themeIconSun');
      const moon = document.getElementById('themeIconMoon');
      if (sun) sun.style.display = theme === 'dark' ? '' : 'none';
      if (moon) moon.style.display = theme === 'light' ? '' : 'none';
      window.dispatchEvent(new CustomEvent('dashboard-theme-changed', { detail: { theme } }));
    }
    // Re-apply after DOM is ready (inline script at top handled the pre-paint case)
    applyTheme(localStorage.getItem('dashboard-theme') || 'dark');

    document.getElementById('themeToggleBtn')?.addEventListener('click', () => {
      const t = document.documentElement.getAttribute('data-theme') || 'dark';
      applyTheme(t === 'dark' ? 'light' : 'dark');
    });

    // ── Mobile menu ────────────────────────────────────────────────────────────
    const menuToggle = document.getElementById('menuToggle');
    const mobileOverlay = document.getElementById('mobileOverlay');
    const mobileSidebar = document.getElementById('mobileSidebar');
    const menuOpenIcon = document.getElementById('menuOpen');
    const menuCloseIcon = document.getElementById('menuClose');

    function openMenu() {
      if (mobileSidebar) { mobileSidebar.classList.remove('hidden'); mobileSidebar.classList.add('flex'); }
      if (mobileOverlay) mobileOverlay.classList.remove('hidden');
      if (menuOpenIcon) menuOpenIcon.classList.add('hidden');
      if (menuCloseIcon) menuCloseIcon.classList.remove('hidden');
    }
    function closeMenu() {
      if (mobileSidebar) { mobileSidebar.classList.add('hidden'); mobileSidebar.classList.remove('flex'); }
      if (mobileOverlay) mobileOverlay.classList.add('hidden');
      if (menuOpenIcon) menuOpenIcon.classList.remove('hidden');
      if (menuCloseIcon) menuCloseIcon.classList.add('hidden');
    }

    menuToggle?.addEventListener('click', () => {
      if (!mobileSidebar) return;
      mobileSidebar.classList.contains('hidden') ? openMenu() : closeMenu();
    });
    mobileOverlay?.addEventListener('click', closeMenu);

    // ── Active nav (primary section + optional subsections; hashes resolved in dashboard.ejs) ──
    function setActiveNav() {
      const hash = window.location.hash || '#status';
      const resolved =
        typeof window.dashboardResolveNavHash === 'function'
          ? window.dashboardResolveNavHash(hash)
          : { sectionHash: hash, scrollToId: null };
      const primaryHash = resolved.sectionHash || hash;

      document.querySelectorAll('.sb-nav-group').forEach((group) => {
        const primary = group.querySelector('a.sidebar-link--primary');
        const subWrap = group.querySelector('.sb-sublinks');
        if (!primary) return;
        const href = primary.getAttribute('href');
        const isActiveSection = href === primaryHash;
        primary.classList.toggle('active', isActiveSection);
        if (subWrap) {
          subWrap.classList.toggle('hidden', !isActiveSection);
          subWrap.querySelectorAll('.sb-sublink').forEach((sub) => {
            sub.classList.toggle('active', sub.getAttribute('href') === hash);
          });
        }
      });

      if (window.innerWidth < 1024 && mobileSidebar && !mobileSidebar.classList.contains('hidden')) {
        closeMenu();
      }
    }
    setActiveNav();
    window.addEventListener('hashchange', setActiveNav);
  </script>

</body>

</html>