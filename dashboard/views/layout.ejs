<!DOCTYPE html>
<html lang="en" class="h-full">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <title>
    <%= title %> — Nova Dashboard
  </title>
  <% if (botIcon) { %>
    <link rel="icon" type="image/png" href="<%= botIcon %>" />
    <% } %>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
      <!-- Apply saved theme before paint to prevent flash -->
      <script>(function () { var t = localStorage.getItem('dashboard-theme') || 'dark'; document.documentElement.setAttribute('data-theme', t); })()</script>
      <script src="https://cdn.tailwindcss.com"></script>
      <script>
        tailwind.config = {
          theme: {
            extend: {
              fontFamily: {
                sans: ['Inter', 'ui-sans-serif', 'system-ui', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                mono: ['Inter', 'ui-sans-serif', 'system-ui', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
              },
            },
          },
        };
      </script>
      <style>
        /* ── Theme tokens ────────────────────────────────────────────────────── */
        :root {
          /* Bot-Dynamic Accents */
          <% if (typeof accentHex !== 'undefined') { %>
          --c-accent: <%= accentHex %>;
          --c-accent-rgb: <%= accentRgb.r %>, <%= accentRgb.g %>, <%= accentRgb.b %>;
          --c-accent-strong: <%= accentHex %>;
          --c-accent-soft-bg: rgba(var(--c-accent-rgb), 0.12);
          --c-accent-soft-ring: rgba(var(--c-accent-rgb), 0.25);
          --c-accent-text: <%= accentHex %>;
          <% } else { %>
          --c-accent: #7c3aed;
          --c-accent-rgb: 124, 58, 237;
          --c-accent-strong: #8b5cf6;
          --c-accent-soft-bg: rgba(124, 58, 237, 0.12);
          --c-accent-soft-ring: rgba(124, 58, 237, 0.25);
          --c-accent-text: #c4b5fd;
          <% } %>

          --c-bg: #050506;
          --c-sidebar: #0d0d10;
          --c-sidebar-border: #1f1f24;
          --c-topbar: #0d0d10;
          --c-topbar-border: #1f1f24;
          --c-text: #f3f4f6;
          --c-text-muted: #a1a1aa;
          --c-text-dim: #71717a;
          --c-nav-text: #d4d4d8;
          --c-nav-hover-bg: #1b1b20;
          --c-nav-hover-text: #ffffff;
          --c-nav-active-bg: rgba(var(--c-accent-rgb), 0.22);
          --c-nav-active-text: #ffffff;
          /* component tokens (consumed by dashboard.ejs) */
          --c-card: #101014;
          --c-card-border: #24242a;
          --c-input: #18181d;
          --c-input-border: #32323a;
          --c-input-text: #ffffff;
          --c-input-ph: #52525b;
          --c-label: #d4d4d8;
          --c-hint: #71717a;
          --c-toggle-off: #3f3f46;
          
          /* Glassmorphism */
          --glass-bg: rgba(16, 16, 20, 0.75);
          --glass-border: rgba(255, 255, 255, 0.05);
          --glass-blur: 12px;
        }

        html[data-theme="light"] {
          --c-bg: #f1f5f9;
          --c-sidebar: #ffffff;
          --c-sidebar-border: #e2e8f0;
          --c-topbar: #ffffff;
          --c-topbar-border: #e2e8f0;
          --c-text: #0f172a;
          --c-text-muted: #475569;
          --c-text-dim: #94a3b8;
          --c-nav-text: #334155;
          --c-nav-hover-bg: #f1f5f9;
          --c-nav-hover-text: #0f172a;
          --c-nav-active-bg: rgba(var(--c-accent-rgb), 0.08);
          --c-nav-active-text: var(--c-accent);
          --c-card: #ffffff;
          --c-card-border: #e2e8f0;
          --c-input: #f8fafc;
          --c-input-border: #cbd5e1;
          --c-input-text: #0f172a;
          --c-input-ph: #94a3b8;
          --c-label: #334155;
          --c-hint: #94a3b8;
          --c-toggle-off: #cbd5e1;
        }

        /* ── Shell ───────────────────────────────────────────────────────────── */
        html {
          font-family: Inter, ui-sans-serif, system-ui, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        body {
          background-color: var(--c-bg) !important;
          color: var(--c-text);
          font-family: inherit;
        }

        #sidebar,
        #mobileSidebar {
          background-color: var(--c-sidebar) !important;
          border-color: var(--c-sidebar-border) !important;
        }

        #mobileTopbar {
          background-color: var(--c-topbar) !important;
          border-color: var(--c-topbar-border) !important;
        }

        /* ── Sidebar internals ───────────────────────────────────────────────── */
        .sb-header {
          border-color: var(--c-sidebar-border);
        }

        .sb-guild-name {
          color: var(--c-text);
        }

        .sb-sub {
          color: var(--c-text-muted);
        }

        .sb-section-label {
          color: var(--c-text-dim);
        }

        .sb-username {
          color: var(--c-text-muted);
        }

        .sb-footer {
          border-color: var(--c-sidebar-border);
        }

        .sidebar-link {
          color: var(--c-nav-text);
        }

        .sidebar-link:hover {
          background-color: var(--c-nav-hover-bg) !important;
          color: var(--c-nav-hover-text) !important;
        }

        .sidebar-link.active {
          background-color: var(--c-nav-active-bg) !important;
          color: var(--c-nav-active-text) !important;
        }

        .brand-accent {
          color: var(--c-accent-strong) !important;
        }

        /* ── Unified Components ────────────────────────────────────────────── */
        .premium-card {
          background: var(--c-card);
          border: 1px solid var(--c-accent-soft-ring);
          border-radius: 1.25rem;
          transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.2s ease;
        }

        .premium-card:hover {
          box-shadow: 0 12px 40px -12px rgba(0,0,0,0.5);
        }

        .glass-panel {
          background: var(--glass-bg);
          backdrop-filter: blur(var(--glass-blur));
          border: 1px solid var(--glass-border);
          border-radius: 1.25rem;
        }

        .icon-box {
          width: 2.5rem;
          height: 2.5rem;
          border-radius: 0.75rem;
          display: flex;
          align-items: center;
          justify-content: center;
          transition: all 0.2s ease;
        }

        .icon-box-sm {
          width: 2rem;
          height: 2rem;
          border-radius: 0.625rem;
        }

        /* Ambient background blobs (like Login) */
        .ambient-blob {
          position: fixed;
          border-radius: 9999px;
          filter: blur(80px);
          pointer-events: none;
          z-index: -1;
          opacity: 0.15;
        }

        html[data-theme="light"] .ambient-blob {
          opacity: 0.05;
        }

        .blob-1 { width: 500px; height: 500px; background: var(--c-accent); top: -200px; right: -100px; }
        .blob-2 { width: 400px; height: 400px; background: #3b82f6; bottom: -100px; left: -100px; }

        input[type="color"] {
          padding: 2px 4px;
          cursor: pointer;
        }
      </style>
</head>

<body class="h-full antialiased overflow-x-hidden font-sans">

  <!-- Ambient background -->
  <div class="ambient-blob blob-1"></div>
  <div class="ambient-blob blob-2"></div>

  <!-- Mobile top bar -->
  <div id="mobileTopbar" class="lg:hidden flex items-center justify-between px-4 py-3 border-b sticky top-0 z-40 bg-[var(--c-topbar)]">
    <div class="flex items-center gap-3">
      <% if (typeof guildIcon !== 'undefined' && guildIcon) { %>
        <img src="<%= guildIcon %>" class="w-8 h-8 rounded-lg ring-1 ring-white/10" alt="Server icon" />
      <% } else { %>
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-xs" style="background:var(--c-accent)">N</div>
      <% } %>
      <div class="min-w-0">
        <p class="sb-guild-name font-bold leading-tight text-sm truncate uppercase tracking-wide">
          <%= typeof guildName !== 'undefined' ? guildName : 'Da Frens' %>
        </p>
      </div>
    </div>
    <button id="menuToggle" class="p-2 rounded-md" style="color:var(--c-text-muted)">
      <svg id="menuOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menuClose" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="flex h-full min-h-screen">
    <!-- Desktop sidebar -->
    <aside id="sidebar" class="hidden lg:flex flex-col w-64 border-r fixed top-0 left-0 h-full z-30 overflow-y-auto">
      <%- include('partials/sidebar') %>
    </aside>

    <!-- Mobile overlay + sidebar -->
    <div id="mobileOverlay" class="hidden fixed inset-0 bg-black/60 z-20 lg:hidden w-full h-full"></div>
    <aside id="mobileSidebar" class="hidden flex-col fixed top-0 left-0 h-full w-64 border-r z-30 overflow-y-auto pt-[56px] pb-6 lg:hidden">
      <%- include('partials/sidebar') %>
    </aside>

    <!-- Main content -->
    <main class="flex-1 lg:ml-64 overflow-y-auto">
      <div class="max-w-4xl mx-auto px-4 py-8">
        <%- body %>
      </div>
    </main>
  </div>

  <script>
    // ── CSRF wrapper for mutating fetch calls ──────────────────────────────────
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
    const _nativeFetch = window.fetch.bind(window);
    window.fetch = (input, init = {}) => {
      const req = new Request(input, init);
      const method = String(req.method || 'GET').toUpperCase();
      const isUnsafe = method === 'POST' || method === 'PUT' || method === 'PATCH' || method === 'DELETE';
      const isLocalUrl = (() => {
        try {
          const u = new URL(req.url, window.location.origin);
          return u.origin === window.location.origin;
        } catch {
          return false;
        }
      })();
      if (!isUnsafe || !isLocalUrl || !csrfToken) {
        return _nativeFetch(input, init);
      }
      const headers = new Headers(init.headers || req.headers || {});
      if (!headers.has('x-csrf-token')) headers.set('x-csrf-token', csrfToken);
      return _nativeFetch(input, { ...init, headers });
    };

    // ── Theme ──────────────────────────────────────────────────────────────────
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('dashboard-theme', theme);
      const sun = document.getElementById('themeIconSun');
      const moon = document.getElementById('themeIconMoon');
      if (sun) sun.style.display = theme === 'dark' ? '' : 'none';
      if (moon) moon.style.display = theme === 'light' ? '' : 'none';
    }
    // Re-apply after DOM is ready (inline script at top handled the pre-paint case)
    applyTheme(localStorage.getItem('dashboard-theme') || 'dark');

    document.getElementById('themeToggleBtn')?.addEventListener('click', () => {
      const t = document.documentElement.getAttribute('data-theme') || 'dark';
      applyTheme(t === 'dark' ? 'light' : 'dark');
    });

    // ── Mobile menu ────────────────────────────────────────────────────────────
    const menuToggle = document.getElementById('menuToggle');
    const mobileOverlay = document.getElementById('mobileOverlay');
    const mobileSidebar = document.getElementById('mobileSidebar');
    const menuOpenIcon = document.getElementById('menuOpen');
    const menuCloseIcon = document.getElementById('menuClose');

    function openMenu() { mobileSidebar.classList.remove('hidden'); mobileSidebar.classList.add('flex'); mobileOverlay.classList.remove('hidden'); menuOpenIcon.classList.add('hidden'); menuCloseIcon.classList.remove('hidden'); }
    function closeMenu() { mobileSidebar.classList.add('hidden'); mobileSidebar.classList.remove('flex'); mobileOverlay.classList.add('hidden'); menuOpenIcon.classList.remove('hidden'); menuCloseIcon.classList.add('hidden'); }

    menuToggle?.addEventListener('click', () => mobileSidebar.classList.contains('hidden') ? openMenu() : closeMenu());
    mobileOverlay?.addEventListener('click', closeMenu);

    // ── Active nav ─────────────────────────────────────────────────────────────
    function setActiveNav() {
      const hash = window.location.hash || '#status';
      document.querySelectorAll('.sidebar-link').forEach(l => l.classList.toggle('active', l.getAttribute('href') === hash));
      if (window.innerWidth < 1024 && mobileSidebar && !mobileSidebar.classList.contains('hidden')) {
        closeMenu();
      }
    }
    setActiveNav();
    window.addEventListener('hashchange', setActiveNav);
  </script>

</body>

</html>