<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — Nova Dashboard</title>
  <% if (botIcon) { %>
    <link rel="icon" type="image/png" href="<%= botIcon %>" />
    <% } %>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
      <style>
        :root {
          --c-bg: #050506;
          --c-card: rgba(16, 16, 20, 0.88);
          --c-card-border: #25252c;
          --c-accent: <%=accentHex || '#7C3AED' %>;

          --c-accent-rgb: <%=accentRgb ? `$ {
            accentRgb.r
          }

          ,
          $ {
            accentRgb.g
          }

          ,
          $ {
            accentRgb.b
          }

          ` : '124, 58, 237' %>;
        }

        *,
        *::before,
        *::after {
          box-sizing: border-box;
          margin: 0;
          padding: 0;
        }

        body {
          min-height: 100vh;
          font-family: Inter, ui-sans-serif, system-ui, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
          background: var(--c-bg);
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 1.5rem;
          overflow: hidden;
        }

        /* Ambient background blobs */
        .bg-blob {
          position: fixed;
          border-radius: 9999px;
          filter: blur(80px);
          pointer-events: none;
          z-index: 0;
        }

        .bg-blob-1 {
          width: 600px;
          height: 600px;
          background: rgba(var(--c-accent-rgb), 0.22);
          top: -200px;
          left: -200px;
        }

        .bg-blob-2 {
          width: 500px;
          height: 500px;
          background: rgba(var(--c-accent-rgb), 0.14);
          bottom: -150px;
          right: -100px;
        }

        .bg-blob-3 {
          width: 300px;
          height: 300px;
          background: rgba(var(--c-accent-rgb), 0.1);
          top: 40%;
          right: 10%;
        }

        /* Grid pattern overlay */
        .bg-grid {
          position: fixed;
          inset: 0;
          z-index: 0;
          background-image:
            linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
          background-size: 40px 40px;
        }

        /* Card */
        .card {
          position: relative;
          z-index: 1;
          width: 100%;
          max-width: 400px;
          background: rgba(16, 16, 20, 0.6);
          border: 1px solid rgba(255, 255, 255, 0.08);
          border-radius: 2rem;
          padding: 3rem 2.5rem;
          backdrop-filter: blur(24px);
          box-shadow:
            0 0 0 1px rgba(var(--c-accent-rgb), 0.1),
            0 25px 50px -12px rgba(0, 0, 0, 0.7);
          transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .card:hover {
          transform: translateY(-4px) scale(1.01);
          border-color: rgba(var(--c-accent-rgb), 0.3);
        }

        /* Avatar glow */
        .avatar-wrap {
          position: relative;
          display: inline-block;
          margin-bottom: 1.25rem;
        }

        .avatar-glow {
          position: absolute;
          inset: -8px;
          border-radius: 9999px;
          background: radial-gradient(circle, rgba(var(--c-accent-rgb), 0.65) 0%, transparent 70%);
          filter: blur(12px);
        }

        .avatar-img {
          position: relative;
          width: 72px;
          height: 72px;
          border-radius: 9999px;
          border: 2px solid rgba(var(--c-accent-rgb), 0.55);
          display: block;
        }

        .avatar-placeholder {
          position: relative;
          width: 72px;
          height: 72px;
          border-radius: 9999px;
          border: 2px solid rgba(var(--c-accent-rgb), 0.55);
          background: linear-gradient(135deg, var(--c-accent), rgba(var(--c-accent-rgb), 0.65));
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 1.75rem;
          font-weight: 700;
          color: #fff;
        }

        /* Typography */
        .guild-name {
          font-size: 1.375rem;
          font-weight: 700;
          color: #f1f5f9;
          margin-bottom: 0.25rem;
        }

        .dashboard-label {
          font-size: 0.75rem;
          font-weight: 600;
          letter-spacing: 0.1em;
          text-transform: uppercase;
          color: var(--c-accent);
          margin-bottom: 2rem;
        }

        /* Divider */
        .divider {
          height: 1px;
          background: linear-gradient(90deg, transparent, rgba(var(--c-accent-rgb), 0.42), transparent);
          margin-bottom: 1.75rem;
        }

        /* Error box */
        .error-box {
          margin-bottom: 1.25rem;
          padding: 0.75rem 1rem;
          background: rgba(239, 68, 68, 0.08);
          border: 1px solid rgba(239, 68, 68, 0.25);
          border-radius: 0.75rem;
          color: #fca5a5;
          font-size: 0.8125rem;
          display: flex;
          align-items: flex-start;
          gap: 0.5rem;
        }

        .discord-btn {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 0.75rem;
          width: 100%;
          padding: 1rem 1.5rem;
          background: var(--c-accent);
          border-radius: 1rem;
          font-size: 0.9375rem;
          font-weight: 700;
          color: #fff;
          text-decoration: none;
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          box-shadow: 0 4px 20px rgba(var(--c-accent-rgb), 0.3);
          border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .discord-btn:hover {
          background: var(--c-accent);
          filter: brightness(1.1);
          transform: translateY(-2px);
          box-shadow: 0 10px 30px rgba(var(--c-accent-rgb), 0.4);
        }

        .discord-btn:active {
          transform: scale(0.98);
        }

        /* Footer note */
        .footer-note {
          margin-top: 1.5rem;
          font-size: 0.75rem;
          color: #475569;
          text-align: center;
        }

        .footer-note strong {
          color: #64748b;
          font-weight: 500;
        }

        .page-footer {
          position: relative;
          z-index: 1;
          margin-top: 1.5rem;
          text-align: center;
          font-size: 0.6875rem;
          color: #1e293b;
        }
      </style>
</head>

<body>

  <!-- Ambient background -->
  <div class="bg-blob bg-blob-1"></div>
  <div class="bg-blob bg-blob-2"></div>
  <div class="bg-blob bg-blob-3"></div>
  <div class="bg-grid"></div>

  <div style="position:relative;z-index:1;width:100%;display:flex;flex-direction:column;align-items:center">
    <div class="card">

      <!-- Server icon -->
      <div style="text-align:center">
        <div class="avatar-wrap">
          <div class="avatar-glow"></div>
          <% if (botIcon || guildIcon) { %>
            <img src="<%= botIcon || guildIcon %>" class="avatar-img" alt="Bot icon" />
            <% } else { %>
              <div class="avatar-placeholder">N</div>
              <% } %>
        </div>

        <h1 class="guild-name">Nova</h1>
        <p class="dashboard-label">Dashboard</p>
      </div>

      <div class="divider"></div>

      <!-- Error -->
      <% if (error) { %>
        <div class="error-box">
          <svg style="width:1rem;height:1rem;flex-shrink:0;margin-top:1px" fill="none" viewBox="0 0 24 24"
            stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <%= error %>
        </div>
        <% } %>

          <!-- Sign in button -->
          <a href="/auth/discord" class="discord-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
              <path
                d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.114 18.1.128 18.116a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
            </svg>
            Sign in with Discord
          </a>

          <p class="footer-note">
            Authenticate with Discord to access the dashboard!
          </p>

    </div>

  </div>

</body>

</html>