{
  "name": "nova",
  "version": "1.0.0",
  "description": "Helpful multi-purpose bot for the Da Frens Discord server.",
  "main": "index.js",
  "scripts": {
    "start": "doppler run -- node index.js",
    "update": "npm outdated && npm update --save",
    "set-value": "node set-value.js",
    "remove-value": "node remove-value.js",
    "list-values": "node list-values.js",
    "prune-db": "node prune-db.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doubleangels/nova.git"
  },
  "author": "doubleangels",
  "bugs": {
    "url": "https://github.com/doubleangels/nova/issues"
  },
  "homepage": "https://github.com/doubleangels/nova#readme",
  "overrides": {
    "@tootallnate/once": ">=3.0.1",
    "tar": ">=7.5.10",
    "undici": "~6.25.0",
    "@isaacs/brace-expansion": ">=5.0.1"
  },
  "dependencies": {
    "@keyv/sqlite": "^4.0.8",
    "@sentry/node": "^10.53.1",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "dayjs": "^1.11.20",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "he": "^1.2.0",
    "keyv": "^5.6.0",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7"
  }
}
