{
  "name": "nova",
  "version": "1.0.0",
  "description": "Helpful multi-purpose bot for the Da Frens Discord server.",
  "main": "index.js",
  "packageManager": "pnpm@10.6.4",
  "scripts": {
    "start": "doppler run -- node index.js",
    "update": "pnpm outdated && pnpm update",
    "set-value": "node set-value.js",
    "remove-value": "node remove-value.js",
    "list-values": "node list-values.js",
    "prune-db": "node prune-db.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:debug": "pnpm exec jest --inspect-brk --runInBand"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sqlite3"
    ],
    "overrides": {
      "@tootallnate/once": ">=3.0.1",
      "@isaacs/brace-expansion": ">=5.0.6",
      "brace-expansion": ">=5.0.6",
      "ip-address": ">=10.1.1",
      "socks": ">=2.8.9",
      "tar": ">=7.5.11",
      "form-data": ">=4.0.6",
      "undici": "^6.27.0"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doubleangels/nova.git"
  },
  "author": "doubleangels",
  "bugs": {
    "url": "https://github.com/doubleangels/nova/issues"
  },
  "homepage": "https://github.com/doubleangels/nova#readme",
  "overrides": {
    "@tootallnate/once": ">=3.0.1",
    "ip-address": ">=10.1.1",
    "socks": ">=2.8.9",
    "tar": ">=7.5.11",
    "undici": "^6.27.0",
    "@isaacs/brace-expansion": ">=5.0.6",
    "brace-expansion": ">=5.0.6",
    "form-data": ">=4.0.6"
  },
  "dependencies": {
    "@keyv/sqlite": "^4.0.8",
    "@sentry/node": "^10.62.0",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "dayjs": "^1.11.21",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "he": "^1.2.0",
    "keyv": "^5.6.0",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1"
  }
}
